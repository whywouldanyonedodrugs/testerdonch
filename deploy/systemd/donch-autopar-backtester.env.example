# Optional overrides for donch-autopar backtester service.
# Copy to: /etc/default/donch-autopar-backtester

# Telegram notifications (recommended)
# DONCH_TG_BOT_TOKEN=123456:ABCDEF...
# DONCH_TG_CHAT_ID=123456789

# If omitted, these defaults are used by script/service:
# - remote src: root@167.235.64.82:/srv/donch-autopar/
# - local mirror: /data/autopar
# - results root: /opt/testerdonch/results/donch_autopar
