le":"en-US"}],"bannerNotification":{"message":[{"markDefs":[{"_type":"externalLink","_key":"29d31598464d","newTab":false,"url":"https://support.kraken.com/hc/articles/201889308-I-can-t-sign-in-to-my-account-"}],"children":[{"_type":"span","marks":[],"text":"Due to an increase in demand, you may experience delays with Live Support. Please consider our article on ","_key":"a7d3b3094bd10"},{"_type":"span","marks":["29d31598464d"],"text":"how to sign in to your account","_key":"6de1ad09acf4"},{"text":".","_key":"71596789c07d","_type":"span","marks":[]}],"_type":"block","style":"normal","_key":"55afa1276143"}],"bannerStyle":"yellow","hideAll":false,"enabledLocales":["en-US","fr-FR","pt-BR","it-IT","es-ES"]}},"query":"*[(_type == 'article' || _type == 'articlePortable') \u0026\u0026 !(_id in path('drafts.**')) \u0026\u0026 (url.current == $url) \u0026\u0026 visible == true]{\n  _id, _createdAt, _rev, _updatedAt,\n  contentPortable[]{\n  ...,\n  markDefs[]{\n    ...,\n    _type == \"articleLink\" =\u003e {\n      ...,\n      referenceArticle-\u003e{ url }\n    },\n    _type == \"fileLink\" =\u003e {\n      ...,\n      asset-\u003e{ url }\n    },\n  },\n  _type == \"callout\" =\u003e {\n    ...,\n    messagePortable[]{\n      ...,\n      markDefs[]{\n        ...,\n        _type == \"articleLink\" =\u003e {\n          ...,\n          referenceArticle-\u003e{ url }\n        },\n        _type == \"fileLink\" =\u003e {\n          ...,\n          asset-\u003e{ url }\n        },\n      },\n    }\n  },\n  _type == \"button\" =\u003e {\n    ...,\n    buttonLink{\n      ...,\n      referenceArticle-\u003e{ url },\n      file{\n        ...,\n        asset-\u003e{ url }\n      }\n    }\n  },\n  _type == \"scImage\" =\u003e {\n    asset-\u003e{\n      _id,\n      'dimensions': metadata.dimensions{\n        aspectRatio,\n        height,\n        width\n      }\n    }\n  },\n  _type == \"video\" =\u003e {\n    ...,\n    native{\n      ...,\n      file{\n        ...,\n        asset-\u003e{ url }\n      }\n    }\n  }\n},\n  htmlContent,\n  url,\n  phraseJob,\n  title,\n  tags,\n  \"sourceLocale\": sourceLocale-\u003ecode,\n  \"disabledLocales\": disabledLocales[]-\u003ecode,\n  section-\u003e{ _id, name, url, description, phraseJob, \"sourceLocale\": sourceLocale-\u003ecode },\n  parentSection-\u003e{ _id, name, url, description, phraseJob, \"sourceLocale\": sourceLocale-\u003ecode },\n  \"category\": section-\u003ecategory-\u003e{ _id, name, url, description, phraseJob, \"sourceLocale\": sourceLocale-\u003ecode }\n}","queryParams":{"url":"4844359082772-Linear-Multi-Collateral-Perpetual-Contract-Specifications"},"namespace":"article-4844359082772","breadcrumbItems":{"category":{"_id":"category-360001977131","name":"Futures","url":{"current":"/360001977131-Futures","_type":"slug"}},"sections":[{"_id":"section-360013002511","name":"General","url":{"current":"/360013002511-Kraken-Futures-General","_type":"slug"}},{"_id":"section-4668394905876","name":"Multi-Collateral Futures","url":{"current":"/4668394905876-Multi-Collateral-Futures","_type":"slug"}}]}},"bannerNotification":{"message":[{"markDefs":[{"_type":"externalLink","_key":"29d31598464d","newTab":false,"url":"https://support.kraken.com/hc/articles/201889308-I-can-t-sign-in-to-my-account-"}],"children":[{"_type":"span","marks":[],"text":"Due to an increase in demand, you may experience delays with Live Support. Please consider our article on ","_key":"a7d3b3094bd10"},{"_type":"span","marks":["29d31598464d"],"text":"how to sign in to your account","_key":"6de1ad09acf4"},{"text":".","_key":"71596789c07d","_type":"span","marks":[]}],"_type":"block","style":"normal","_key":"55afa1276143"}],"bannerStyle":"yellow","hideAll":false,"enabledLocales":["en-US","fr-FR","pt-BR","it-IT","es-ES"]},"messages":{"article-4844359082772-title":"Linear Multi-Collateral Perpetual Contract Specifications","article-4844359082772-content":"\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003ePerpetual Futures are a type of Futures contract that have \u003c/span\u003e\u003cstrong\u003eno expiration date\u003c/strong\u003e\u003cspan style=\"font-weight: 400;\"\u003e and have an \u003c/span\u003e\u003cstrong\u003eauto-rolling\u003c/strong\u003e\u003cspan style=\"font-weight: 400;\"\u003e feature \u003c/span\u003e\u003cstrong\u003eevery hour\u003c/strong\u003e\u003cspan style=\"font-weight: 400;\"\u003e. These contracts feature a funding rate, which is a user-to-user payment designed to keep the price of the perpetual futures contract aligned to its underlying asset\u0026rsquo;s index price (i.e. the spot price of the underlying asset). If the premium is above zero, then the long positions payout to short positions, and if the premium is below zero, then the short positions pay out to the long positions. Traders will either pay or receive funding depending on the market movements. The price divergence is calculated every hour and funding credits/debits accumulate as unrealised profit/loss settling at the end of each hour or when the net position changes.\u0026nbsp;\u003c/span\u003e\u003c/p\u003e\n\n\u003cp\u003e\u003cspan style=\"font-weight: 400;\"\u003eBelow you can find three sections: a detailed table with the specifications of each contract, funding rate and other important information followed by multiple examples to demonstrate the mechanics of a perpetual contract. All multi-collateral futures use the multi-collateral wallet for margining.\u003c/span\u003e\u003c/p\u003e\n\n\u003cdiv\u003e\n\u003cdiv class=\"callout callout--kraken\"\u003e\n\u003cp class=\"callout__title\"\u003eClick below to expand each section:\u003c/p\u003e\n\u003c/div\u003e\n\n\u003cdiv class=\"accordion accordion-default\"\u003e\n\u003cdiv class=\"accordion-item\"\u003e\n\u003cdiv class=\"accordion-item-title\"\u003e\u003cstrong\u003eContract Specifications Table\u003c/strong\u003e\u003c/div\u003e\n\n\u003cdiv class=\"accordion-item-content\"\u003e\n\u003cp\u003e\u003c/p\u003e\n\n\u003cdiv\u003e\n\u003cdiv class=\"callout callout--info\"\u003e\n\u003ch4 class=\"callout__title\"\u003ePlease note:\u003c/h4\u003e\n\n\u003cp\u003eAll multi-collateral contracts have a lot size of 1 unit of the base currency. For example, 1 contract of ETH is equal to 1 ETH.\u003c/p\u003e\n\n\u003cp\u003eThe quote currency for all contracts is the U.S. Dollar (USD).\u003c/p\u003e\n\n\u003cp\u003eSome linear contracts can be in post-only mode, meaning no trades can be executed but orders can be placed. When sufficient liquidity has been established, post-only will be removed on a contract by contract basis.\u003c/p\u003e\n\n\u003cp\u003eIndex constituents can be found \u003ca href=\"https://support.kraken.com/hc/en-us/articles/9551424898964-Index-Constituents\" target=\"_self\"\u003ehere.\u003c/a\u003e\u003c/p\u003e\n\u003c/div\u003e\n\n\u003cp\u003e\u003c/p\u003e\n\n\u003cdiv class=\"table-color-header table-striped scroll-table low-body-padding low-header-padding\"\u003e\n\u003cdiv class=\"pane-horizontal-scroll\"\u003e\n\u003ctable cellpadding=\"0\" cellspacing=\"0\" style=\"margin-left: 0px; margin-right: auto;\"\u003e\n\t\u003cthead\u003e\n\t\t\u003ctr style=\"height: 20px;\"\u003e\n\t\t\t\u003cth style=\"width: 142px;\"\u003e\u003cstrong\u003e\u003cspan class=\"wysiwyg-color-black10 wysiwyg-font-size-medium\"\u003eSymbol\u003c/span\u003e\u003c/strong\u003e\u003c/th\u003e\n\t\t\t\u003cth style=\"width: 88px;\"\u003e\u003cstrong\u003e\u003cspan class=\"wysiwyg-color-black10 wysiwyg-font-size-medium\"\u003eStatus\u003c/span\u003e\u003c/strong\u003e\u003c/th\u003e\n\t\t\t\u003cth style=\"width: 128px;\"\u003e\u003cstrong\u003e\u003cspan class=\"wysiwyg-color-black10 wysiwyg-font-size-medium\"\u003eBase Currency\u003c/span\u003e\u003c/strong\u003e\u003c/th\u003e\n\t\t\t\u003cth style=\"width: 78px;\"\u003e\u003cstrong\u003e\u003cspan class=\"wysiwyg-color-black10 wysiwyg-font-size-medium\"\u003eMin order\u003c/span\u003e\u003c/strong\u003e\u003c/th\u003e\n\t\t\t\u003cth\u003e\u003cstrong