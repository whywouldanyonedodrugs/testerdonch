ARS\u003c/p>\n"},{"_key":"7d06bc17d2ea","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Deposit fee ","field_content":"\u003cp>1.5%\u003c/p>\n"},{"_key":"9c10d187a1b9","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Processing time ","field_content":"\u003cp>Near-instant\u003c/p>\n"},{"_key":"42570dd3a438","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Withdrawal hold ","field_content":"\u003cp> None \u003c/p>"}],"row_description":"Row ::  Worldwide* "}],"table_description":"Table: Legacy Migrated Placeholder","table_expanded_table":false,"table_mobile_style":"classic"},{"_key":"5940557085a5","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>*Funding methods by \u003ca href=\"https://support.kraken.com/articles/360001395743-verification-levels-explained\">account type\u003c/a>\u003c/strong>\u003c/p>\n"},{"_key":"4dd9f37e6988","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"fc5224436a50","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"5bf371757f00","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Pro personal and Business accounts will support SWIFT funding only.\u003c/p>\n"}]},{"_key":"5a3909a0d08e","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"3df18e425def","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Verified accounts will have full access to ARS funding.\u003c/p>\n"}]}],"field_type":"ul"},{"_key":"23f866e7b36c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Accounts that support ARS will not have any alternative funding methods enabled. If you have questions or require assistance, please contact our \u003ca target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https://support.kraken.com/forms/38536269187476\">support team for further guidance.\u003c/a>\u003c/p>\u003cp>\u003c/p>\u003cp>\u003cstrong>Please note:\u003c/strong> While ARS transfers are typically processed near-instantly, we have no control over the regulatory checks and compliance procedures at banks, which may occasionally extend processing times\u003c/p>"}],"field_title":"ARS (Argentine Peso) withdrawal options"},{"_key":"76344166e612","_type":"paragraphAccordionItem","field_children":[{"_key":"2432e16e7968","_type":"paragraphArticleBodyTable","field_rows":[{"_key":"NajXNQua71kT5H8l9BdVH","field_cells":[{"_key":"kGkOaCe7cuAc2r1NInvqu","cell_description":"Content of Column 1","field_content":"Availability"},{"_key":"lkjxOqk5xuEsH9Z7C16RY","cell_description":"Content of Column 2","field_content":"Withdrawal method"},{"_key":"2p2R1vKkxoRwQf7JwcLtk","cell_description":"Content of Column 3","field_content":"Withdrawal minimum"},{"_key":"_i90X6PwS3sSiBI5mvD1U","cell_description":"Content of Column 4","field_content":"Withdrawal fee"},{"_key":"6gC_6z7a_RTHpLw93DQEB","cell_description":"Content of Column 5","field_content":"Processing time"},{"_key":"C5clkElo1AeC1dMgMHFqI","cell_description":"Content of Column 6","field_content":"Withdrawal hold"}],"row_description":"Row :: Availability"},{"_key":"LHViaOIW8cNUhhBL4BQAK","field_cells":[{"_key":"cYvDwn9VH6sxZ0iF0zgzX","cell_description":"Content of Column 1","field_content":"\u003cp>Brazil only\u003c/p>\n"},{"_key":"wetE4dZ17_zKbubL8V374","cell_description":"Content of Column 2","field_content":"\u003cp>\u003ca href=\"https://support.kraken.com/articles/what-is-the-pix-funding-method\">PIX\u003c/a>\u003c/p>\n"},{"_key":"oMGL2zc3yybVLgYupst-W","cell_description":"Content of Column 3","field_content":"R$50"},{"_key":"LmptIm-F4AtgN7Dufp956","cell_description":"Content of Column 4","field_content":"0.50%"},{"_key":"VLs8aAHO-5xuOxMdaM4-9","cell_description":"Content of Column 5","field_content":"Near Instant"},{"_key":"wSnXgZ6RZLL478u4F-irS","cell_description":"Content of Column 6","field_content":"None"}],"row_description":"Row :: Brazil"}],"table_expanded_table":true,"table_mobile_style":"classic"}],"field_is_expanded":false,"field_title":"BRL (Brazilian Real) withdrawal options"},{"_key":"4ea75da4ed8d","_type":"paragraphAccordionItem","field_children":[{"_key":"ab8ba01b0d46","_type":"paragraphArticleBodyTable","field_rows":[{"_key":"c9Ox2W6MoqW0LPYLuv6fb","field_cells":[{"_key":"JyKUz3yRoZLs5Fe4_3CcZ","cell_description":"Content of Column 1","field_content":"Availability"},{"_key":"8x9UzsC1vV0SxuFc6p4XH","cell_description":"Content of Column 2","field_content":"Withdrawal method"},{"_key":"Wdy_YyJxtP66Jxjj8LPEb","cell_description":"Content of Column 3","field_content":"Withdrawal minimum"},{"_key":"cLZRWf8Xs21UDaXTnP9Tu","cell_description":"Content of Column 4","field_content":"Withdrawal fee"},{"_key":"QyC4GaHXJyb9u-M_t-gE9","cell_description":"Content of Column 5","field_content":"Processing time"},{"_key":"c1W97lh0Z2DRA9dEaCI2W","cell_description":"Content of Column 6","field_content":"Withdrawal hold"}],"row_description":"Row :: Availability"},{"_key":"54b077548d2a","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"2380974aba77","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Mexico only\u003c/p>\n"},{"_key":"e62ea39acd35","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Bank transfer (SPEI)\u003c/p>\n"},{"_key":"d8e3674c6f6d","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>150 MXN\u003c/p>\n"},{"_key":"0d3a582052b7","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>0.5%\u003c/p>\n"},{"_key":"ddc0b16f5661","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Near instant\u003c/p>\n"},{"_key":"91d93d754ddf","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>None\u003c/p>\n"}],"row_description":"Row :: add here"}],"table_expanded_table":true,"table_mobile_style":"classic"},{"_key":"fefe3b2c1aec","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Please note:\u003c/strong> While MXN transfers are typically processed near-instantly, we have no control over the regulatory checks and compliance procedures at banks, which may occasionally extend processing times\u003c/p>"}],"field_is_expanded":false,"field_title":"MXN (Mexican Pesos) withdrawal options"}]},{"_key":"bdf4e12f2b0f","_type":"paragraphArticleHeadingBody","field_body":"","field_heading":" Frequently Asked Questions ","field_level":3},{"_key":"4a2c61bc5e51","_type":"paragraphAccordion","field_children":[{"_key":"46af0599f3f8","_type":"paragraphAccordionItem","field_children":[{"_key":"7c98b1202956","_type":"paragraphArticleBodyLc","field_body":"\u003cp>The payments providers that we work with charge us fees for withdrawals.\u003c/p>"}],"field_id":"nDT6u2w7RZBYR2YmHqL6c","field_title":"Why does Kraken charge withdrawal fees?"},{"_key":"646361023a59","_type":"paragraphAccordionItem","field_children":[{"_key":"9c07ea172d8e","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Withdrawal limits depend on your \u003ca href=\"/articles/360001449826\" >\u003cstrong>verification level\u003c/strong>\u003c/a>.\u003c/p>"}],"field_id":"TbLT7z5DhviY9nexj20Tz","field_title":"What are the withdrawal limits?"},{"_key":"dafacc449db8","_type":"paragraphAccordionItem","field_children":[{"_key":"b2c69ab6a45c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Intermediary or correspondent banks (banks between our bank and your bank that processes the transaction in transit) may sometimes charge fees or convert the transaction to a different currency en route.\u003c/p>"}],"field_id":"2A1OXtz8f6Mv7xVNlanbm","field_title":"Are there any other fees?"}]},{"_key":"d19a50a51c58","_type":"paragraphArticleHeadingBody","field_body":"\u003cp>The Krap App offers a quick, cost-free way to move funds directly between Kraken accounts. \u003ca target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https://support.kraken.com/krakapp\">Click here to learn more.\u003c/a>\u003c/p>\u003cblockquote>\u003cp>\u003cem>The decimal and thousands separators shown in this article may differ from the formats displayed on our trading platforms. Review our article on how we use points and commas for more information.\u003c/em>\u003c/p>\u003c/blockquote>\u003cp>\u003c/p>","field_heading":"Krak App","field_heading_html_id":"b7ecd3f189c1","field_level":2}],"field_last_updated_label":"Last updated:","field_title":"Cash withdrawal options (fees, minimums and processing times)","field_tldr_title":"Key takeaways"}],"field_page_meta":{"description":"Support Center for Kraken.com | Bitcoin & Cryptocurrency Exchange | Bitcoin Trading Platform","title":"Cash withdrawal options (fees, minimums and processing times) | Kraken"},"field_tags":[{"_key":"06ac823b8a25","_ref":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","_type":"taxonomyTag","_id":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","firstPublishedAt":"2026-01-20T10:38:23.492Z","lastPublishedAt":"2026-01-20T10:38:23.492Z","name":"sc-tier-1"}],"field_target_languages":["de_de","es_es","fr_fr","it_it","nl_nl","pl_pl","pt_br","ru_ru","tr_tr","uk_ua","vi_vn","zh_cn"],"is_article":true,"lastPublishedAt":"2026-03-17T11:43:12.451Z","locale":{"_ref":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","_type":"taxonomyLocales","_id":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","code":"en-us","field_label":"English","name":"en-US"},"path":"/articles/360000423043-cash-withdrawal-options-fees-minimums-and-processing-times-","status":true,"title":"Cash withdrawal options (fees, minimums and processing times)"}},{"_key":"95d14285d630","reference":{"_ref":"article-360048212832","_type":"page","_id":"article-360048212832","_system":{"base":{"id":"article-360048212832","rev":"8GspKpLKzWgCGxfZLl2iFf"}},"appId":"support","content_source_locale":"en_us","enabled_locales":[],"field_page_components":[{"_key":"68cecadd4b80","_type":"paragraphArticleLayout","field_article_breadcrumb_label":"Support","field_article_breadcrumbs":true,"field_children":[{"_key":"95f9f89d4975","_type":"paragraphArticleBodyLc","field_body":"\u003cp>You can instantly purchase a range of cryptocurrencies using your Visa and Mastercard.\u003c/p>"},{"_key":"c29e33cef545","_type":"paragraphNotification","field_can_be_closed":false,"field_direction":"inline","field_has_icon":true,"field_text":"\u003cp>&nbsp;\u003c/p>\n\n\u003cp>Withdrawals up to 100% of your first card purchase are locked for 72 hours for security. For example, a $1,000 purchase restricts equivalent withdrawals in cash or crypto for 72 hours. Additional purchases during this period remain locked for the rest of the timeframe.\u003c/p>\n\n\u003cp>&nbsp;\u003c/p>\n","field_title":"Withdrawal hold","field_tone":"warning"},{"_key":"738b88091590","_type":"paragraphNotification","field_can_be_closed":false,"field_closed_state_is_persistent":true,"field_direction":"stacked","field_has_icon":true,"field_text":"\u003cp>For more information on spread and processing fees, \u003ca href=\"https://www.kraken.com/features/fee-schedule\">click here.\u003c/a>\u003c/p>\n","field_tone":"primary"},{"_key":"941aa8d4463a","_type":"paragraphAccordion","field_children":[{"_key":"b98145c4ce7e","_type":"paragraphAccordionItem","field_children":[{"_key":"d2cc8e727204","_type":"paragraphArticleBodyLc","field_body":"\u003cp>To add a payment card to your Kraken account, ensure the following:\u003c/p>"},{"_key":"e256e0f129e5","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"3360a95a792d","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"19f4dff7fdf5","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Your Kraken account must be \u003ca href=\"https://support.kraken.com/articles/360021973671-how-to-get-verified-on-kraken\" target=\"_blank\">verified\u003c/a>.\u003c/p>\n"}]},{"_key":"c0ac11ef1eff","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"90d6c4b7964d","_type":"paragraphArticleBodyLc","field_body":"\u003cp>You must hold a valid Visa or Mastercard in the same legal name as your Kraken account.\u003c/p>"}]},{"_key":"b265c92ad3a2","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"9a450f47bd11","_type":"paragraphArticleBodyLc","field_body":"\u003cp>You must reside in a \u003ca href=\"/articles/360001368823\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">supported region\u003c/a>.\u003c/p>"}]},{"_key":"a95bf035cebc","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"1ebaa64817c6","_type":"paragraphArticleBodyLc","field_body":"\u003cp>For non-US clients, debit and credit cards that are enabled with \u003ca href=\"/articles/360048212832-Debit-or-credit-card-purchases-with-Visa-and-Mastercard-#3ds\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">3D Secure\u003c/a> are accepted.\u003c/p>"}]},{"_key":"ad18a87612df","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"02e1fc44f3f0","_type":"paragraphArticleBodyLc","field_body":"\u003cp>For US clients only debit cards are supported at this time.\u003c/p>"}]}],"field_type":"ul"},{"_key":"e4716534fbde","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_id":"6hqbnosANG5WQF0ZHfnUX","field_title":"Requirements"},{"_key":"e772e6f65d81","_type":"paragraphAccordionItem","field_children":[{"_key":"93c96e8ab0fd","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Kraken fees for buying, selling, or converting assets using your card consist of a displayed fee and, where applicable, a spread which is included in the price. Spread fees may apply, depending on factors like transaction size, asset, payment method, and market conditions.\u003c/p>\u003cblockquote>\u003cstrong>Note: Transactions may not be cancelled once initiated. All purchases are final and non-refundable.\u003c/strong>\u003c/blockquote>\u003cp>\u003c/p>\u003cp>\u003cstrong>Card purchase fees:\u003c/strong>\u003c/p>"},{"_key":"cd8805c2e68f","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"206a3d631ba3","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"a53b8fc63d77","_type":"paragraphArticleBodyLc","field_body":"\u003cp>The total transaction fee is displayed on the final confirmation page before completing the purchase. There are no hidden fees.\u003c/p>"}]}],"field_type":"ul"},{"_key":"d24039f10a5f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Card and transaction limits:\u003c/strong>\u003c/p>"},{"_key":"71cb69fc401b","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"6382ea8c48b3","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"9d19d797f574","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Card limits are dynamic and may adjust over time with continued product usage. In most cases, this means that your limits will increase the more that you use Kraken, but in some cases your limits may also decrease. Limits are determined by a number of factors, including but not limited to: how long you&rsquo;ve had a Kraken account, your payment method, country of residence, and your transaction activity. Limits reset on a rolling weekly basis and cannot be increased by reaching out to client support. If you reach your limit for card payments, we recommend depositing funds with a different payment method until your weekly limit resets.&nbsp;\u003c/p>\n"}]},{"_key":"938429805450","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"4945bc64c999","_type":"paragraphArticleBodyLc","field_body":"\u003cp>For worldpay payment methods (Card, Apple Pay, and Google Pay), clients are subject to a maximum number of successful transactions within any rolling 24-hour period.\u003c/p>"}]}],"field_type":"ul"},{"_key":"150afb976891","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Currency-specific limits:\u003c/strong>\u003c/p>"},{"_key":"f67302abaa77","_type":"paragraphArticleBodyTable","field_rows":[{"_key":"cfef76f81e2b","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"d6a4812f9e78","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Currency","field_content":"\u003cp>\u003cstrong>Currency\u003c/strong>\u003c/p>"},{"_key":"ab6c922bfddf","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Minimum purchase amount","field_content":"\u003cp>\u003cstrong>Minimum purchase amount\u003c/strong>\u003c/p>"},{"_key":"4726d08a1be2","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Seven day purchase limit","field_content":"\u003cp>\u003cstrong>Seven day purchase limit\u003c/strong>\u003c/p>"}],"row_description":"Row :: Currency"},{"_key":"aa793119dc0c","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"0bc65311f8ab","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Currency","field_content":"\u003cp>AUD\u003c/p>"},{"_key":"dac1084d822d","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Minimum purchase amount","field_content":"\u003cp>A$14.00\u003c/p>"},{"_key":"4055676a777c","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Seven day purchase limit","field_content":"\u003cp>A$1,500 - A$7,000\u003c/p>\n"}],"row_description":"Row ::  AUD "},{"_key":"8c4e8420a169","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"f9acfa081633","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Currency","field_content":"\u003cp>CAD\u003c/p>"},{"_key":"efbdff74561a","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Minimum purchase amount","field_content":"\u003cp>C$12.50\u003c/p>"},{"_key":"fb58e6daf316","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Seven day purchase limit","field_content":"\u003cp>C$1,500 - C$6,500\u003c/p>\n"}],"row_description":"Row ::  CAD "},{"_key":"8b406e3908d4","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"e98d8b9b67b1","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Currency","field_content":"\u003cp>CHF\u003c/p>"},{"_key":"f7ca9b852c98","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Minimum purchase amount","field_content":"\u003cp>CHF 10.00\u003c/p>"},{"_key":"80ba9d61372f","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Seven day purchase limit","field_content":"\u003cp>CHF 1,000 - CHF 5,000\u003c/p>\n"}],"row_description":"Row ::  CHF "},{"_key":"cbed8e125952","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"c95cac754d04","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Currency","field_content":"\u003cp>EUR\u003c/p>"},{"_key":"161c1976a7be","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Minimum purchase amount","field_content":"\u003cp>€10.00\u003c/p>"},{"_key":"6126500e1935","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Seven day purchase limit","field_content":"\u003cp>&euro;1,000 - &euro;5,000\u003c/p>\n"}],"row_description":"Row ::  EUR "},{"_key":"72d39314289f","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"ae032e4e514f","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Currency","field_content":"\u003cp>GBP\u003c/p>"},{"_key":"71208447be2b","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Minimum purchase amount","field_content":"\u003cp>£8.00\u003c/p>"},{"_key":"f8eb792c720f","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Seven day purchase limit","field_content":"\u003cp>&pound;800 - &pound;4,000\u003c/p>\n"}],"row_description":"Row ::  GBP "},{"_key":"444f71c97a54","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"d3034909fb5f","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Currency","field_content":"\u003cp>USD\u003c/p>"},{"_key":"7f751e628a5c","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Minimum purchase amount","field_content":"\u003cp>$10.00\u003c/p>"},{"_key":"fa0de87beb2e","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Seven day purchase limit","field_content":"\u003cp>$1,000 - $5,000\u003c/p>\n"}],"row_description":"Row ::  USD "}],"table_description":"Table: Legacy Migrated Placeholder","table_expanded_table":false,"table_mobile_style":"summary"}],"field_faq_answer":"\u003cp>Kraken fees for buying, selling, or converting assets using your card consist of a displayed fee and, where applicable, a spread which is included in the price. Spread fees may apply, depending on factors like transaction size, asset, payment method, and market conditions.\u003c/p>\u003cblockquote>\u003cstrong>Note: Transactions may not be cancelled once initiated. All purchases are final and non-refundable.\u003c/strong>\u003c/blockquote>\u003cp>\u003c/p>\u003cp>\u003cstrong>Card purchase fees:\u003c/strong>\u003c/p>\n\u003cul>\n\u003cli>\u003cp>The total transaction fee is displayed on the final confirmation page before completing the purchase. There are no hidden fees.\u003c/p>\u003c/li>\n\u003c/ul>\n\u003cp>\u003cstrong>Card and transaction limits:\u003c/strong>\u003c/p>\n\u003cul>\n\u003cli>\u003cp>Card limits are dynamic and may adjust over time with continued product usage. In most cases, this means that your limits will increase the more that you use Kraken, but in some cases your limits may also decrease. Limits are determined by a number of factors, including but not limited to: how long you&rsquo;ve had a Kraken account, your payment method, country of residence, and your transaction activity. Limits reset on a rolling weekly basis and cannot be increased by reaching out to client support. If you reach your limit for card payments, we recommend depositing funds with a different payment method until your weekly limit resets.&nbsp;\u003c/p>\n\u003c/li>\n\u003c/ul>\n\u003cp>\u003cstrong>Currency-specific limits:\u003c/strong>\u003c/p>\n\u003ctable>\n\u003ctr>\u003ctd>\u003cp>\u003cstrong>Currency\u003c/strong>\u003c/p>\u003c/td>\u003ctd>\u003cp>\u003cstrong>Minimum purchase amount\u003c/strong>\u003c/p>\u003c/td>\u003ctd>\u003cp>\u003cstrong>Seven day purchase limit\u003c/strong>\u003c/p>\u003c/td>\u003c/tr>\n\u003ctr>\u003ctd>\u003cp>AUD\u003c/p>\u003c/td>\u003ctd>\u003cp>A$14.00\u003c/p>\u003c/td>\u003ctd>\u003cp>A$1,500 - A$7,000\u003c/p>\n\u003c/td>\u003c/tr>\n\u003ctr>\u003ctd>\u003cp>CAD\u003c/p>\u003c/td>\u003ctd>\u003cp>C$12.50\u003c/p>\u003c/td>\u003ctd>\u003cp>C$1,500 - C$6,500\u003c/p>\n\u003c/td>\u003c/tr>\n\u003ctr>\u003ctd>\u003cp>CHF\u003c/p>\u003c/td>\u003ctd>\u003cp>CHF 10.00\u003c/p>\u003c/td>\u003ctd>\u003cp>CHF 1,000 - CHF 5,000\u003c/p>\n\u003c/td>\u003c/tr>\n\u003ctr>\u003ctd>\u003cp>EUR\u003c/p>\u003c/td>\u003ctd>\u003cp>€10.00\u003c/p>\u003c/td>\u003ctd>\u003cp>&euro;1,000 - &euro;5,000\u003c/p>\n\u003c/td>\u003c/tr>\n\u003ctr>\u003ctd>\u003cp>GBP\u003c/p>\u003c/td>\u003ctd>\u003cp>£8.00\u003c/p>\u003c/td>\u003ctd>\u003cp>&pound;800 - &pound;4,000\u003c/p>\n\u003c/td>\u003c/tr>\n\u003ctr>\u003ctd>\u003cp>USD\u003c/p>\u003c/td>\u003ctd>\u003cp>$10.00\u003c/p>\u003c/td>\u003ctd>\u003cp>$1,000 - $5,000\u003c/p>\n\u003c/td>\u003c/tr>\n\u003c/table>","field_id":"ijvcmGuoTvKjFziLsQG8U","field_title":"Fees and limits"},{"_key":"7c0c723275a1","_type":"paragraphAccordionItem","field_children":[{"_key":"d2640f78709e","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"233c6b10f6ea","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"ea4a88b3590d","_type":"paragraphArticleBodyLc","field_body":"\u003cp>The default payment currency is pre-determined by your verified \u003ca href=\"/articles/360001368823\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">country of residence.\u003c/a>\u003c/p>"}]},{"_key":"62d1dae254d1","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"f35c0db4a9d5","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Card issuers may impose additional fees (e.g., cash advance or international transaction fees) beyond Kraken’s fees.\u003c/p>"}]},{"_key":"ee053754ef02","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"7c47f5ab9130","_type":"paragraphArticleBodyLc","field_body":"\u003cp>The \u003ca target=\"blank\" rel=\"noopener\" href=\"/articles/360051144472\">Buy Crypto\u003c/a> widget and our Kraken app are specifically designed for easy buying and selling. Withdrawals to cards are not supported.\u003c/p>"}]}],"field_type":"ul"},{"_key":"9cf6e1d7bbdf","_type":"paragraphArticleBodyLc","field_body":"\u003cblockquote>As a security precaution we may limit the number of transactions allowed per day.\u003c/blockquote>"}],"field_id":"YxUCD22DtSe4FmHV2m4gi","field_title":"Important information"},{"_key":"e3b71f3c6d57","_type":"paragraphAccordionItem","field_children":[{"_key":"9364782ef497","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"2f25beb0ea75","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"83d571e18bef","_type":"paragraphArticleBodyLc","field_body":"\u003cp>If you are using the Buy Crypto widget on our website, you can view step-by-step instructions \u003ca href=\"/articles/360051144472-Buying-Crypto-on-Kraken#addcard\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">here\u003c/a>.\u003c/p>"}]},{"_key":"adb8b2bd6bbe","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"acb884869c19","_type":"paragraphArticleBodyLc","field_body":"\u003cp>For the Kraken App, please see the instructions provided \u003ca href=\"/articles/360046777031-The-Kraken-app#addcard\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">here\u003c/a>.\u003c/p>"}]}],"field_type":"ul"},{"_key":"15c94bc4c260","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_id":"OwfkpErcOIO0TGiZgyxl9","field_title":"How to add your payment card"},{"_key":"3ad530679d00","_type":"paragraphAccordionItem","field_children":[{"_key":"9aa5a8b4c005","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Storing your card details helps us to:\u003c/p>"},{"_key":"e1eac326034f","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"d17740e73364","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"94d736833da7","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Verify your account, comply with our legal and regulatory obligations, and prevent and detect fraud and crime.\u003c/p>"}]},{"_key":"e504954b224a","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"0c630398aa31","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Creates a smooth and fast payment journey. Stored card details can be removed anytime.\u003c/p>"}]},{"_key":"09eff0cafa52","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"9f26375e1edf","_type":"paragraphArticleBodyLc","field_body":"\u003cp>For legal and regulatory purposes, we will continue to store records of your transactions in accordance with our client \u003ca href=\"https://www.kraken.com/legal/privacy\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Privacy Policy\u003c/a>.\u003c/p>"}]}],"field_type":"ul"},{"_key":"c593c6c2a57b","_type":"paragraphArticleBodyLc","field_body":"\u003cp>If you would like to opt-out please \u003ca href=\"/articles/360051144472-Buying-Crypto-on-Kraken#How%20to%20edit%20or%20delete%20your%20saved%20payment%20card%20or%20online%20bank%20account\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">remove your payment card \u003c/a>and feel free to use an alternative payment method from this list:\u003c/p>"},{"_key":"55683b17c9ac","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"e35049d9b40b","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"44153a3efff1","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/4405883992724-Digital-wallet-purchases\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Apple Pay or Google Pay\u003c/a>\u003c/p>"}]},{"_key":"18b25c6d266b","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"937654dab385","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/how-do-i-use-plaid-ach-for-instant-buy-using-usd\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Buying instantly with Plaid ACH\u003c/a>\u003c/p>"}]},{"_key":"4ec3b1fc8483","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"ad54c04a5806","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360000381846-Cash-deposit-options-fees-minimums-and-processing-times-\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Supported currencies and payment methods.\u003c/a>\u003c/p>"}]},{"_key":"3b63f37e117b","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"19fede034fee","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/fund-your-kraken-account-with-paypal\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">PayPal\u003c/a>\u003c/p>"}]},{"_key":"51ce917b0fdb","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"5d39ecd96c45","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/4408701975444-How-do-I-fund-my-Kraken-account-with-EUR-and-GBP-via-Plaid-\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Plaid EUR/GBP\u003c/a>\u003c/p>"}]},{"_key":"7d257af166e8","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"7b84aec2c9b8","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/8795459449492-How-do-I-fund-my-account-with-USD-using-ACH-via-Plaid-\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Plaid via ACH\u003c/a>\u003c/p>"}]}],"field_type":"ul"}],"field_id":"cObSlo-EoS0VA6M69vuvZ","field_title":"Why does Kraken need my consent to store my card details?"},{"_key":"a4b63bc3f6e3","_type":"paragraphAccordionItem","field_children":[{"_key":"bc4231079cfa","_type":"paragraphArticleBodyLc","field_body":"\u003cp>There are a number of reasons why a transaction could fail:\u003c/p>"},{"_key":"126832086579","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"d8aa9cf21903","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"d00995bcd971","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Website or API connectivity issues.\u003c/p>"}]},{"_key":"b569ee626847","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"97e247694cf9","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Adverse market volatility, meaning we&#x27;re unable to lock down a price.\u003c/p>"}]}],"field_type":"ul"},{"_key":"06b5b799d7ab","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Transactions can also be declined by your card issuer at their discretion.\u003c/p>\u003cp>If your card was charged but you did not immediately receive your crypto assets, the transaction will automatically be voided by Kraken within two hours. Voided transactions will typically disappear from your card statement within 24 hours, but this depends on your bank&#x27;s policies. Please contact your card issuer (typically via a phone number provided on your card) if the transaction remains pending for longer than expected.\u003c/p>\u003cp>These lists are not exhaustive, so if your purchases continue to fail please contact our Support team.\u003c/p>"}],"field_id":"x6Y0a6YL4UeOP1mWYvuI0","field_title":"Failed or declined transactions"},{"_key":"128b968bfcaf","_type":"paragraphAccordionItem","field_children":[{"_key":"8d8c68a22c8c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>3DS, typically referred to as &quot;Verified by Visa&quot; or “Mastercard SecureCode&quot;, is an additional security layer used to authorize online purchases. Depending on your card issuer, they may require a password; one-time-PIN; or authorization within a banking app \u003c/p>\u003cp>If you are unsure if your card is 3DS, please contact your card issuer to enquire if they support this security feature. \u003c/p>"}],"field_id":"RSiDznXNth0MS08Rb0jub","field_title":"Explanation of 3D Secure (3DS)"},{"_key":"4b0432d9136d","_type":"paragraphAccordionItem","field_children":[{"_key":"e354408cbd3d","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Kraken offers Visa and Mastercard in many countries. Please see \u003ca href=\"/articles/where-is-kraken-licensed-or-regulated\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Where is Kraken licensed or regulated?\u003c/a>.\u003c/p>"}],"field_id":"GFm7AJKbbbNb1tukf1XQp","field_title":"Supported regions"}],"field_emit_faq_schema":true},{"_key":"54ec098f5192","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Troubleshooting\u003c/strong>\u003cem> \u003c/em>\u003c/p>"},{"_key":"a193960f6cef","_type":"paragraphAccordion","field_children":[{"_key":"fce792f218d6","_type":"paragraphAccordionItem","field_children":[{"_key":"fe50eebdabb4","_type":"paragraphArticleBodyLc","field_body":"\u003cp>There are a number of reasons why a transaction could fail:\u003c/p>"},{"_key":"90917d2c5742","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"93e8bd91f431","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"c00f642ba804","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Website or API connectivity issues.\u003c/p>"}]},{"_key":"c21e35f3baf7","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"7524f27afe38","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Adverse market volatility, meaning we&#x27;re unable to lock down a price.\u003c/p>"}]}],"field_type":"ul"},{"_key":"8b18775a0e82","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>\u003cp>If charged but no crypto assets are received, transactions are voided within two hours and typically removed from your statement within 24 hours. Contact your card issuer for delays.\u003c/p>\u003cp>Please contact your card issuer (typically via a phone number provided on your card) if the transaction remains pending for longer than expected.\u003c/p>\u003cp>\u003cbr/>\u003c/p>"}],"field_id":"x6Y0a6YL4UeOP1mWYvuI0","field_title":"Failed or declined transactions"},{"_key":"d880230d8632","_type":"paragraphAccordionItem","field_children":[{"_key":"79a8bbcae02b","_type":"paragraphArticleBodyLc","field_body":"\u003cp>3DS, typically referred to as &quot;Verified by Visa&quot; or “Mastercard SecureCode&quot;, adds an extra layer of security (e.g., password, one-time PIN, or banking app authorization). Contact your card issuer to confirm 3DS support. If you are unsure if your card is 3DS, please contact your card issuer.\u003c/p>"}],"field_id":"RSiDznXNth0MS08Rb0jub","field_title":"Explanation of 3D Secure (3DS)"},{"_key":"04da61471d8a","_type":"paragraphAccordionItem","field_children":[{"_key":"fe13a9c553ca","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Kraken offers Visa and Mastercard in many countries. View the list of \u003ca href=\"/articles/where-is-kraken-licensed-or-regulated\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">supported regions here\u003c/a>.\u003c/p>"}],"field_id":"GFm7AJKbbbNb1tukf1XQp","field_title":"Supported regions"}],"field_emit_faq_schema":true},{"_key":"2dcfda89fda7","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cem>\u003c/em>\u003c/p>\u003cp>\u003cem>The decimal and thousands separators shown in this article may differ from the formats displayed on our trading platforms. Review our article on \u003ca href=\"/articles/360001169543-Decimal-separators-points-vs-commas#88d86a6c0380\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">how we use points and commas\u003c/a> for more information.\u003c/em>\u003c/p>"}],"field_last_updated_label":"Last updated:","field_title":"Debit or credit card purchases with Visa and Mastercard","field_tldr_title":"Key takeaways"}],"field_page_meta":{"description":"Support Center for Kraken.com | Bitcoin & Cryptocurrency Exchange | Bitcoin Trading Platform","title":"Debit or credit card purchases with Visa and Mastercard | Kraken"},"field_tags":[{"_key":"3a15306e78ba","_ref":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","_type":"taxonomyTag","_id":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","firstPublishedAt":"2026-01-20T10:38:23.492Z","lastPublishedAt":"2026-01-20T10:38:23.492Z","name":"sc-tier-1"}],"field_target_languages":["de_de","es_es","fr_fr","it_it","nl_nl","pl_pl","pt_br","ru_ru","tr_tr","uk_ua","vi_vn","zh_cn"],"is_article":true,"lastPublishedAt":"2026-06-17T18:30:34.680Z","locale":{"_ref":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","_type":"taxonomyLocales","_id":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","code":"en-us","field_label":"English","name":"en-US"},"path":"/articles/360048212832-debit-or-credit-card-purchases-with-visa-and-mastercard-","status":true,"title":"Debit or credit card purchases with Visa and Mastercard"}},{"_key":"08d0f6372d54","reference":{"_ref":"article-360058699052","_type":"page","_id":"article-360058699052","_system":{"base":{"id":"article-360058699052","rev":"qgdcbURyIrnrYmhUU2Rlf4"}},"appId":"support","content_source_locale":"en_us","enabled_locales":[],"field_page_components":[{"_key":"33bf85e5d09e","_type":"paragraphArticleLayout","field_article_breadcrumb_label":"Support","field_article_breadcrumbs":true,"field_children":[{"_key":"565389466e2a","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Once your account has\u003ca href=\"/articles/360059110151\" > been verified\u003c/a>, you will be able to fund your account to buy and sell crypto. Follow the guides below to help you deposit and withdraw cash and crypto, using the Kraken app.\u003c/p>"},{"_key":"661ca2ca1b89","_type":"paragraphAccordion","field_children":[{"_key":"6c2495cb99bc","_type":"paragraphAccordionItem","field_children":[{"_key":"ddccfaf4063b","_type":"paragraphArticleBodyLc","field_body":"\u003cp>To deposit cash to your Kraken app:\u003c/p>"},{"_key":"5dd3e8486f7f","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"6b4ce71c3baf","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"0fb13425ab64","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Open the Kraken app and tap the \u003cstrong>Deposit button. \u003c/strong>This is located at the bottom of your app screen.\u003c/p>"},{"_key":"0dd92b4367d1","_type":"paragraphArticleImage","field_image":{"alt":"DepositGif","asset":{"_ref":"image-42883e2c48a6031a6f944cc1b31bdaeb04c2b16f-360x648-gif","_type":"sanity.imageAsset","mimeType":"image/gif","originalFilename":"App_Deposit_Cash.gif","size":926824,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.5555555555555556,"height":648,"width":360},"lqip":"data:image/jpeg;base64,"},"_id":"image-42883e2c48a6031a6f944cc1b31bdaeb04c2b16f-360x648-gif","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/42883e2c48a6031a6f944cc1b31bdaeb04c2b16f-360x648.gif"}},"field_width":"auto"}]},{"_key":"c4f8906e9da3","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"55e1eb946ba7","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Search for the currency under cash you&#x27;d like to deposit and tap on it.\u003c/p>"},{"_key":"e1d24fdf17d7","_type":"paragraphArticleImage","field_image":{"alt":"Cash","asset":{"_ref":"image-09b93536c2c93af9d7bfa4700b08d0f01778e15f-1179x2424-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"KrakenApp_Cash.jpg","size":169493,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.4863861386138614,"height":2424,"width":1179},"lqip":"data:image/jpeg;base64,"},"_id":"image-09b93536c2c93af9d7bfa4700b08d0f01778e15f-1179x2424-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/09b93536c2c93af9d7bfa4700b08d0f01778e15f-1179x2424.jpg"}},"field_width":"48"},{"_key":"38d19c2112e9","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"af5acf07bbeb","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"0ab37cc3e14b","_type":"paragraphArticleBodyLc","field_body":"\u003cp>If you are shown multiple options, tap on your preferred \u003ca href=\"/articles/360000423043-Cash-withdrawal-options-fees-minimums-and-processing-times-\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">payment network\u003c/a>.\u003c/p>"},{"_key":"60c092c3d661","_type":"paragraphArticleImage","field_image":{"alt":"USD example","asset":{"_ref":"image-6ffd15468f96e515769a0527b053cf3c1296778e-1206x2451-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"IMG_8203.jpg","size":58457,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.4920440636474908,"height":2451,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-6ffd15468f96e515769a0527b053cf3c1296778e-1206x2451-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/6ffd15468f96e515769a0527b053cf3c1296778e-1206x2451.jpg"}},"field_width":"48"},{"_key":"ce42aace4b25","_type":"paragraphArticleImage","field_image":{"alt":"GBP example","asset":{"_ref":"image-e8e3e1ab672db8c79757c8eec878985e82896fc8-798x1214-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Screenshot 2026-04-22 at 15.09.44.png","size":492461,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.657331136738056,"height":1214,"width":798},"lqip":"data:image/png;base64,"},"_id":"image-e8e3e1ab672db8c79757c8eec878985e82896fc8-798x1214-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/e8e3e1ab672db8c79757c8eec878985e82896fc8-798x1214.png"}},"field_width":"48"},{"_key":"f6b27362373a","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"b41970147592","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"be6c53c2f16b","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Review the important notes and instructions. For this example, we are using USD Swift Bank:\u003c/p>"},{"_key":"796ee369b610","_type":"paragraphArticleImage","field_image":{"alt":"USD example instructions ","asset":{"_ref":"image-a894fecbc6e047c2f2b25af5ee63f212bcae04cb-1206x2456-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"IMG_8204.jpg","size":101227,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.49104234527687296,"height":2456,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-a894fecbc6e047c2f2b25af5ee63f212bcae04cb-1206x2456-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/a894fecbc6e047c2f2b25af5ee63f212bcae04cb-1206x2456.jpg"}},"field_width":"48"},{"_key":"ca420d088843","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"b1527c48ef9e","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"989155280c30","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Copy the bank account details on the deposit instructions and provide it directly to your bank or financial institution to initiate the transfer.\u003c/p>\u003cblockquote> Various banks have different requirements, so please contact your bank directly for specific instructions on how to complete the deposit. \u003c/blockquote>"},{"_key":"38ca514f976d","_type":"paragraphArticleImage","field_image":{"alt":"Deposit bank ","asset":{"_ref":"image-8a10e23963a83b838ebd1064f42924f22b3648ab-826x1590-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"image.png","size":400848,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.519496855345912,"height":1590,"width":826},"lqip":"data:image/png;base64,"},"_id":"image-8a10e23963a83b838ebd1064f42924f22b3648ab-826x1590-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/8a10e23963a83b838ebd1064f42924f22b3648ab-826x1590.png"}},"field_width":"auto"},{"_key":"21c05775359e","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"bf7ab3d3aff4","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"a75aec98c437","_type":"paragraphArticleBodyLc","field_body":"\u003cp>To help your deposit go smoothly, use our \u003ca href=\"/articles/deposit-requirements-and-checklist-dlt\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">deposit checklist\u003c/a> before sending any funds.\u003c/p>"}]},{"_key":"69e768172755","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"095d792c1e54","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Once your deposit arrives, you will receive an email confirming the funds have been credited to your Kraken account balance.\u003c/p>"}]}],"field_type":"ol"},{"_key":"5346742a7fa7","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_id":"P6Rp5ZczbPW3KakWhy6zQ","field_title":" Deposit cash "},{"_key":"880e741925eb","_type":"paragraphAccordionItem","field_children":[{"_key":"55150604fe93","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"9980f4634494","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"ce540d788626","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Go to your \u003cstrong>Portfolio\u003c/strong> and select the currency you would like to withdraw from your available balances. \u003c/p>"}]},{"_key":"ddc5b6bac84c","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"afca05deb040","_type":"paragraphArticleBodyLc","field_body":"\u003cp>On the next screen, tap the \u003cstrong>Withdraw\u003c/strong> button.\u003c/p>"},{"_key":"cddcc5100084","_type":"paragraphArticleImage","field_image":{"alt":"Withdraw","asset":{"_ref":"image-7e0785710e7bc923d04faeefefabcc9ed47fdb8e-1179x1332-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Withdraw.jpeg","size":79549,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.8851351351351351,"height":1332,"width":1179},"lqip":"data:image/jpeg;base64,"},"_id":"image-7e0785710e7bc923d04faeefefabcc9ed47fdb8e-1179x1332-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/7e0785710e7bc923d04faeefefabcc9ed47fdb8e-1179x1332.jpg"}},"field_width":"auto"}]},{"_key":"307a6bc9e2d7","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"bc730d177011","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Choose the network you&#x27;d like to withdraw. If you are shown multiple options, select your \u003ca href=\"/articles/360000423043-Cash-withdrawal-options-fees-minimums-and-processing-times-\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">preferred payment network.\u003c/a>\u003c/p>"}]},{"_key":"01fc0da89639","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"4d1554893374","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Then input the amount you would like to withdraw.\u003c/p>\u003cp>\u003c/p>"}]},{"_key":"080c4fa7cab2","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"ab3dfc78e3bf","_type":"paragraphArticleBodyLc","field_body":"\u003cp>In the\u003cstrong> Withdraw To\u003c/strong> section, select an existing withdrawal address or tap Enter a new bank account.\u003c/p>\u003cul>\u003cli>To add a new bank account, select your preferred funding method.\u003c/li>\u003cli>Input a unique description to name the account. Follow the instructions and provide the required details.\u003c/li>\u003c/ul>\u003cp>You can refer to our \u003ca href=\"/articles/360049193731-What-information-is-required-when-adding-a-new-bank-account-\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">frequently asked questions\u003c/a> for more information about the different requirements.\u003c/p>"}]},{"_key":"101b93019e2d","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"1d8ad47d3b98","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Tap \u003cstrong>Review\u003c/strong> and confirm once you’re ready to withdraw.\u003c/p>"}]}],"field_type":"ol"},{"_key":"979ba6564838","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_id":"u2AAuLvHHuSyHEFDPbeMG","field_title":" Withdraw cash"},{"_key":"4ae09aeaef3a","_type":"paragraphAccordionItem","field_children":[{"_key":"d0fac6503396","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"ffbd87d567b7","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"aa1712d5da4e","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Tap the \u003cstrong>deposit\u003c/strong> icon located on the bottom of the screen.\u003c/p>\u003cp>\u003c/p>"},{"_key":"3adfa23c6877","_type":"paragraphArticleImage","field_image":{"alt":"Home","asset":{"_ref":"image-d464d9381258e9e812a7f2dea11ac4a0cb41a54f-896x1366-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"image.png","size":622985,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.6559297218155198,"height":1366,"width":896},"lqip":"data:image/png;base64,"},"_id":"image-d464d9381258e9e812a7f2dea11ac4a0cb41a54f-896x1366-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/d464d9381258e9e812a7f2dea11ac4a0cb41a54f-896x1366.png"}},"field_width":"48"}]},{"_key":"47ad6e67f9de","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"04d21553b8d2","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Search for the currency you&#x27;d like to deposit.\u003c/p>"},{"_key":"b6fe6bed1f70","_type":"paragraphArticleImage","field_image":{"alt":"Deposit crypto ","asset":{"_ref":"image-4ebbbcbf081a6d5b16e22dcf7c848c37925dbb89-776x1588-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"image.png","size":405956,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.48866498740554154,"height":1588,"width":776},"lqip":"data:image/png;base64,"},"_id":"image-4ebbbcbf081a6d5b16e22dcf7c848c37925dbb89-776x1588-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/4ebbbcbf081a6d5b16e22dcf7c848c37925dbb89-776x1588.png"}},"field_width":"auto"}]},{"_key":"f742560e7678","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"d454f1952f9d","_type":"paragraphArticleBodyLc","field_body":"\u003cp>If you are shown multiple options, select your \u003ca href=\"/articles/360000423043-Cash-withdrawal-options-fees-minimums-and-processing-times-\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">preferred funding method\u003c/a>.\u003c/p>"},{"_key":"8359866e89ed","_type":"paragraphArticleImage","field_image":{"alt":"Funding method","asset":{"_ref":"image-1093c98e8d9d9d1eb7c2346def4a11ba741bed1e-1206x2415-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"IMG_8207.jpg","size":104191,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.4993788819875776,"height":2415,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-1093c98e8d9d9d1eb7c2346def4a11ba741bed1e-1206x2415-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/1093c98e8d9d9d1eb7c2346def4a11ba741bed1e-1206x2415.jpg"}},"field_width":"auto"},{"_key":"0002bbba5888","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"21e6811a65e0","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"98c825a1f8a0","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Review the important notes and instructions. Once ready, tap \u003cstrong>I understand\u003c/strong>.\u003c/p>"},{"_key":"6cbad0a0057c","_type":"paragraphArticleImage","field_image":{"alt":"Instructions","asset":{"_ref":"image-c383e68b271a7da637201bc887da27d506b6bba9-1206x2464-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"IMG_8208.jpg","size":112712,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.48944805194805197,"height":2464,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-c383e68b271a7da637201bc887da27d506b6bba9-1206x2464-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/c383e68b271a7da637201bc887da27d506b6bba9-1206x2464.jpg"}},"field_width":"auto"}]},{"_key":"c597a835c405","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"61489a210d45","_type":"paragraphArticleBodyLc","field_body":"\u003cp>If you have Funding 2FA enabled, you will need to complete this before proceeding.\u003c/p>"}]},{"_key":"c50c97e57f37","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"6bab619b45ac","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Copy the wallet address into the wallet from which the funds will be sent. Do not type the address by hand.\u003c/p>"}]},{"_key":"f83abf7cd4fb","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"447a54740ce1","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Alternatively, you can also use the provided ‘QR code’. IMPORTANT: If you use the QR code for XRP and XLM ensure the tag/memo is included. For EOS, the memo will need to be manually typed in.\u003c/p>\u003cp>\u003cem>*For certain cryptocurrencies, you will need to include more details than just the address: \u003c/em>\u003c/p>\u003cul>\u003cli>Ripple (XRP) deposits need a ‘destination tag’.\u003c/li>\u003cli>Lumens (XLM) deposits need a &#x27;memo&#x27;.\u003c/li>\u003cli>EOS deposits need a &#x27;memo&#x27;.\u003c/li>\u003c/ul>"}]},{"_key":"0d8b34b0da28","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"654b753e3cb5","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Once you have initiated a valid transaction from your wallet, the deposit will be credited to your account when the minimum number of required confirmations has been reached.\u003c/p>"}]}],"field_type":"ol"},{"_key":"15873dc80e84","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_id":"bvUdjc7nZ55-epXyILur2","field_title":" Deposit cryptocurrencies (single network) "},{"_key":"2944efaa49d0","_type":"paragraphAccordionItem","field_children":[{"_key":"5c26c1b4bef6","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Some cryptocurrencies supported on Kraken have multiple networks to choose from, such as the stablecoins DAI, USDT and USDC.\u003c/p>"},{"_key":"28b0b952edee","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"2ec4ed2850c3","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"1e87b8371e44","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Tap the \u003cstrong>deposit\u003c/strong> icon located on the bottom of the screen.\u003c/p>"},{"_key":"bc8142759cfe","_type":"paragraphArticleImage","field_image":{"alt":"Home","asset":{"_ref":"image-d464d9381258e9e812a7f2dea11ac4a0cb41a54f-896x1366-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"image.png","size":622985,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.6559297218155198,"height":1366,"width":896},"lqip":"data:image/png;base64,"},"_id":"image-d464d9381258e9e812a7f2dea11ac4a0cb41a54f-896x1366-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/d464d9381258e9e812a7f2dea11ac4a0cb41a54f-896x1366.png"}},"field_width":"48"},{"_key":"334e4420052d","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"4ee6089e7154","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"b1625da14fbf","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Select \u003cstrong>Deposit\u003c/strong> and search for the currency you would like to deposit, e.g. DAI, USDT or USDC. \u003c/p>\u003cp>\u003c/p>"},{"_key":"ceb0d7ad489b","_type":"paragraphArticleImage","field_image":{"alt":"Deposit","asset":{"_ref":"image-4ebbbcbf081a6d5b16e22dcf7c848c37925dbb89-776x1588-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"image.png","size":405956,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.48866498740554154,"height":1588,"width":776},"lqip":"data:image/png;base64,"},"_id":"image-4ebbbcbf081a6d5b16e22dcf7c848c37925dbb89-776x1588-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/4ebbbcbf081a6d5b16e22dcf7c848c37925dbb89-776x1588.png"}},"field_width":"auto"},{"_key":"b813c562e237","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"7ecb25201065","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"ecb5646c5173","_type":"paragraphArticleBodyLc","field_body":"\u003cp> Select the network you wish to deposit on. Each network has different \u003ca href=\"/articles/360000292886-Cryptocurrency-deposit-fees-and-minimums\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">fees\u003c/a>, \u003ca href=\"/articles/360001389303-Overview-of-cryptocurrency-minimums\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">minimums\u003c/a> and \u003ca href=\"/articles/203325283-Cryptocurrency-deposit-processing-times\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">processing times\u003c/a>.\u003c/p>\u003cp>You will then need to choose between multiple networks depending on the currency you choose.\u003c/p>\u003cp>To see all supported networks for each cryptocurrency listed on Kraken visit \u003ca href=\"/articles/360000678446-Cryptocurrencies-available-on-Kraken\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">this article\u003c/a>.\u003c/p>"},{"_key":"7376277c9732","_type":"paragraphArticleImage","field_image":{"alt":"Network","asset":{"_ref":"image-1269808eb4fb6eae7fef55d7e39ae7ec1a0e3e5e-1206x2472-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"IMG_8210.jpg","size":121107,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.4878640776699029,"height":2472,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-1269808eb4fb6eae7fef55d7e39ae7ec1a0e3e5e-1206x2472-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/1269808eb4fb6eae7fef55d7e39ae7ec1a0e3e5e-1206x2472.jpg"}},"field_width":"48"},{"_key":"a7f5430a7929","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"bbca9bd57bb0","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"8c16d4eb4d0e","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Review the important notes and instructions. Once ready, tap \u003cstrong>I understand\u003c/strong>.\u003c/p>"},{"_key":"4ef293f75bbd","_type":"paragraphArticleImage","field_image":{"alt":"Instructions","asset":{"_ref":"image-f837060ece17078e0f24139c9929449e312a9c6d-1206x2473-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"IMG_8211.jpg","size":115609,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.4876668014557218,"height":2473,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-f837060ece17078e0f24139c9929449e312a9c6d-1206x2473-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/f837060ece17078e0f24139c9929449e312a9c6d-1206x2473.jpg"}},"field_width":"48"},{"_key":"f467df824878","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"bf50311f05e7","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"51e8c3eda7c8","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Copy the wallet address into the wallet from which the funds will be sent. Do not type the address by hand. \u003c/p>"}]},{"_key":"a66286b5b80b","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"5825997080e6","_type":"paragraphArticleBodyLc","field_body":"\u003cp>You can also use the ‘QR code’ provided.\u003c/p>"}]},{"_key":"f574dbe83b04","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"f98c014773f8","_type":"paragraphArticleBodyLc","field_body":"\u003cp> Once you have initiated a valid transaction from your wallet, deposit will be credited to your account when the \u003ca href=\"/articles/203325283-Cryptocurrency-deposit-processing-times\" >minimum number of required confirmations\u003c/a> has been reached. \u003c/p>"}]}],"field_type":"ol"},{"_key":"ac0461674f7a","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_id":"Es1zbCv9jsburhOKls0UO","field_title":" Deposit cryptocurrencies (multiple networks) "},{"_key":"bd9437a5f977","_type":"paragraphAccordionItem","field_children":[{"_key":"d1b169bf978c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>When depositing Ethereum (ETH) you can choose between multiple networks and two deposit methods.\u003c/p>"},{"_key":"bc9e5452271b","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"8b8bd7603bc5","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"23a2c79608b8","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Tap the \u003cstrong>Deposit\u003c/strong> icon located on the bottom of the screen.\u003c/p>"},{"_key":"32c3d374d204","_type":"paragraphArticleImage","field_image":{"alt":"Deposit","asset":{"_ref":"image-ffdf1ad888910afc899f22d414bd60fed30b5af7-896x1366-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"deposit.webp","size":70030,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.6559297218155198,"height":1366,"width":896},"lqip":"data:image/jpeg;base64,"},"_id":"image-ffdf1ad888910afc899f22d414bd60fed30b5af7-896x1366-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/ffdf1ad888910afc899f22d414bd60fed30b5af7-896x1366.jpg"}},"field_width":"auto"},{"_key":"2b99b836b7be","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"db7e9718d712","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"128626c22524","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Search for ETH. There are multiple networks available to deposit ETH. \u003c/p>"},{"_key":"708fef539403","_type":"paragraphArticleImage","field_image":{"alt":"ETH","asset":{"_ref":"image-a7a386e6805857d2c016d710eedd8eb68e10fd16-1206x2473-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"IMG_8212.jpg","size":121732,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.4876668014557218,"height":2473,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-a7a386e6805857d2c016d710eedd8eb68e10fd16-1206x2473-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/a7a386e6805857d2c016d710eedd8eb68e10fd16-1206x2473.jpg"}},"field_width":"auto"}]},{"_key":"54c6a8b674bf","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"976f131307b4","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Review the important notes and instructions. Once ready, tap \u003cstrong>I understand\u003c/strong>.\u003c/p>"},{"_key":"77aa521c1c48","_type":"paragraphArticleImage","field_image":{"alt":"Instructions","asset":{"_ref":"image-482cfe9cba505a3ab4284c2d8bfdbb58ea5b94ae-1206x2452-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"IMG_8213.jpg","size":109834,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.49184339314845027,"height":2452,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-482cfe9cba505a3ab4284c2d8bfdbb58ea5b94ae-1206x2452-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/482cfe9cba505a3ab4284c2d8bfdbb58ea5b94ae-1206x2452.jpg"}},"field_width":"auto"},{"_key":"ee191ddf09f6","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"a0248c8bd116","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"8004d555a82c","_type":"paragraphArticleBodyLc","field_body":"\u003cp> After selecting the network, you will be presented with your deposit address. \u003c/p>"}]},{"_key":"5461df8dd3ff","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"df0b3712fe61","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Copy the wallet address and paste into the wallet from which the funds will be sent. Do not type the address by hand.\u003c/p>"}]},{"_key":"0118dc9ab251","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"f308e6e3e712","_type":"paragraphArticleBodyLc","field_body":"\u003cp> You can also use the ‘QR code’ provided. \u003c/p>"}]},{"_key":"cafc46d176f8","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"16c9fa08c18a","_type":"paragraphArticleBodyLc","field_body":"\u003cp> Once you have initiated a valid transaction from your wallet, the ETH deposit will be credited to your account when the minimum number of required confirmations has been reached. This will vary depending on the network you choose above. \u003c/p>"}]}],"field_type":"ol"},{"_key":"d6f9fca26f2c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_id":"OFi3pcu_rs33X6IJGqQ2d","field_title":" Deposit ETH (multiple networks and methods) "},{"_key":"b92abab8b69b","_type":"paragraphAccordionItem","field_children":[{"_key":"60759bdf07d1","_type":"paragraphArticleBodyLc","field_body":"\u003cp>To exchange BTC for kBTC a Kraken user initiates a withdrawal of BTC from their Kraken account and an equivalent amount of kBTC is sent to the user&#x27;s external withdrawal address.\u003c/p>"},{"_key":"8bd3f571205e","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"8132b08d5e67","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"469e342a7efc","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Hold some BTC in your Kraken account.\u003c/p>"}]},{"_key":"33833be3e9e2","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"3915f59132c4","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Go to the Portfolio page on Kraken. (web or mobile)\u003c/p>"}]},{"_key":"f82547e7b19c","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"76561a868c6d","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Select \u003cstrong>Withdraw\u003c/strong>, and choose \u003cstrong>Bitcoin\u003c/strong> from the asset dropdown.\u003c/p>"}]},{"_key":"71b5464499e6","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"e76de507f40a","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Select \u003cstrong>Ethereum (kBTC)\u003c/strong> or \u003cstrong>OP Mainnet (kBTC)\u003c/strong> from the network dropdown.\u003c/p>"}]},{"_key":"251c63359094","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"c4e404126f33","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Complete the withdrawal process, and your BTC will be exchanged to kBTC on the selected network.\u003c/p>"}]}],"field_type":"ol"},{"_key":"d080cb653563","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_id":"643137008d65305402c4f31d3c19f097","field_title":"Withdrawing kBTC"},{"_key":"2c39764c9b9e","_type":"paragraphAccordionItem","field_children":[{"_key":"b1a0a9045bf6","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"ab3bef056e81","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"1cd0de32432f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Select the currency from your available balances. Tap \u003cstrong>withdraw\u003c/strong>. \u003c/p>"},{"_key":"79180f5f894e","_type":"paragraphArticleImage","field_image":{"alt":"Withdraw","asset":{"_ref":"image-5011d3d5c4bf00f563be72ddb543ff535961f116-732x1430-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"image.png","size":237043,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.5118881118881119,"height":1430,"width":732},"lqip":"data:image/png;base64,"},"_id":"image-5011d3d5c4bf00f563be72ddb543ff535961f116-732x1430-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/5011d3d5c4bf00f563be72ddb543ff535961f116-732x1430.png"}},"field_width":"auto"}]},{"_key":"f2186c0771c5","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"eda4ebf60e0c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Input the amount. \u003c/p>"},{"_key":"3713426de837","_type":"paragraphArticleImage","field_image":{"alt":"Withdraw amount ","asset":{"_ref":"image-0b49511081df6528debe87938478801a1dd349d4-496x944-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"image.png","size":100280,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.5254237288135594,"height":944,"width":496},"lqip":"data:image/png;base64,"},"_id":"image-0b49511081df6528debe87938478801a1dd349d4-496x944-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/0b49511081df6528debe87938478801a1dd349d4-496x944.png"}},"field_width":"auto"},{"_key":"2aba8baa7626","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"60531a10fe1c","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"69f0177c58fb","_type":"paragraphArticleBodyLc","field_body":"\u003cp>In the \u003cstrong>Withdraw To\u003c/strong> section, select an existing withdrawal address \u003cem>or\u003c/em> click \u003cem>Enter a new address.\u003c/em>\u003c/p>\n\n\u003cp>If entering a new address:\u003c/p>\n\n\u003cul>\n\t\u003cli>\u003cstrong>Select the network.\u003c/strong> Some cryptocurrencies can be withdrawn on multiple networks. Make sure the network you select matches the wallet you are sending to,&nbsp;for example, if your wallet is an Ethereum wallet, select the Ethereum Network. Review&nbsp;\u003ca data-testid=\"external-link\" href=\"/articles/360000678446-Cryptocurrencies-available-on-Kraken\" rel=\"noopener\" target=\"blank\">this article\u003c/a> to check the supported networks for each currency.\u003c/li>\n\t\u003cli>\u003cstrong>Enter a unique description.\u003c/strong> This is a description to help you identify the address later (ex. &quot;My BTC wallet&quot;). Each withdrawal address must have a unique label.\u003c/li>\n\t\u003cli>\u003cstrong>Paste the withdrawal address.\u003c/strong> Copy the exact address from the receiving wallet and paste it directly,&nbsp;never type an address by hand.\u003c/li>\n\u003c/ul>\n\n\u003cp>\u003cstrong>Note\u003c/strong>: Different cryptocurrencies may share the \u003ca data-testid=\"external-link\" href=\"/articles/360001474826-Supported-address-formats-for-cryptocurrency-withdrawal\" rel=\"noopener\" target=\"blank\">same address format\u003c/a>.&nbsp;Always confirm you have selected the correct asset and network before proceeding.\u003c/p>\n"}]},{"_key":"d56a4f5c83e5","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"08056d87cfeb","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Click \u003cstrong>Add withdrawal address\u003c/strong>. Depending on your device, your new address may be approved automatically or you may need to confirm it via a link sent to your registered email address within one hour.\u003c/p>\n"}]},{"_key":"39db8e4b683a","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"5e42bc3f16c3","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Click confirm.\u003c/p>"}]}],"field_type":"ol"},{"_key":"68758822ea85","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_id":"CD8jeGPXMjQel5XiloLh9","field_title":" Withdraw cryptocurrencies "},{"_key":"3e791ae49d55","_type":"paragraphAccordionItem","field_children":[{"_key":"b12da3559f74","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"37ad615b6a96","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"e870c07ebcd1","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Tap your profile icon on the top left, and select withdraw.\u003c/p>"}]},{"_key":"3ade2d433887","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"68793531912c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Choose the currency where your withdrawal address is saved.\u003c/p>"}]},{"_key":"3e865e93207d","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"7e1b40bee775","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Click on the \u003cstrong>Withdraw To\u003c/strong> section.\u003c/p>"}]},{"_key":"4b665b130fee","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"7a775a7bc375","_type":"paragraphArticleBodyLc","field_body":"\u003cp> Locate the address you wish to delete and swipe from right to left. \u003c/p>"}]},{"_key":"c1346260cff3","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"209621aee571","_type":"paragraphArticleBodyLc","field_body":"\u003cp> Select \u003cstrong>Yes\u003c/strong> to the question “Are you sure you wish to remove this address?&quot;\u003c/p>"}]},{"_key":"3508922a76bd","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"65f74cfd340c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>You will receive an email notification to confirm the address has been removed.\u003c/p>"}]}],"field_type":"ol"},{"_key":"e7b153fb5ebd","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_id":"TDC9l4NPWunNkZTFCGIpm","field_title":" Delete a withdrawal address "},{"_key":"7683391bba93","_type":"paragraphAccordionItem","field_children":[{"_key":"80b22f7ef138","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Kraken Pay offer a quick, cost-free way to move funds directly between Kraken accounts. \u003ca href=\"/articles/kraken-transfers\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Click here to learn more.\u003c/a>\u003c/p>"}],"field_id":"52d5a5f77f35","field_title":"Kraken Pay"}]},{"_key":"1a021da80d9c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>If you have any issues funding your account, please \u003ca href=\"/forms\" >contact our support team\u003c/a>.\u003cbr/>\u003c/p>"}],"field_last_updated_label":"Last updated:","field_title":"Depositing and withdrawing funds from the Kraken app","field_tldr_title":"Key takeaways"}],"field_page_meta":{"description":"Support Center for Kraken.com | Bitcoin & Cryptocurrency Exchange | Bitcoin Trading Platform","title":"Depositing and withdrawing funds from the Kraken app | Kraken"},"field_tags":[{"_key":"92798881ff79","_ref":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","_type":"taxonomyTag","_id":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","firstPublishedAt":"2026-01-20T10:38:23.492Z","lastPublishedAt":"2026-01-20T10:38:23.492Z","name":"sc-tier-1"}],"field_target_languages":["de_de","es_es","fr_fr","it_it","nl_nl","pl_pl","pt_br","ru_ru","tr_tr","uk_ua","vi_vn","zh_cn"],"is_article":true,"lastPublishedAt":"2026-04-22T22:16:30.448Z","locale":{"_ref":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","_type":"taxonomyLocales","_id":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","code":"en-us","field_label":"English","name":"en-US"},"path":"/articles/360058699052-depositing-and-withdrawing-funds-from-the-kraken-app","status":true,"title":"Depositing and withdrawing funds from the Kraken app"}},{"_key":"6d575f397487","reference":{"_ref":"article-360058727972","_type":"page","_id":"article-360058727972","_system":{"base":{"id":"article-360058727972","rev":"Q2ExDXRtKhetVltnLwLEBh"}},"appId":"support","content_source_locale":"en_us","enabled_locales":[],"field_page_components":[{"_key":"d08d50b6244f","_type":"paragraphArticleLayout","field_article_breadcrumb_label":"Support","field_article_breadcrumbs":true,"field_children":[{"_key":"1e8e680fc736","_type":"paragraphAccordion","field_children":[{"_key":"36dd2cf50a4b","_type":"paragraphAccordionItem","field_children":[{"_key":"862ed0cb65a0","_type":"paragraphArticleBodyLc","field_body":"\u003cp>To buy crypto using your cash balance, payment card, Plaid ACH or digital wallet:\u003c/p>"},{"_key":"a10f9e259dac","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"ca16efbbd138","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"af6d4d3deaeb","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Tap on the \u003cstrong>Trade\u003c/strong> button and then tap \u003cstrong>Buy\u003c/strong>.\u003c/p>"},{"_key":"ef53d1aa4d8d","_type":"paragraphArticleImage","field_image":{"alt":"home","asset":{"_ref":"image-1416fcc5f62b2d538b130a4b670618f7e3553683-1179x1733-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Home_Trade.jpg","size":120254,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.6803231390652048,"height":1733,"width":1179},"lqip":"data:image/jpeg;base64,"},"_id":"image-1416fcc5f62b2d538b130a4b670618f7e3553683-1179x1733-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/1416fcc5f62b2d538b130a4b670618f7e3553683-1179x1733.jpg"}},"field_width":"auto"},{"_key":"67a97cc1930c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"12de8932e439","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"458885b2f104","_type":"paragraphArticleBodyLc","field_body":"\u003cp>From the list of assets tap on the crypto you would like to buy, or use the search function to find a specific \u003ca href=\"/articles/360000678446-Cryptocurrencies-available-on-Kraken\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">asset. \u003c/a>\u003c/p>"},{"_key":"94183d4bf66c","_type":"paragraphArticleImage","field_image":{"alt":"Search for an asset","asset":{"_ref":"image-7a0af85dbae2b85120a5680fcd41ce6f29fbc1ef-786x1704-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Buy Asset Selector.png","size":93911,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.4612676056338028,"height":1704,"width":786},"lqip":"data:image/png;base64,"},"_id":"image-7a0af85dbae2b85120a5680fcd41ce6f29fbc1ef-786x1704-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/7a0af85dbae2b85120a5680fcd41ce6f29fbc1ef-786x1704.png"}},"field_width":"auto"},{"_key":"37cd4a28bb53","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"655a66fd0c3f","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"4c67bab88b73","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Enter the amount you would like to buy and select one of your available payment methods.  \u003c/p>"},{"_key":"82874733eafa","_type":"paragraphArticleImage","field_image":{"alt":"Enter amount 2","asset":{"_ref":"image-b729c0fdffd866ba965029a2f310460dd9de94a4-393x852-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"buy.png","size":28864,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.4612676056338028,"height":852,"width":393},"lqip":"data:image/png;base64,"},"_id":"image-b729c0fdffd866ba965029a2f310460dd9de94a4-393x852-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/b729c0fdffd866ba965029a2f310460dd9de94a4-393x852.png"}},"field_width":"auto"}]},{"_key":"68ad3a218d7f","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"8c3a7ceb0ac9","_type":"paragraphArticleBodyLc","field_body":"\u003cp>On the next screen you can review your purchase. If everything looks right, tap \u003cstrong>Confirm\u003c/strong>.\u003c/p>"},{"_key":"ac59178059e3","_type":"paragraphArticleImage","field_image":{"alt":"Confirm your purchase","asset":{"_ref":"image-3677067ab906f947e20c28bbf923a38c7c3db63f-390x844-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Instant buy.png","size":30142,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.46208530805687204,"height":844,"width":390},"lqip":"data:image/png;base64,"},"_id":"image-3677067ab906f947e20c28bbf923a38c7c3db63f-390x844-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/3677067ab906f947e20c28bbf923a38c7c3db63f-390x844.png"}},"field_width":"auto"}]},{"_key":"d1a3a5ddf1dd","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"97b07ebcff34","_type":"paragraphArticleBodyLc","field_body":"\u003cp>That&#x27;s it! You have successfully bought crypto.\u003c/p>"},{"_key":"de71259f00fd","_type":"paragraphArticleImage","field_image":{"alt":"Success ","asset":{"_ref":"image-e90fa1981d3818250f83f05ac6472686823b4899-390x844-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Instant buy.png","size":172702,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.46208530805687204,"height":844,"width":390},"lqip":"data:image/png;base64,"},"_id":"image-e90fa1981d3818250f83f05ac6472686823b4899-390x844-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/e90fa1981d3818250f83f05ac6472686823b4899-390x844.png"}},"field_width":"auto"}]}],"field_type":"ol"}],"field_id":"9370477ad38a","field_title":"How to buy"},{"_key":"43da13b74223","_type":"paragraphAccordionItem","field_children":[{"_key":"0c1a0e3cc13f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>To sell crypto and credit the cash into your account balance, you will need to locate the asset from your account balance:\u003c/p>"},{"_key":"934615e17ff7","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"126f636a732c","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"128336009be4","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Tap the \u003cstrong>Trade \u003c/strong>button and then \u003cstrong>Sell\u003c/strong>.\u003c/p>"},{"_key":"69606d5d6058","_type":"paragraphArticleImage","field_image":{"alt":"Trade","asset":{"_ref":"image-1416fcc5f62b2d538b130a4b670618f7e3553683-1179x1733-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Home_Trade.jpg","size":120254,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.6803231390652048,"height":1733,"width":1179},"lqip":"data:image/jpeg;base64,"},"_id":"image-1416fcc5f62b2d538b130a4b670618f7e3553683-1179x1733-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/1416fcc5f62b2d538b130a4b670618f7e3553683-1179x1733.jpg"}},"field_width":"auto"},{"_key":"5881e79a84a8","_type":"paragraphArticleBodyLc","field_body":"\u003cp> \u003c/p>"},{"_key":"d29f368a2da0","_type":"paragraphArticleImage","field_image":{"alt":"Sell","asset":{"_ref":"image-1721260e227ba698ff8be8d4c94e48fafeb7110d-1102x740-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"image.png","size":169638,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.4891891891891893,"height":740,"width":1102},"lqip":"data:image/png;base64,"},"_id":"image-1721260e227ba698ff8be8d4c94e48fafeb7110d-1102x740-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/1721260e227ba698ff8be8d4c94e48fafeb7110d-1102x740.png"}},"field_width":"auto"}]},{"_key":"2b9026e3063c","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"5571658e64c8","_type":"paragraphArticleBodyLc","field_body":"\u003cp>From your assets list tap on the crypto you would like to sell.\u003c/p>"},{"_key":"56fbc2f39950","_type":"paragraphArticleImage","field_image":{"alt":"Sell assets","asset":{"_ref":"image-840a25eb83ea3cbddd08e1e4c04f4af74b6aa1fd-786x1688-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Sell Asset Selector.png","size":67313,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.4656398104265403,"height":1688,"width":786},"lqip":"data:image/png;base64,"},"_id":"image-840a25eb83ea3cbddd08e1e4c04f4af74b6aa1fd-786x1688-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/840a25eb83ea3cbddd08e1e4c04f4af74b6aa1fd-786x1688.png"}},"field_width":"auto"}]},{"_key":"3c314ab195b1","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"d162a26c55f7","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Input the amount you would like to sell (you can toggle between cash value and crypto volume). The cash will be added to your balance in the default currency you have saved on the Kraken app. If you want to receive the cash in a different currency, you will need to change this on your \u003cstrong>Account\u003c/strong> settings before completing the transaction.\u003c/p>"},{"_key":"688f50878bee","_type":"paragraphArticleImage","field_image":{"alt":"Sell input","asset":{"_ref":"image-a9b1af8fcce8effb9a3cc34132dde5f3368f2af2-786x1688-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Sell Input.png","size":98861,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.4656398104265403,"height":1688,"width":786},"lqip":"data:image/png;base64,"},"_id":"image-a9b1af8fcce8effb9a3cc34132dde5f3368f2af2-786x1688-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/a9b1af8fcce8effb9a3cc34132dde5f3368f2af2-786x1688.png"}},"field_width":"auto"}]},{"_key":"938df7ad72ea","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"a92d2deff927","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Tap \u003cstrong>Continue\u003c/strong> to review your sale. If everything looks right, tap \u003cstrong>Confirm\u003c/strong> to complete your sale.\u003c/p>"},{"_key":"15a93b0b402c","_type":"paragraphArticleImage","field_image":{"alt":"Confirm send","asset":{"_ref":"image-3150a3bdd74261690a9449cbdd40fd5b025313d8-786x1688-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Confirm - Instant sell.png","size":75712,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.4656398104265403,"height":1688,"width":786},"lqip":"data:image/png;base64,"},"_id":"image-3150a3bdd74261690a9449cbdd40fd5b025313d8-786x1688-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/3150a3bdd74261690a9449cbdd40fd5b025313d8-786x1688.png"}},"field_width":"auto"},{"_key":"23594501ec3d","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}]},{"_key":"75d110df8638","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"23d483be3782","_type":"paragraphArticleBodyLc","field_body":"\u003cp>That&#x27;s it! You can check your \u003cstrong>Portfolio\u003c/strong> to see your new account balance.\u003c/p>"},{"_key":"a065ca72e20f","_type":"paragraphArticleImage","field_image":{"alt":"Sell confirmation","asset":{"_ref":"image-7518ef0c14e23597d63ec0c8a5729712d4656bb9-786x1688-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Instant Sell Success (1).png","size":388031,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.4656398104265403,"height":1688,"width":786},"lqip":"data:image/png;base64,"},"_id":"image-7518ef0c14e23597d63ec0c8a5729712d4656bb9-786x1688-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/7518ef0c14e23597d63ec0c8a5729712d4656bb9-786x1688.png"}},"field_width":"auto"}]}],"field_type":"ol"},{"_key":"e0480963293f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_id":"fdf052b5e6ea","field_title":"How to sell"},{"_key":"f0ba9104b68e","_type":"paragraphAccordionItem","field_children":[{"_key":"b565be068a74","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Our convert feature allows you to change between any crypto and cash combination. This includes cash to cash, crypto to crypto, as well as cash to crypto:\u003c/p>"},{"_key":"8625b7ee0373","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"5c15ad4a3a20","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"d273c96951e5","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Tap the \u003cstrong>Trade\u003c/strong> button and then tap \u003cstrong>Convert\u003c/strong>.\u003c/p>"},{"_key":"0ef87bce1b13","_type":"paragraphArticleImage","field_image":{"alt":"Trade","asset":{"_ref":"image-1416fcc5f62b2d538b130a4b670618f7e3553683-1179x1733-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Home_Trade.jpg","size":120254,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.6803231390652048,"height":1733,"width":1179},"lqip":"data:image/jpeg;base64,"},"_id":"image-1416fcc5f62b2d538b130a4b670618f7e3553683-1179x1733-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/1416fcc5f62b2d538b130a4b670618f7e3553683-1179x1733.jpg"}},"field_width":"auto"},{"_key":"88c3f2d89972","_type":"paragraphArticleImage","field_image":{"alt":"Convert","asset":{"_ref":"image-b17c2ef16cea61653ed3f58bf5862e544ae63787-1132x752-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"image.png","size":180037,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.5053191489361701,"height":752,"width":1132},"lqip":"data:image/png;base64,"},"_id":"image-b17c2ef16cea61653ed3f58bf5862e544ae63787-1132x752-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/b17c2ef16cea61653ed3f58bf5862e544ae63787-1132x752.png"}},"field_width":"auto"}]},{"_key":"471e99512ca7","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"ec8ab6ebfbd3","_type":"paragraphArticleBodyLc","field_body":"\u003cp>The first field is the asset you want to \u003cstrong>Convert from. \u003c/strong>The second field is for the asset you want \u003cstrong>Convert to. \u003c/strong>Select from any of your existing account balances. \u003c/p>"},{"_key":"79a35787d4ee","_type":"paragraphArticleImage","field_image":{"alt":"Convert currency","asset":{"_ref":"image-8affedd41163cd51cc2b33fdfd431c3b32391036-390x844-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Convert.png","size":36814,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.46208530805687204,"height":844,"width":390},"lqip":"data:image/png;base64,"},"_id":"image-8affedd41163cd51cc2b33fdfd431c3b32391036-390x844-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/8affedd41163cd51cc2b33fdfd431c3b32391036-390x844.png"}},"field_width":"auto"},{"_key":"3899006705de","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Next, input the amount you would like to convert. The Order type \u003cstrong>Instant\u003c/strong> is selected by default. If everything looks right, tap \u003cstrong>Continue\u003c/strong> to review. \u003c/p>"},{"_key":"b2e691898d45","_type":"paragraphArticleImage","field_image":{"alt":"Convert currency 2","asset":{"_ref":"image-21b31f40ee01de5c412846c9186b786dc4c8b90c-390x844-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Convert.png","size":37284,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.46208530805687204,"height":844,"width":390},"lqip":"data:image/png;base64,"},"_id":"image-21b31f40ee01de5c412846c9186b786dc4c8b90c-390x844-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/21b31f40ee01de5c412846c9186b786dc4c8b90c-390x844.png"}},"field_width":"auto"},{"_key":"b441520b23d7","_type":"paragraphArticleBodyLc","field_body":"\u003cblockquote>Order type\u003c/blockquote>"},{"_key":"b3bd232232f5","_type":"paragraphArticleImage","field_image":{"alt":"Order type","asset":{"_ref":"image-cc14cf6ad76d6b89d7e9d96cd7fddf3bbc95d68d-364x546-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Convert.jpeg","size":16474,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.6666666666666666,"height":546,"width":364},"lqip":"data:image/jpeg;base64,"},"_id":"image-cc14cf6ad76d6b89d7e9d96cd7fddf3bbc95d68d-364x546-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/cc14cf6ad76d6b89d7e9d96cd7fddf3bbc95d68d-364x546.jpg"}},"field_width":"auto"}]},{"_key":"79b16ca3b2d9","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"52135327c547","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Tap \u003cstrong>Confirm\u003c/strong> to complete your conversion.\u003c/p>"},{"_key":"77f762717eac","_type":"paragraphArticleImage","field_image":{"alt":"Convert confirm","asset":{"_ref":"image-a1074a623b31aaae526e05799279228d31350a10-390x844-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Instant convert.png","size":30282,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.46208530805687204,"height":844,"width":390},"lqip":"data:image/png;base64,"},"_id":"image-a1074a623b31aaae526e05799279228d31350a10-390x844-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/a1074a623b31aaae526e05799279228d31350a10-390x844.png"}},"field_width":"auto"},{"_key":"dcded8bf9204","_type":"paragraphArticleImage","field_image":{"alt":"Convert confirmation ","asset":{"_ref":"image-36247c2bfc6eed77b215a46a297f71ffb791bd9a-390x844-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Instant buy.png","size":172000,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.46208530805687204,"height":844,"width":390},"lqip":"data:image/png;base64,"},"_id":"image-36247c2bfc6eed77b215a46a297f71ffb791bd9a-390x844-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/36247c2bfc6eed77b215a46a297f71ffb791bd9a-390x844.png"}},"field_width":"auto"}]}],"field_type":"ol"},{"_key":"74ec7361a88e","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_id":"4b5662ba8634","field_title":"How to convert"}]},{"_key":"d198c36f683f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_last_updated_label":"Last updated:","field_title":"Buying, selling and converting cryptocurrency with the Kraken app","field_tldr_title":"Key takeaways"}],"field_page_meta":{"description":"Support Center for Kraken.com | Bitcoin & Cryptocurrency Exchange | Bitcoin Trading Platform","title":"Buying, selling and converting cryptocurrency with the Kraken app | Kraken"},"field_tags":[{"_key":"9a4df5889e39","_ref":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","_type":"taxonomyTag","_id":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","firstPublishedAt":"2026-01-20T10:38:23.492Z","lastPublishedAt":"2026-01-20T10:38:23.492Z","name":"sc-tier-1"}],"field_target_languages":["de_de","es_es","fr_fr","it_it","nl_nl","pl_pl","pt_br","ru_ru","tr_tr","uk_ua","vi_vn","zh_cn"],"lastPublishedAt":"2025-08-08T22:53:30.977Z","locale":{"_ref":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","_type":"taxonomyLocales","_id":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","code":"en-us","field_label":"English","name":"en-US"},"path":"/articles/360058727972-buying-selling-and-converting-cryptocurrency-with-the-kraken-app","status":true,"title":"Buying, selling and converting cryptocurrency with the Kraken app"}},{"_key":"ecb322a4b8c1","reference":{"_ref":"article-360001449826","_type":"page","_id":"article-360001449826","_system":{"base":{"id":"article-360001449826","rev":"8GspKpLKzWgCGxfZLkxmQ7"}},"appId":"support","content_source_locale":"en_us","enabled_locales":[],"field_page_components":[{"_key":"2924e7a4f8bf","_type":"paragraphArticleLayout","field_article_breadcrumb_label":"Support","field_article_breadcrumbs":true,"field_children":[{"_key":"527da016ac2b","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Your funding limits depend on many factors like your \u003ca data-testid=\"external-link\" href=\"/articles/360001368823\" rel=\"noopener\" target=\"blank\">residency\u003c/a>, \u003ca data-testid=\"external-link\" href=\"https://support.kraken.com/articles/360001395743\" rel=\"noopener\" target=\"_blank\">verification status\u003c/a>&nbsp;and the asset you&#39;re trying to deposit or withdraw.\u003c/p>\n"},{"_key":"118c5f525ca5","_type":"paragraphAccordion","field_children":[{"_key":"b7283ab7b531","_type":"paragraphAccordionItem","field_children":[{"_key":"e960d4630d92","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Your funding limits are determined by a number of factors, including your verification status, country of residence, transaction activity, how long you’ve had a Kraken account, and the asset you're trying to deposit or withdraw. Cash and cryptocurrency limits reset on a rolling 24-hour and 30-day basis. Limits for certain payment methods are dynamic and may change over time. In most cases, your limits will increase the more that you use Kraken.\u003c/p>"}],"field_id":"IViUYaICa-WeUY1WnC8Zk","field_title":"How limits work"},{"_key":"c5eb4aab44ed","_type":"paragraphAccordionItem","field_children":[{"_key":"7b77dfe03fcf","_type":"paragraphArticleBodyLc","field_body":"\u003cp>If you have a verified account, you can increase your funding limits by verifying more information about your identity and ensuring your account is secured with \u003ca target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https://support.kraken.com/articles/360000426923-secure-your-account-with-two-factor-authentication-2fa-\">2-factor authentication\u003c/a>. For more information about verifying your identity, please see \u003ca target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https://support.kraken.com/articles/360021973671-how-to-get-verified-on-kraken\">how to get verified on Kraken.\u003c/a>\u003cbr>\u003cbr>If you have a personal account with higher limits already, you can contact Support to request an increase in funding limits, however, we cannot guarantee an increase above the default amount for all funding methods or asset types.\u003c/p>"}],"field_id":"uZc_vNqJvRa9yC3uBzD6g","field_title":" Increasing your limits "},{"_key":"021134b68419","_type":"paragraphAccordionItem","field_children":[{"_key":"03d7027dc54d","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360000678446\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Cryptocurrency\u003c/a> limits depend on verification level as shown below: \u003c/p>"},{"_key":"771f7b2240cd","_type":"paragraphArticleBodyTable","field_rows":[{"_key":"674e316d45b8","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"76bf0940a17c","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Daily (24 hour)","field_content":"\u003cp>\u003cstrong>Daily (24 hour)\u003c/strong>\u003c/p>"},{"_key":"584277afecf9","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":""},{"_key":"1b20c787ab53","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":""}],"row_description":"Row :: Daily (24 hour)"},{"_key":"ca9d22773cea","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"bdab1c76df17","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Daily (24 hour)","field_content":"\u003cp>\u003c/p>"},{"_key":"f90dc9079c52","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>\u003cstrong>Standard verification\u003c/strong>\u003c/p>\n"},{"_key":"22805e04171c","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>\u003cstrong>Higher limits\u003c/strong>\u003c/p>\n"}],"row_description":"Row :: "},{"_key":"1fba36a080d4","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"d0b588101d87","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Daily (24 hour)","field_content":"\u003cp>\u003cstrong>Deposit\u003c/strong>\u003c/p>"},{"_key":"249c1f1745d5","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>Unlimited\u003c/p>"},{"_key":"4ae2be198464","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>Unlimited\u003c/p>"}],"row_description":"Row :: Deposit"},{"_key":"705cad2686e8","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"718f23962a09","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Daily (24 hour)","field_content":"\u003cp>\u003cstrong>Withdraw\u003c/strong>\u003c/p>"},{"_key":"6e9b03b4f574","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>$500,000\u003c/p>"},{"_key":"541ae8f4b934","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>$10,000,000+**\u003c/p>"}],"row_description":"Row :: Withdraw"}],"table_description":"Table: Legacy Migrated Placeholder","table_expanded_table":false,"table_mobile_style":"classic"},{"_key":"20d2e8cac925","_type":"paragraphArticleBodyTable","field_rows":[{"_key":"d560995f1464","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"84ce96946132","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Monthly (30 day)  limits ","field_content":"\u003cp>\u003cstrong>Monthly (30 day) \u003c/strong>\u003cspan class=\"unknown__pt__mark__0c02ae9ace811\">\u003cspan class=\"unknown__pt__mark__200a129ea91ff\">\u003cspan class=\"unknown__pt__mark__224c148ab5f28\">\u003cspan class=\"unknown__pt__mark__226107273fad7\">\u003cspan class=\"unknown__pt__mark__2af88a0b9f6b6\">\u003cspan class=\"unknown__pt__mark__33707f687e8d9\">\u003cspan class=\"unknown__pt__mark__45739783cbb8a\">\u003cspan class=\"unknown__pt__mark__4f1dfe515d64e\">\u003cspan class=\"unknown__pt__mark__50980688f604d\">\u003cspan class=\"unknown__pt__mark__5ce3e84822232\">\u003cspan class=\"unknown__pt__mark__62e7ea0ed804b\">\u003cspan class=\"unknown__pt__mark__66ffca6a73545\">\u003cspan class=\"unknown__pt__mark__67339fcd2c02d\">\u003cspan class=\"unknown__pt__mark__7023452c87ab3\">\u003cspan class=\"unknown__pt__mark__7069d2e1c8689\">\u003cspan class=\"unknown__pt__mark__7090fff0fa951\">\u003cspan class=\"unknown__pt__mark__7279310def8fc\">\u003cspan class=\"unknown__pt__mark__76b119b04bcb9\">\u003cspan class=\"unknown__pt__mark__7e6eecb59af59\">\u003cspan class=\"unknown__pt__mark__8e1cbdb85e483\">\u003cspan class=\"unknown__pt__mark__8e71e25e0bc3e\">\u003cspan class=\"unknown__pt__mark__941d85edf5840\">\u003cspan class=\"unknown__pt__mark__961032174f9da\">\u003cspan class=\"unknown__pt__mark__970869f23cf30\">\u003cspan class=\"unknown__pt__mark__9aab58bd579ca\">\u003cspan class=\"unknown__pt__mark__b1d85b82db910\">\u003cspan class=\"unknown__pt__mark__b7319bd449ee0\">\u003cspan class=\"unknown__pt__mark__b74bba5da40bf\">\u003cspan class=\"unknown__pt__mark__b94a1165738e3\">\u003cspan class=\"unknown__pt__mark__be109cdd3e984\">\u003cspan class=\"unknown__pt__mark__cf8bf54b169a6\">\u003cspan class=\"unknown__pt__mark__db169207fb03b\">\u003cspan class=\"unknown__pt__mark__de1ab5d576157\">\u003cspan class=\"unknown__pt__mark__e89d265db4522\">\u003cspan class=\"unknown__pt__mark__f0d7a3829874a\">\u003cspan class=\"unknown__pt__mark__f2e4af257c49b\">\u003cspan class=\"unknown__pt__mark__f3a9a780aada8\">\u003cspan class=\"unknown__pt__mark__f9337172bf293\">\u003cspan class=\"unknown__pt__mark__feab96ad27dd7\">\u003cbr/>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003c/span>\u003cstrong> limits\u003c/strong>\u003c/p>"},{"_key":"d9357e4d7082","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":""},{"_key":"ec7ebbfd1322","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":""}],"row_description":"Row ::  Monthly (30 day)  limits "},{"_key":"5bf6e91a8436","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"5479bdf9ca85","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Monthly (30 day)  limits ","field_content":"\u003cp>\u003c/p>"},{"_key":"f94e482375e4","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>\u003cstrong>Standard verification\u003c/strong>\u003c/p>\n"},{"_key":"7350c382975e","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>\u003cstrong>Higher limits\u003c/strong>\u003c/p>\n"}],"row_description":"Row :: "},{"_key":"b16cdf51b267","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"e59b0b2349c8","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Monthly (30 day)  limits ","field_content":"\u003cp>\u003cstrong>Deposit\u003c/strong>\u003c/p>"},{"_key":"43d7f5f491d3","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>Unlimited\u003c/p>"},{"_key":"b632d4af34f9","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>Unlimited\u003c/p>"}],"row_description":"Row :: Deposit"},{"_key":"647f9f681521","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"139bd3e226bf","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Monthly (30 day)  limits ","field_content":"\u003cp>\u003cstrong>Withdraw\u003c/strong>\u003c/p>"},{"_key":"108c76fca7d6","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>Unlimited\u003c/p>"},{"_key":"1dd3c21dcdee","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>Unlimited\u003c/p>"}],"row_description":"Row :: Withdraw"}],"table_description":"Table: Legacy Migrated Placeholder","table_expanded_table":false,"table_mobile_style":"classic"},{"_key":"b5ecec60bd08","_type":"paragraphArticleBodyLc","field_body":"\u003cblockquote>All limit values are calculated in USD.\u003c/blockquote>\u003cp>\u003cem>**If you wish to increase your limits beyond the default amount, view the \u003ca href=\"#uZc_vNqJvRa9yC3uBzD6g\">&quot;Increasing your limits&quot; section \u003c/a>above. \u003c/em>\u003c/p>"}],"field_id":"Uru36mqHjZfVJB9PXaFDy","field_title":" Cryptocurrency limits "},{"_key":"75c6e999e5ab","_type":"paragraphAccordionItem","field_children":[{"_key":"386527b90ee1","_type":"paragraphArticleBodyLc","field_body":"\u003cp>The currency limits apply to all \u003ca data-testid=\"external-link\" href=\"/sections/4402657269268-Cash-Funding\" rel=\"noopener\" target=\"blank\">cash\u003c/a>&nbsp;funding options. Limits for instant purchase options or ACH deposits are subject to your Kraken account limits and depend on which method you choose. This applies to the following methods:\u003c/p>\n"},{"_key":"79e50cda4ad8","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"300e6ff92335","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"abbf44d6c42f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca data-testid=\"external-link\" href=\"/articles/8795459449492-How-do-I-fund-my-account-with-USD-using-ACH-via-Plaid-\" rel=\"noopener\" target=\"blank\">ACH purchases and deposits\u003c/a>\u003c/p>\n"}]},{"_key":"7a849e61c4fa","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"0cf6c1385b1c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360048212832-Debit-or-credit-card-purchases-with-Visa-and-Mastercard-\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Credit card purchases\u003c/a>\u003c/p>"}]},{"_key":"af0cedf9b511","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"dc9d90ad29ad","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/4405883992724-Digital-wallet-purchases\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Digital wallet purchases\u003c/a>\u003c/p>"}]},{"_key":"34de1686077b","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"5ab8ec0584a6","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360045033651-AUD-Bank-Transfers-with-Osko-and-PayID\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">AUD funding limits\u003c/a>\u003c/p>"}]}],"field_type":"ul"},{"_key":"92b4912b4048","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Remember\u003c/strong> that all limit values are calculated in USD. For example, if you have a verified account without higher limits, and you deposit 100,000 EUR when EUR is worth more than USD, your deposit will be put on-hold for going over the daily limit.\u003c/p>\n"},{"_key":"a0f2fb1200b0","_type":"paragraphArticleBodyTable","field_rows":[{"_key":"672b0669a7b0","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"e80776f5bf43","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Daily (24 hour)","field_content":"\u003cp>Daily (24 hour)\u003c/p>"},{"_key":"244261738140","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":""},{"_key":"40a2bb8ef9e0","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":""}],"row_description":"Row :: Daily (24 hour)"},{"_key":"89b722afb081","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"7127489e3e85","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Daily (24 hour)","field_content":"\u003cp>\u003c/p>"},{"_key":"023cafad8a51","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>\u003cstrong>Standard verification\u003c/strong>\u003c/p>\n"},{"_key":"0c80ad857903","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>\u003cstrong>Higher limits\u003c/strong>\u003c/p>\n"}],"row_description":"Row :: "},{"_key":"7bc8e418d95d","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"1ddb91e71e46","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Daily (24 hour)","field_content":"\u003cp>\u003cstrong>Deposit\u003c/strong>\u003c/p>"},{"_key":"148a816d9a11","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>$100,000\u003c/p>"},{"_key":"dbef35fa6e63","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>$10,000,000+**\u003c/p>"}],"row_description":"Row :: Deposit"},{"_key":"e3c738dbb0b5","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"80ee1cc7133f","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Daily (24 hour)","field_content":"\u003cp>\u003cstrong>Withdraw\u003c/strong>\u003c/p>"},{"_key":"4377cee1b49b","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>$100,000\u003c/p>"},{"_key":"0ca574bf94f9","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>$10,000,000+**\u003c/p>"}],"row_description":"Row :: Withdraw"}],"table_description":"Table: Legacy Migrated Placeholder","table_expanded_table":false,"table_mobile_style":"classic"},{"_key":"0e303b50d034","_type":"paragraphArticleBodyTable","field_rows":[{"_key":"e11920d30d2d","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"1c29d2d14b2f","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Monthly (30 day)  limits ","field_content":"\u003cp>\u003cstrong>Monthly (30 day) \u003c/strong>\u003cspan class=\"unknown__pt__mark__0c02ae9ace811\">\u003cspan class=\"unknown__pt__mark__200a129ea91ff\">\u003cspan class=\"unknown__pt__mark__224c148ab5f28\">\u003cspan class=\"unknown__pt__mark__226107273fad7\">\u003cspan class=\"unknown__pt__mark__2af88a0b9f6b6\">\u003cspan class=\"unknown__pt__mark__33707f687e8d9\">\u003cspan class=\"unknown__pt__mark__45739783cbb8a\">\u003cspan class=\"unknown__pt__mark__4f1dfe515d64e\">\u003cspan class=\"unknown__pt__mark__50980688f604d\">\u003cspan class=\"unknown__pt__mark__5ce3e84822232\">\u003cspan class=\"unknown__pt__mark__62e7ea0ed804b\">\u003cspan class=\"unknown__pt__mark__66ffca6a73545\">\u003cspan class=\"unknown__pt__mark__67