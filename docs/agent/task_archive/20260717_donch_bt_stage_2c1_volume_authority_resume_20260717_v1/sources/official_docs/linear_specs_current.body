rong>\u003c/p>"},{"_key":"8cdf23e844d3","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Withdrawal hold ","field_content":"\u003cp> Withdrawal hold \u003c/p>"}],"row_description":"Row ::  Availability "},{"_key":"6444944c3a13","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"1b63f24a1293","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Availability ","field_content":"\u003cp>Argentina only*\u003c/p>\n"},{"_key":"f4751f5b3f5a","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Deposit method ","field_content":"\u003cp>\u003cstrong>\u003cstrong>Bank transfer&nbsp;\u003c/strong>\u003c/strong>\u003c/p>\n"},{"_key":"074657909e71","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Deposit minimum ","field_content":"\u003cp>10,000 ARS\u003c/p>\n"},{"_key":"7bb0e4ef009d","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Deposit fee ","field_content":"\u003cp>free\u003c/p>"},{"_key":"f7bec6dec4d6","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Processing time ","field_content":"\u003cp>Near-instant\u003c/p>\n"},{"_key":"41c5449e9c25","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Withdrawal hold ","field_content":"\u003cp> None \u003c/p>"}],"row_description":"Row ::  Worldwide* "}],"table_description":"Table: Legacy Migrated Placeholder","table_expanded_table":true,"table_mobile_style":"classic"},{"_key":"bedc0cc18505","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>*Funding methods by \u003ca href=\"https://support.kraken.com/articles/360001395743-verification-levels-explained\">account type\u003c/a>\u003c/strong>\u003c/p>\n"},{"_key":"f923f629e585","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"755e279aa68e","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"701221444799","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Verified accounts will have full access to ARS funding.\u003c/p>\n"}]},{"_key":"1442a8efed86","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"f0a9e7c1d920","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Pro personal and Business accounts will support SWIFT funding only.\u003c/p>\n"}]}],"field_type":"ul"},{"_key":"b25de2b483bd","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Accounts that support ARS will not have any alternative funding methods enabled. If you have questions or require assistance, please contact our \u003ca href=\"https://support.kraken.com/forms/38536269187476\">support team for further guidance.\u003c/a>\u003c/p>\n"}],"field_title":"ARS (Argentine Peso)"},{"_key":"dd64eb5e3155","_type":"paragraphAccordionItem","field_children":[{"_key":"780d6fd5bc4f","_type":"paragraphArticleBodyTable","field_rows":[{"_key":"bhZsWIgCsGT-xqJCIAxBk","field_cells":[{"_key":"dYvOdnHoEKhzs39nQ20V9","cell_description":"Content of Column 1","field_content":"Availability"},{"_key":"3OXJpJJRC1XGfyCvS4c38","cell_description":"Content of Column 2","field_content":"Deposit method"},{"_key":"9Cw6x5Gq4R_hBOQ_3mb1S","cell_description":"Content of Column 3","field_content":"Deposit minimum"},{"_key":"k7YzuckahnXfCq5b5kI5P","cell_description":"Content of Column 4","field_content":"Deposit fee"},{"_key":"2DsslpzQ5u2GpnwoAAHq6","cell_description":"Content of Column 5","field_content":"Processing time"}],"row_description":"Row :: Availability"},{"_key":"h-xPbWDP20chHwtw-EGDb","field_cells":[{"_key":"CMjegliM49_XJYdIOzWf-","cell_description":"Content of Column 1","field_content":"\u003cp>Brazil only\u003c/p>\n"},{"_key":"qSUl5U1DKobsS-tGuay_M","cell_description":"Content of Column 2","field_content":"\u003cp>\u003ca href=\"https://support.kraken.com/articles/what-is-the-pix-funding-method\">Bank transfer (PIX\u003c/a>)\u003c/p>\n"},{"_key":"BOdXdyI8XBrHzwZnxdqKz","cell_description":"Content of Column 3","field_content":"50 BRL"},{"_key":"0jWUYxuQ3p1NqTYGBw6fx","cell_description":"Content of Column 4","field_content":"\u003cp>0.3% IOF tax\u003c/p>"},{"_key":"hEZ6beaFPH8122Yb1WV-6","cell_description":"Content of Column 5","field_content":"Near instant"},{"_key":"cec7f8cd9f00","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here"}],"row_description":"Row :: Brazil"}],"table_expanded_table":true,"table_mobile_style":"classic"}],"field_is_expanded":false,"field_title":"BRL (Brazilian real)"},{"_key":"ab4e97fe3d2b","_type":"paragraphAccordionItem","field_children":[{"_key":"63be1c7b8361","_type":"paragraphArticleBodyTable","field_rows":[{"_key":"mJ6aJpJXrvhgLpd38GxCN","field_cells":[{"_key":"E7UFQXnOB5IGDtU1L0fzW","cell_description":"Content of Column 1","field_content":"Availability"},{"_key":"k476l1dIj5ENDcz-xkVuv","cell_description":"Content of Column 2","field_content":"Deposit method"},{"_key":"-9sxCxxAbB2Dcz4X1sFwI","cell_description":"Content of Column 3","field_content":"Deposit minimum"},{"_key":"xvfGGvJrbT-veOwgpebWL","cell_description":"Content of Column 4","field_content":"Deposit fee"},{"_key":"51kG9xwwPo9xJ_eA0P-rg","cell_description":"Content of Column 5","field_content":"Processing time"}],"row_description":"Row :: Availability"},{"_key":"92403b4e77ba","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"5296f12f428b","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Mexico only\u003c/p>\n"},{"_key":"62a23e2778fb","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Bank transfer (SPEI)\u003c/p>\n"},{"_key":"8f3d5702fd78","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>150 MXN\u003c/p>\n"},{"_key":"7b797e478d0b","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>free\u003c/p>"},{"_key":"8823a3da1ed3","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Up to 20 minutes\u003c/p>\n"}],"row_description":"Row :: add here"}],"table_expanded_table":true,"table_mobile_style":"classic"}],"field_is_expanded":false,"field_title":"MXN (Mexican Pesos)"}]},{"_key":"3e51e87913f8","_type":"paragraphArticleHeadingBody","field_body":"\u003cp>If you have verified your Kraken account, depending on your \u003ca data-testid=\"external-link\" href=\"https://support.kraken.com/articles/where-is-kraken-licensed-or-regulated\" rel=\"noopener\" target=\"blank\">country of residence,\u003c/a>&nbsp;you may be able to use one of the next payment methods:\u003c/p>\n","field_heading":" Want to buy instantly? ","field_level":1},{"_key":"dd819ea68fdd","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"9ebb2540d6c7","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"ef61d3aec2d4","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360048212832-Visa-and-MasterCard-purchases\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">\u003cstrong>Visa and Mastercard debit/credit card\u003c/strong>\u003c/a>\u003c/p>"}]},{"_key":"b932098d5b9d","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"d3eaab7faa46","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/4405883992724-Digital-wallet-purchases\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">\u003cstrong>Digital wallet purchases\u003c/strong>\u003c/a>\u003c/p>"}]},{"_key":"8388d9aa592a","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"4e07fbc3eecb","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/how-do-i-use-plaid-ach-for-instant-buy-using-usd\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">\u003cstrong>Buying instantly with Plaid ACH\u003c/strong>\u003c/a>\u003c/p>"}]}],"field_type":"ul"},{"_key":"23cd4310a459","_type":"paragraphArticleHeadingBody","field_body":"\u003cp>Krak App offers a quick, cost-free way to move funds directly between Kraken accounts.&nbsp;\u003c/p>\n","field_heading":" Krak App","field_level":1},{"_key":"3847d23ca8b8","_type":"paragraphArticleButtonLink","field_download_on_click":false,"field_event":{"_ref":"006c01d23b3c","_type":"taxonomyAnalyticsEvents","_id":"006c01d23b3c","name":"Button Clicked"},"field_event_properties":{"action":"Growth CTA","label":"Get on Krak","path":"/articles/360000381846-cash-deposit-options-fees-minimums-and-processing-times-","title":"Cash deposit options (fees, minimums and processing times)","url":"https://support.kraken.com/articles/360000381846-cash-deposit-options-fees-minimums-and-processing-times-"},"field_is_download_link":false,"field_link":{"_type":"link","text":"Get on Krak","url":"https://www.kraken.com/krak?utm_source=supportcenter&utm_medium=article&utm_campaign=krakapp"},"field_nofollow":false,"field_skip_automatic_adjustments":false},{"_key":"b79e454bbed6","_type":"paragraphArticleHeadingBody","field_body":"","field_heading":" Important deposit information ","field_heading_html_id":"37a7ff4d4784","field_level":2},{"_key":"619736214d20","_type":"paragraphNotification","field_can_be_closed":false,"field_direction":"inline","field_has_icon":true,"field_text":"\u003cp>\u003cp> If required and shown in the deposit instructions, make sure your deposit includes a \u003ca href=\"/articles/360000381026-Why-is-the-deposit-reference-important-\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">reference\u003c/a> to your Kraken \u003ca href=\"/articles/360028555092-How-to-find-your-account-number-Public-Account-ID-\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Public account ID\u003c/a> which starts with AA and is 16 characters long. \u003c/p>\u003c/p>","field_title":"Prevent deposit delays","field_tone":"warning"},{"_key":"b2a11c64e54b","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"38ab25dde587","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"d9edee816ed9","_type":"paragraphArticleBodyLc","field_body":"\u003cp> The currency you use for a bank transfer (deposit) to Kraken, must match the currency of the deposit method. For example, if you&#x27;re sending EUR, it should only go to EUR deposit methods like SEPA &amp; SEPA Instant (Banking Circle), SEPA (Bank Frick), or EUR SWIFT (Bank Frick) for transfers from outside the SEPA area. If you send a cash transfer in the wrong currency to one of our bank accounts, the transfer may be returned and/or some additional charges may be applied. \u003c/p>"}]},{"_key":"4cf4586ae6cc","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"56ec13731f46","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Deposit fees are what it costs Kraken to accept your deposit and do not include your bank&#39;s charges (if any) for sending a transfer.\u003c/p>\n"}]},{"_key":"c9a4656df88c","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"498ef874a417","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Verified residents in Canada can deposit with cash and debit cards using our \u003ca href=\"/articles/360027825511-Canada-Post-In-Person-Cash-and-Debit-CAD-deposits\">In-Person\u003c/a> provider.\u003c/p>\n"}]},{"_key":"5f8fc191e16e","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"e09d800ba56e","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Please be mindful of \u003ca href=\"/articles/360041580292\">banking holidays\u003c/a>.&nbsp;\u003c/p>\n"}]},{"_key":"afea4c8553a5","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"9d1aa3954c67","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>This information can change without notice and is not always current. Please sign in to your Kraken account and navigate to the relevant funding page to see the most current information.\u003c/strong>\u003c/p>\n"}]},{"_key":"8d9b81eae4e7","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"14259f45e71f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Kraken does not currently support US domestic deposits via checks. Do not mail checks or deposit physical cash directly to any of our bank accounts or addresses. Any checks we receive will be destroyed.\u003c/p>\n"}]}],"field_type":"ul"},{"_key":"7d2c8f303fff","_type":"paragraphArticleHeadingBody","field_body":"","field_heading":" Frequently asked questions ","field_heading_html_id":"73ff0b2949f5","field_level":1},{"_key":"ed608d9c98b5","_type":"paragraphAccordion","field_children":[{"_key":"aecff8c5813b","_type":"paragraphAccordionItem","field_children":[{"_key":"e2b4755c1d0c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Processing times are estimates only and are outside of Kraken&#39;s control. Delays are possible. If your deposit does not arrive within the estimated time frame above, please \u003ca href=\"/articles/360000410866\">follow these steps\u003c/a>.\u003c/p>\n"}],"field_id":"XYyi3f-jQKQ8s3a0xhETX","field_title":" Why hasn't my deposit arrived yet? "},{"_key":"c6f35e91deda","_type":"paragraphAccordionItem","field_children":[{"_key":"a9121779cdc0","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Your bank may charge you fees for sending the deposit to our payments processors.\u003c/p>\n\n\u003cp>Intermediary or correspondent banks (banks between your bank and our bank that processes the transaction in transit) may also charge fees or convert the transaction to a different currency en route (if sending euros from outside of Europe, for example). These fees are on the account of the sender and the responsibility of the sending bank.\u003c/p>\n"}],"field_id":"5iTPX4Saor6iPZFyv39Om","field_title":" Are there any other fees? "},{"_key":"5e152a688301","_type":"paragraphAccordionItem","field_children":[{"_key":"c260b3354a8e","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360001449826\">Deposit limits\u003c/a> will depend on your verification level.\u003c/p>\n"}],"field_id":"AMhYAl4d5jl9ATA3Gv4_H","field_title":" What are the deposit limits? "},{"_key":"d9268e797b1b","_type":"paragraphAccordionItem","field_children":[{"_key":"8aa9682d0799","_type":"paragraphArticleBodyLc","field_body":"\u003cp>A \u003ca data-testid=\"external-link\" href=\"/articles/360000380966\" rel=\"noopener\" target=\"blank\">deposit might be held for various reasons.\u003c/a> When a deposit is held our support team will reach out promptly with more information.\u003c/p>\n"}],"field_id":"mso0eyYOXSZ6Mi-3F9QEo","field_title":" Why is my deposit being held? "}]},{"_key":"372df0dcce88","_type":"paragraphArticleBodyLc","field_body":"\u003cblockquote>\u003cem>The decimal and thousands separators shown in this article may differ from the formats displayed on our trading platforms. Review our article on how we use points and commas for more information.\u003c/em>\u003c/blockquote>"}],"field_last_updated_label":"Last updated:","field_title":"Cash deposit options (fees, minimums and processing times)","field_tldr_title":"Key takeaways"}],"field_page_meta":{"description":"Support Center for Kraken.com | Bitcoin & Cryptocurrency Exchange | Bitcoin Trading Platform","title":"Cash deposit options (fees, minimums and processing times) | Kraken"},"field_tags":[{"_key":"fd8a63968685","_ref":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","_type":"taxonomyTag","_id":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","firstPublishedAt":"2026-01-20T10:38:23.492Z","lastPublishedAt":"2026-01-20T10:38:23.492Z","name":"sc-tier-1"}],"field_target_languages":["es_es","de_de","fr_fr","it_it","nl_nl","pl_pl","pt_br","ru_ru","vi_vn","tr_tr","uk_ua","zh_cn"],"is_article":true,"lastPublishedAt":"2026-06-15T17:38:54.298Z","locale":{"_ref":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","_type":"taxonomyLocales","_id":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","code":"en-us","field_label":"English","name":"en-US"},"path":"/articles/360000381846-cash-deposit-options-fees-minimums-and-processing-times-","status":true,"title":"Cash deposit options (fees, minimums and processing times)"}},{"_key":"ec2bfc0c6bf0","reference":{"_ref":"article-360000423043","_type":"page","_id":"article-360000423043","_system":{"base":{"id":"article-360000423043","rev":"6MhMITRfqm7ciowiEOhASq"}},"appId":"support","content_source_locale":"en_us","enabled_locales":[],"field_page_components":[{"_key":"26c4febb042f","_type":"paragraphArticleLayout","field_article_breadcrumb_label":"Support","field_article_breadcrumbs":true,"field_children":[{"_key":"94bbd1c2e00f","_type":"paragraphNotification","field_alternative_icon":"InfoCircle","field_can_be_closed":false,"field_direction":"inline","field_has_icon":true,"field_text":"\u003cp>\u003cp>For security, certain transactions such as \u003ca href=\"/articles/8795459449492\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">ACH,\u003c/a> \u003ca href=\"/articles/fund-your-kraken-account-with-paypal\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Paypal\u003c/a>, \u003ca href=\"/articles/360048212832\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">debit or credit card purchases\u003c/a> or\u003ca href=\"/articles/4405883992724-Digital-wallet-purchases\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\"> digital wallet purchases\u003c/a> will trigger a temporary (72 hour) withdrawal hold. Cash deposits via \u003ca href=\"/articles/8795459449492-How-do-I-fund-my-account-with-USD-using-ACH-via-Plaid-\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">ACH Plaid\u003c/a> are held from withdrawal for 7 days. \u003cstrong>This applies to all crypto and fiat withdrawals.\u003c/strong> Debit/credit card purchases in USD may always be subject to the 72-hour hold, not just the first transaction.\u003c/p>\u003c/p>","field_title":"Withdrawal hold","field_tone":"primary"},{"_key":"e5f81c84635b","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Below is an overview of withdrawal options and their minimums, fees and processing times.\u003c/p>"},{"_key":"e81e6de5a985","_type":"paragraphArticleHeadingBody","field_body":"","field_heading":" Important withdrawal information ","field_heading_html_id":"c9cf7ea9b08b","field_level":2},{"_key":"3b5334f4a8e6","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"a04972b0ff62","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"49e158944dbe","_type":"paragraphArticleBodyLc","field_body":"\u003cp>This information can change without notice and is not always current. Please sign in to your Kraken account and navigate to the relevant funding page to see the most current information.\u003c/p>"}]},{"_key":"a67e7d321606","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"57aaa357a5f7","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360000381006\" >Cash\u003c/a>, checks, \u003ca href=\"/articles/360000381006\" >credit &amp; debit cards\u003c/a> or \u003ca href=\"/articles/360000382423\" >third-party payments processor\u003c/a> withdrawals are not possible.\u003c/p>"}]},{"_key":"5ed29f09c8fc","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"cc3ac7f4ca5c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Processing times are estimates only and are outside of Kraken&#x27;s control, so delays are possible.\u003c/p>"}]},{"_key":"14debfc09d3d","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"a9d68daa3814","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Please be mindful of banking holidays. \u003c/p>"}]},{"_key":"db6e6d8c9dcf","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"56a0257c5005","_type":"paragraphArticleBodyLc","field_body":"\u003cp>If your withdrawal does not arrive within the estimated time frame below, \u003ca href=\"/articles/360000410866\" >follow these steps\u003c/a>.\u003c/p>"}]}],"field_type":"ul"},{"_key":"6180f75b9a2c","_type":"paragraphArticleHeadingBody","fie