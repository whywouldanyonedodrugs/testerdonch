ell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":""},{"_key":"940191b25fb1","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":""}],"row_description":"Row ::  Monthly (30 day)  limits "},{"_key":"249420707d20","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"ce4db5eae636","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Monthly (30 day)  limits ","field_content":"\u003cp>\u003c/p>"},{"_key":"7940d0af010e","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>\u003cstrong>Standard verification\u003c/strong>\u003c/p>\n"},{"_key":"dd631168873a","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>\u003cstrong>Higher limits\u003c/strong>\u003c/p>\n"}],"row_description":"Row :: "},{"_key":"d1286b60884e","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"02889ed6e3b6","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Monthly (30 day)  limits ","field_content":"\u003cp>\u003cstrong>Deposit\u003c/strong>\u003c/p>"},{"_key":"8dabae114a0c","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>$500,000\u003c/p>"},{"_key":"853bc4cbce4d","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>$100,000,000+\u003c/p>"}],"row_description":"Row :: Deposit"},{"_key":"a0b99981964d","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"24eb5d77fd85","_type":"paragraphArticleBodyTableCell","cell_description":"Column ::  Monthly (30 day)  limits ","field_content":"\u003cp>\u003cstrong>Withdraw\u003c/strong>\u003c/p>"},{"_key":"77c3e5576d6b","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>$500,000\u003c/p>"},{"_key":"bdcab68d11d3","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: Legacy Migrated Placeholder","field_content":"\u003cp>$100,000,000+\u003c/p>"}],"row_description":"Row :: Withdraw"}],"table_description":"Table: Legacy Migrated Placeholder","table_expanded_table":false,"table_mobile_style":"classic"},{"_key":"42f287e61e07","_type":"paragraphArticleBodyLc","field_body":"\u003cblockquote>All limit values are calculated in USD.\u003c/blockquote>\u003cp>\u003cem>**If you wish to increase your limits beyond the default amount, view the \u003ca href=\"#uZc_vNqJvRa9yC3uBzD6g\">&quot;Increasing your limits&quot; section \u003c/a>above. \u003c/em>\u003c/p>"}],"field_id":"TB_PmnJzdS3qhDD57Vxqg","field_title":"Cash limits"}]},{"_key":"ac7024a52235","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Related articles:\u003c/strong>\u003c/p>"},{"_key":"a6f4821e11fc","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"53e6a71b1f53","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"220dd97b22c3","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360001368823\" >Where can I use Kraken?\u003c/a>\u003c/p>"}]},{"_key":"d665c2be34b1","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"3456b1f54c73","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360001395743\" >What can I do with each verification Level?\u003c/a>\u003c/p>"}]},{"_key":"5da57eacdb7a","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"97f8f82d88d5","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360000381806\" >How to view cash deposit and withdrawal limits?\u003c/a>\u003c/p>"}]},{"_key":"e65bb1004766","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"82217b5bab62","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360000381846\" >Cash deposit options (fees, minimums and processing times)\u003c/a>\u003c/p>"}]}],"field_type":"ul"},{"_key":"832dd8a1b87d","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cem>The decimal and thousands separators shown in this article may differ from the formats displayed on our trading platforms. Review our article on how we use points and commas for more information.\u003c/em>\u003c/p>"}],"field_last_updated_label":"Last updated:","field_title":"Deposit and withdrawal limits by verification status","field_tldr_title":"Key takeaways"}],"field_page_meta":{"description":"Support Center for Kraken.com | Bitcoin & Cryptocurrency Exchange | Bitcoin Trading Platform","title":"Deposit and withdrawal limits by verification level | Kraken"},"field_target_languages":["de_de","es_es","fr_fr","it_it","nl_nl","pl_pl","pt_br","ru_ru","tr_tr","uk_ua","vi_vn","zh_cn"],"is_article":true,"lastPublishedAt":"2026-04-13T22:48:51.484Z","locale":{"_ref":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","_type":"taxonomyLocales","_id":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","code":"en-us","field_label":"English","name":"en-US"},"path":"/articles/360001449826-deposit-and-withdrawal-limits-by-verification-level","status":false,"title":"Deposit and withdrawal limits by verification level"}},{"_key":"bf35a386ffd1","reference":{"_ref":"article-360028093572","_type":"page","_id":"article-360028093572","_system":{"base":{"id":"article-360028093572","rev":"eo7fo3UGT1I6NVQ6e5FtTz"}},"appId":"support","content_source_locale":"en_us","enabled_locales":[],"field_page_components":[{"_key":"cf32626d2edc","_type":"paragraphArticleLayout","field_article_breadcrumb_label":"Support","field_article_breadcrumbs":true,"field_children":[{"_key":"6d5e5668f426","_type":"paragraphNotification","field_can_be_closed":false,"field_direction":"inline","field_has_icon":true,"field_text":"\u003cp>\u003cp>If required and shown in the deposit instructions, make sure your deposit includes a \u003ca href=\"/articles/360000381026-Why-is-the-deposit-reference-important-\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">reference\u003c/a> to your Kraken \u003ca href=\"/articles/360028555092-How-to-find-your-account-number-Public-Account-ID-\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Public account ID\u003c/a> which starts with AA and is 16 characters long.\u003c/p>\u003c/p>","field_title":"Prevent deposit delays","field_tone":"warning"},{"_key":"081c233c2854","_type":"paragraphNotification","field_alternative_icon":"InfoCircle","field_can_be_closed":false,"field_direction":"inline","field_has_icon":true,"field_text":"\u003cp>\u003cp>Read the \u003ca href=\"/articles/360000381846#h_01F6F7XD5Y8DDF5MMQYZJH3827\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">important deposit information\u003c/a> and \u003ca href=\"/articles/360000381846-Cash-deposit-options-fees-minimums-and-processing-times-#h_01FCQ050FAQ8RGD4JEXZPQYW7V\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">frequently asked questions\u003c/a> before depositing. If your deposit was placed on hold \u003ca href=\"/articles/360000380966\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">review this article\u003c/a> for more information.\u003c/p>\u003c/p>","field_title":"First-time cash deposits","field_tone":"primary"},{"_key":"47b9a15d8441","_type":"paragraphArticleBodyLc","field_body":"\u003cp>To help your deposit go smoothly, please check the information below before sending any funds.\u003cbr/>\u003c/p>\u003cp>\u003c/p>"},{"_key":"f934cb682200","_type":"paragraphAccordion","field_children":[{"_key":"0de411c04880","_type":"paragraphAccordionItem","field_children":[{"_key":"115b43a1b620","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"e5578b543f41","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"4f1917e3a34a","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Account ownership\u003c/strong>: Make sure the name on the bank account you are depositing from matches the name on your Kraken account. If your bank account is a joint account, one of the names on the bank account must match the name on your Kraken account.\u003cbr/>\u003cbr/>\u003c/p>"}]},{"_key":"1560249c7970","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"d3913cd0a477","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Account type:\u003c/strong> Deposits from a business bank account can \u003cstrong>only \u003c/strong>be sent to a \u003ca href=\"/articles/115004862007-Business-account-with-Pro-limits\">Kraken business account\u003c/a>. Similarly, a personal Kraken account should only be funded from a personal bank account that is registered under the same name as your Kraken account.\u003c/p>\n"}]},{"_key":"e6280b5528ab","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"5bf4f387334b","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360000381026\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">\u003cstrong>Deposit memo\u003c/strong>\u003c/a>: If required and shown in the deposit instructions, make sure your deposit includes a reference to your Kraken Public account ID which starts with AA and is 16 characters long. \u003c/p>"}]},{"_key":"b1e1da7fb01b","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"e9cc3676635c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360000381846\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">\u003cstrong>Deposit minimum\u003c/strong>\u003c/a>: Make sure your deposit is above the minimum required amount.\u003c/p>"}]},{"_key":"37dd50c6b93f","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"8e59421834fe","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360001449826\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">\u003cstrong>Deposit limits\u003c/strong>\u003c/a>: Make sure the deposit will not result in you exceeding your daily or monthly deposit limit. Refer to the value indicated as your &quot;Maximum deposit.&quot;\u003c/p>"}]},{"_key":"2236f1f5c1d2","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"532e5b7104c0","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Duplicate deposit amounts\u003c/strong>: Make sure you don&#x27;t send multiple deposits of the same amount within a 72 hour period. This may result in delays as our system will flag them as possible duplicates. Please use different amounts for each deposit.\u003c/p>"}]},{"_key":"cdc2d59b2f1b","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"9b3a168def36","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Compatible bank\u003c/strong>: Make sure you are not depositing from a \u003ca href=\"/articles/360000382423\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">third-party payments processor\u003c/a>.\u003c/p>"}]}],"field_type":"ul"},{"_key":"8be28afd9f36","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_id":"k7wAt-WGB6nDF40Qp3bWt","field_title":"Deposit checklist"},{"_key":"af95de58e48e","_type":"paragraphAccordionItem","field_children":[{"_key":"e2b0e134f67d","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"b126d41de6e7","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"718e86e80012","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Account type\u003c/strong>: It is best to deposit from your checking account as savings accounts have a limited amount of transactions that are allowed to occur. Check with your bank if there are any of these limits on your savings account. Business Kraken accounts can accept transactions from IRA, Trust or a business(LLC) bank account.\u003c/p>"}]},{"_key":"6a5f8519efcd","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"8996e7ce0efd","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Transfer method\u003c/strong>: Confirm with your bank whether you are using a \u003ca href=\"/articles/360000410583\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">FedWire\u003c/a> transfer option.\u003c/p>"}]},{"_key":"d142eab1df1a","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"e676140699f4","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>USD Deposit limits\u003c/strong>: Make sure the deposit will not result in you exceeding your \u003ca href=\"/articles/360000381846-Cash-deposit-options-fees-minimums-and-processing-times-\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">USD daily or monthly deposit limits\u003c/a>.\u003c/p>"}]}],"field_type":"ul"}],"field_id":"LY_3WtbnQZ29RRSvNfdL8","field_title":"Additional things to check for domestic USD deposits"}]},{"_key":"74f6c52972a8","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cbr/>If you notice any \u003ca href=\"/articles/360000381846\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">unexpected delays\u003c/a> in having funds credited to your Kraken account, \u003ca href=\"/articles/360000410866\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">see this support article\u003c/a>.\u003c/p>"}],"field_last_updated_label":"Last updated:","field_title":"Bank deposit requirements and checklist","field_tldr_title":"Key takeaways"}],"field_page_meta":{"description":"Support Center for Kraken.com | Bitcoin & Cryptocurrency Exchange | Bitcoin Trading Platform","title":"Bank deposit requirements and checklist | Kraken"},"field_tags":[{"_key":"d6d956732ad1","_ref":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","_type":"taxonomyTag","_id":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","firstPublishedAt":"2026-01-20T10:38:23.492Z","lastPublishedAt":"2026-01-20T10:38:23.492Z","name":"sc-tier-1"}],"field_target_languages":["de_de","es_es","fr_fr","it_it","nl_nl","pl_pl","pt_br","ru_ru","tr_tr","uk_ua","vi_vn","zh_cn"],"lastPublishedAt":"2025-11-10T17:44:25.732Z","locale":{"_ref":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","_type":"taxonomyLocales","_id":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","code":"en-us","field_label":"English","name":"en-US"},"path":"/articles/360028093572-bank-deposit-requirements-and-checklist","status":true,"title":"Bank deposit requirements and checklist"}},{"_key":"7bfe05a28d10","reference":{"_ref":"article-201396837","_type":"page","_id":"article-201396837","_system":{"base":{"id":"article-201396837","rev":"xkQmuGjb6jes3pD0yOJ6ua"}},"appId":"support","content_source_locale":"en_us","enabled_locales":[],"field_page_components":[{"_key":"5aa009cc1f1c","_type":"paragraphArticleLayout","field_article_breadcrumb_label":"Support","field_article_breadcrumbs":true,"field_children":[{"_key":"630a24593ef2","_type":"paragraphArticleBodyLc","field_body":"\u003cp>At Kraken, \u003ca href=\"https://www.kraken.com/features/security\" >we prioritize and invest heavily in security\u003c/a>. However, don&#x27;t let this put your own guard down. No amount of security on our end can make up for inadequate personal security.\u003c/p>\u003cp>It is vital for clients to take advantage of the account security tools and advice that we offer and to never share access to the account with anyone else.\u003c/p>"},{"_key":"a22af062efeb","_type":"paragraphAccordion","field_children":[{"_key":"b53e65cf867a","_type":"paragraphAccordionItem","field_children":[{"_key":"d1cdd803bfd7","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"f8c3a2ce5b10","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"5fdb3c95cb36","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Never allow anyone to create or manage an account on your behalf.\u003c/p>\n"}]},{"_key":"b44f0ec04c9f","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"29de1a84ec14","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Create a \u003ca href=\"https://support.kraken.com/articles/201396497\" style=\"text-decoration:none\">\u003cu>password\u003c/u>\u003c/a> that is long (at least 15 characters) and that is not used on any other website. We recommend using a password manager such as KeePass or 1Password.\u003c/p>\n"}]},{"_key":"dd7791a6c3ab","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"47d3aa66e52b","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Enable \u003ca href=\"https://support.kraken.com/articles/360000911823\" style=\"text-decoration:none\">\u003cu>Sign-in 2FA\u003c/u>\u003c/a>, ideally using multiple \u003ca href=\"https://support.kraken.com/articles/what-is-a-passkey\" style=\"text-decoration:none\">\u003cu>Passkeys\u003c/u>\u003c/a>. This is the most important security feature.\u003c/p>\n\n\u003col>\n\t\u003cli style=\"list-style-type:lower-alpha\">Sign-in 2FA activates \u003ca href=\"https://support.kraken.com/articles/4406211200404\" style=\"text-decoration:none\">\u003cu>Step-up 2FA\u003c/u>\u003c/a>, an additional security layer required anytime you want to add, edit or remove any 2FA settings on your account.&nbsp;\u003c/li>\n\t\u003cli style=\"list-style-type:lower-alpha\">Warnings\n\t\u003col>\n\t\t\u003cli style=\"list-style-type:lower-roman\">A poorly stored \u003ca href=\"https://support.kraken.com/articles/360001486466\" style=\"text-decoration:none\">\u003cu>2FA backup code\u003c/u>\u003c/a> puts your account at risk of compromise. If you are worried about losing your sign-in 2FA, set up \u003ca href=\"https://support.kraken.com/articles/how-to-enable-multiple-two-factor-authentication-on-kraken-web-refresh\" style=\"text-decoration:none\">\u003cu>multiple Passkeys\u003c/u>\u003c/a> and a \u003ca href=\"https://support.kraken.com/articles/360000444923-what-is-a-master-key-\" style=\"text-decoration:none\">\u003cu>Master Key\u003c/u>\u003c/a> (see point 4).\u003c/li>\n\t\t\u003cli style=\"list-style-type:lower-roman\">There are potential security \u003ca href=\"https://support.kraken.com/articles/risks-of-using-an-authenticator-app\" style=\"text-decoration:none\">\u003cu>risks with using an Authenticator App\u003c/u>\u003c/a>. Upgrade your security settings by enabling \u003ca href=\"https://support.kraken.com/articles/what-is-a-passkey\" style=\"text-decoration:none\">\u003cu>Passkeys\u003c/u>\u003c/a>.\u003c/li>\n\t\u003c/ol>\n\t\u003c/li>\n\u003c/ol>\n"}]},{"_key":"d38ce4d30047","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"a6f017a84dae","_type":"paragraphArticleBodyLc","field_body":"\u003cp style=\"list-style-type:decimal\">Set up a \u003ca href=\"https://support.kraken.com/articles/how-to-enable-a-master-key-on-kraken-video-guide\" style=\"text-decoration:none\">\u003cu>Master Key\u003c/u>\u003c/a> to have additional protection against password resets and as a backup for your Sign-in 2FA.\u003c/p>\n\n\u003col>\n\t\u003cli style=\"list-style-type:lower-alpha\">If your email is ever compromised, a Master Key can prevent unwanted Kraken password resets.\u003c/li>\n\t\u003cli style=\"list-style-type:lower-alpha\">Make sure the Master Key is set up using a different method from your&nbsp; Sign-in 2FA. For example, if you use a Hardware Security Key for Sign-in 2FA, then use a Cross-Device Passkey set up on your mobile device for the Master Key.\u003c/li>\n\u003c/ol>\n"}]},{"_key":"a56b83e0fcfd","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"ce2e8a685995","_type":"paragraphArticleBodyLc","field_body":"\u003cp style=\"list-style-type:decimal\">Enable the \u003ca href=\"https://support.kraken.com/articles/201396877\" style=\"text-decoration:none\">\u003cu>Global Settings Lock (GSL)\u003c/u>\u003c/a> to prevent changes to your account settings and withdrawal addresses &mdash; even if an attacker gains access to your account.\u003c/p>\n\n\u003col>\n\t\u003cli style=\"list-style-type:lower-alpha\">Always enable a Master Key before enabling the GSL. Kraken Support cannot speed up GSL removal.\u003c/li>\n\u003c/ol>\n"}]},{"_key":"f31162bc4a6a","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"834bf08dc2a9","_type":"paragraphArticleBodyLc","field_body":"\u003cp style=\"list-style-type:decimal\">Enable 2FA for \u003ca href=\"https://support.kraken.com/articles/360000911763\" style=\"text-decoration:none\">\u003cu>withdrawals\u003c/u>\u003c/a>, \u003ca href=\"https://support.kraken.com/articles/360000911503\" style=\"text-decoration:none\">\u003cu>trading\u003c/u>\u003c/a> and \u003ca href=\"https://support.kraken.com/articles/360000714526\" style=\"text-decoration:none\">\u003cu>API\u003c/u>\u003c/a>.\u003c/p>\n\n\u003col>\n\t\u003cli style=\"list-style-type:lower-alpha\">Step-up 2FA or the GSL must be active in order for these 2FAs to be effective.\u003c/li>\n\u003c/ol>\n"}]},{"_key":"cb69709e8ace","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"ee24f46bf07d","_type":"paragraphArticleBodyLc","field_body":"\u003cp style=\"list-style-type:decimal\">\u003ca href=\"https://support.kraken.com/articles/115012482687\" style=\"text-decoration:none\">\u003cu>Beware of scams\u003c/u>\u003c/a>.\u003c/p>\n\n\u003col>\n\t\u003cli style=\"list-style-type:lower-alpha\">Bookmark \u003ca href=\"https://id.kraken.com/sign-in\" style=\"text-decoration:none\">\u003cu>id.kraken.com/sign-in\u003c/u>\u003c/a> to avoid using search engines to navigate to our site.\u003c/li>\n\t\u003cli style=\"list-style-type:lower-alpha\">Unlike authenticator apps, Passkeys are resistant to phishing. Enable them today.\u003c/li>\n\t\u003cli style=\"list-style-type:lower-alpha\">Never share your sign-in details with anyone. The Kraken Support Team will never ask for your password or to install third party software.&nbsp;\u003c/li>\n\t\u003cli style=\"list-style-type:lower-alpha\">Verify the legitimacy of any emails claiming to be from Kraken by checking \u003ca href=\"https://support.kraken.com/hc/en-us/articles/is-this-email-from-kraken\" style=\"text-decoration:none\">\u003cu>Is this email from Kraken\u003c/u>\u003c/a>?\u003c/li>\n\u003c/ol>\n"}]},{"_key":"e1c8c9708ae2","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"38337af8a8cf","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"https://support.kraken.com/articles/360001332083\" style=\"text-decoration:none\">\u003cu>Only use Kraken&#39;s official apps\u003c/u>\u003c/a>. Third-party mobile apps using Kraken&#39;s name or asking for your Kraken credentials are forms of phishing.\u003c/p>\n"}]}],"field_type":"ol"}],"field_id":"#securing-your-Kraken-account","field_is_expanded":false,"field_title":"Securing your Kraken account"},{"_key":"9a99e0fea047","_type":"paragraphAccordionItem","field_children":[{"_key":"c021abe25142","_type":"paragraphArticleBodyLc","field_body":"\u003cp>If the email address associated with your Kraken account is compromised, it can be used to request your username, reset your password and approve withdrawals.\u003c/p>\n"},{"_key":"999092e3b0ce","_type":"paragraphNotification","field_can_be_closed":false,"field_closed_state_is_persistent":true,"field_direction":"stacked","field_has_icon":true,"field_text":"\u003cp>We strongly recommend setting up a dedicated email address that you only use for Kraken.\u003c/p>\n","field_tone":"primary"},{"_key":"6ef04ae23162","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"60e609f07348","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"b52460d00e29","_type":"paragraphArticleBodyLc","field_body":"\u003cp style=\"list-style-type:decimal\">Create a password using \u003ca href=\"https://support.kraken.com/articles/201396497\" style=\"text-decoration:none\">\u003cu>the same guidelines as for your Kraken password\u003c/u>\u003c/a>.\u003c/p>\n\n\u003col>\n\t\u003cli style=\"list-style-type:lower-alpha\">Ensure it is unique and not the same password used for any other accounts you may have.\u003c/li>\n\u003c/ol>\n"}]},{"_key":"1477b3ff3cdb","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"5f1d6f366766","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Set up Two-factor Authentication for your email address, preferably with Passkeys if they are an available option. Don&#39;t use the SMS 2FA option if your email provider offers it.\u003c/p>\n"}]},{"_key":"3c07ceedecd0","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"4faa85e36159","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"https://blog.kraken.com/post/219/security-advisory-mobile-phones/\" style=\"text-decoration:none\">\u003cu>Remove your phone numbers from your email account\u003c/u>\u003c/a>.\u003c/p>\n"}]},{"_key":"5b0e3404054b","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"cab841a5c437","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Set up \u003ca href=\"https://support.kraken.com/articles/201648223\" style=\"text-decoration:none\">\u003cu>PGP\u003c/u>\u003c/a> (for Advanced clients) to receive signed and encrypted email from us, if your email provider supports it.\u003c/p>\n"}]}],"field_type":"ol"},{"_key":"68cd68ddbc78","_type":"paragraphArticleBodyLc","field_body":"\u003cp>For additional information, see \u003ca href=\"https://support.kraken.com/articles/360021870651-securing-your-email-address\" style=\"text-decoration:none\">\u003cu>Securing your email address\u003c/u>\u003c/a>.\u003c/p>\n"}],"field_is_expanded":false,"field_title":"Securing your email"},{"_key":"9618d7852c22","_type":"paragraphAccordionItem","field_children":[{"_key":"752a2fcc7cef","_type":"paragraphArticleBodyLc","field_body":"\u003cp>A compromised device can log and record everything you type into it, and mobile devices are the most common way to use \u003ca href=\"https://support.kraken.com/articles/360000426923\" style=\"text-decoration:none\">\u003cu>two-factor authentication (2FA)\u003c/u>\u003c/a>.\u003c/p>\n"},{"_key":"5c6ef044de5b","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"11c3f7363b95","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"4bc6c9ddc9c4","_type":"paragraphArticleBodyLc","field_body":"\u003cp style=\"list-style-type:decimal\">Enable a password/PIN on your device.\u003c/p>\n\n\u003col>\n\t\u003cli style=\"list-style-type:lower-alpha\">Create a secure passphrase and use biometric sign-in (fingerprint, face ID), if possible. Avoid easy to guess PINs and sign-in patterns.\u003c/li>\n\u003c/ol>\n"},{"_key":"65c61a23a968","_type":"paragraphArticleBodyLc","field_body":"\u003cp style=\"list-style-type:decimal\">Don&#39;t share your device.\u003c/p>\n\n\u003col>\n\t\u003cli style=\"list-style-type:lower-alpha\">Don&#39;t get guilted by friends and family to share access and passwords to your devices, especially if you use those devices for your 2FA.\u003c/li>\n\u003c/ol>\n"},{"_key":"7c293034a6ce","_type":"paragraphArticleBodyLc","field_body":"\u003cp style=\"list-style-type:decimal\">Never install remote access software such as AnyDesk, TeamViewer, RemotePC or GoToMyPC.\u003c/p>\n\n\u003col>\n\t\u003cli style=\"list-style-type:lower-alpha\">Some customer service teams will request remote access to your computer to help troubleshoot technical issues. This is very dangerous and it is also a favorite technique of scammers.\u003c/li>\n\t\u003cli style=\"list-style-type:lower-alpha\">Kraken Support will never ask you to install remote access software!\u003c/li>\n\u003c/ol>\n"},{"_key":"830c85b0b798","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Avoid public computers and/or devices. Only sign in from your personal devices.\u003c/p>\n"},{"_key":"72d7b3e45498","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Avoid work devices for personal accounts. They are able to monitor and record your activity.\u003c/p>\n"}]}],"field_type":"ol"}],"field_is_expanded":false,"field_title":"Securing your devices"},{"_key":"804cbed0e12c","_type":"paragraphAccordionItem","field_children":[{"_key":"769276f8ad3d","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Mobile phone numbers have become a critical element in authentication and account recovery processes. However, they pose significant security risks, especially for handling sensitive information, including cryptocurrency.\u003c/p>\n\n\u003cp>Telecom providers often lack robust security measures, leaving users vulnerable to attacks like phone number hijacking, where attackers use social engineering to gain control over a victim&#39;s number. The consequences can include theft, extortion, and loss of access to key accounts.\u003c/p>\n\n\u003cp>To safeguard your accounts and personal data, you can think about the following:\u003c/p>\n"},{"_key":"809193a1a29c","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"8bd37c267b19","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"abd6bfd34ea2","_type":"paragraphArticleBodyLc","field_body":"\u003cp style=\"list-style-type:decimal\">Avoid using your mobile phone number as a primary identifier or for two-factor authentication (2FA) wherever possible.\u003c/p>\n\n\u003col>\n\t\u003cli style=\"list-style-type:lower-alpha\">Replace SMS-based 2FA with Passkeys, Hardware Security Keys or authenticator apps for improved security.\u003c/li>\n\t\u003cli style=\"list-style-type:lower-alpha\">If SMS is your only option, consider a dedicated phone number solely for authentication. Use a pre-paid burner phone or a service like Google Voice to limit exposure.\u003c/li>\n\u003c/ol>\n"}]},{"_key":"6ef2c7172648","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"21a9ae29df30","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Set a strong PIN or passcode on your telecom account to secure changes and protect your number.\u003c/p>\n"}]},{"_key":"bb05f2f4b2fe","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"ef037b63ee8e","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Request a port freeze and enable a SIM lock to prevent unauthorized number transfers.\u003c/p>\n"}]},{"_key":"eb52606e6a1c","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"872a85a50ad1","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Regularly audit your online accounts to ensure they are not linked to your phone number unnecessarily.\u003c/p>\n"}]}],"field_type":"ol"},{"_key":"5d01015d1580","_type":"paragraphArticleBodyLc","field_body":"\u003cp>By taking these proactive measures, you can significantly reduce the risks associated with mobile phone vulnerabilities, securing your digital assets and safeguarding your online presence.\u003c/p>\n"}],"field_is_expanded":false,"field_title":"Securing your mobile phone number"},{"_key":"ecbba68515bc","_type":"paragraphAccordionItem","field_children":[{"_key":"f79db2318971","_type":"paragraphArticleBodyLc","field_body":"\u003cp>A compromised internet connection can steal your sign-in details and direct you to phishing sites. Here are some ways you can secure your internet connection:\u003c/p>\n"},{"_key":"edf9e0225738","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"f53aa94c345f","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"6572a3103e53","_type":"paragraphArticleBodyLc","field_body":"\u003cp style=\"list-style-type:decimal\">Change the default password on your home internet router.\u003c/p>\n\n\u003col>\n\t\u003cli style=\"list-style-type:lower-alpha\">Keeping the default password will allow any stranger from the internet to gain control over your router.\u003c/li>\n\t\u003cli style=\"list-style-type:lower-alpha\">To prevent brute force attacks, use \u003ca href=\"https://support.kraken.com/articles/201396497\" style=\"text-decoration:none\">\u003cu>the same guidelines as for your Kraken password\u003c/u>\u003c/a>, ensuring it is unique.\u003c/li>\n\u003c/ol>\n"}]},{"_key":"33a22e4c09ee","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"78b748879a2c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Make sure your WiFi network is password protected. This is separate from the router password.\u003c/p>\n"}]},{"_key":"86ad1adb7b68","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"9c8b52534c56","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Create a guest network if your router has that option and keep the main network private for your devices only.\u003c/p>\n"}]},{"_key":"ec44760cf3ef","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"968d53bd587f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Avoid public WiFi. Use your mobile data plan instead. If you have to use public WiFi, make sure to have a reputable VPN (avoid free VPNs).\u003c/p>\n"}]}],"field_type":"ol"}],"field_is_expanded":false,"field_title":"Securing your internet"}]}],"field_last_updated_label":"Last updated:","field_title":"Securing your Kraken account and digital life","field_tldr_title":"Key takeaways"}],"field_page_meta":{"description":"Support Center for Kraken.com | Bitcoin & Cryptocurrency Exchange | Bitcoin Trading Platform","title":"Securing your Kraken account and digital life | Kraken"},"field_tags":[{"_key":"1d37063f3f52","_ref":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","_type":"taxonomyTag","_id":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","firstPublishedAt":"2026-01-20T10:38:23.492Z","lastPublishedAt":"2026-01-20T10:38:23.492Z","name":"sc-tier-1"}],"field_target_languages":["de_de","es_es","fr_fr","it_it","nl_nl","pl_pl","pt_br","ru_ru","tr_tr","uk_ua","vi_vn","zh_cn"],"lastPublishedAt":"2025-08-08T19:15:10.853Z","locale":{"_ref":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","_type":"taxonomyLocales","_id":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","code":"en-us","field_label":"English","name":"en-US"},"path":"/articles/201396837-securing-your-kraken-account-and-digital-life","status":true,"title":"Securing your Kraken account and digital life"}}],"visibility":[{"_key":"ffc46030c54e","component":"searchFilter","value":true}]},{"_createdAt":"2025-03-06T16:06:26Z","_id":"product-Classic","_key":"bb42ffbdcaa0","_rev":"R4bDO5qNaIcYVJNTEZsDyn","_type":"taxonomyProduct","_updatedAt":"2025-05-30T08:07:28Z","deprecated":false,"description":"","displayName":"Kraken Classic","editable":false,"name":"Product: Classic","topArticles":[],"visibility":[{"_key":"24c1d228093b","component":"searchFilter","value":true}]},{"_createdAt":"2025-03-06T16:06:26Z","_id":"e5892589-0b2c-4f06-bd71-4cb2f5ef93f2","_key":"27287b27f181","_rev":"R4bDO5qNaIcYVJNTEZsDyn","_type":"taxonomyProduct","_updatedAt":"2025-05-30T08:07:28Z","deprecated":false,"description":null,"displayName":"Kraken Desktop","editable":false,"name":"Product: Kraken Desktop","topArticles":[{"_key":"01e0f5005d4c","reference":{"_ref":"efc511d0-e99a-499c-8316-10a4465b4bad","_type":"page","_id":"efc511d0-e99a-499c-8316-10a4465b4bad","_system":{"base":{"id":"efc511d0-e99a-499c-8316-10a4465b4bad","rev":"i1tyRZhQ5X1BzjThFmUKOC"}},"appId":"support","content_source_locale":"en_us","enabled_locales":[],"field_page_components":[{"_key":"dcbe383d79fa","_type":"paragraphArticleLayout","field_article_breadcrumb_label":"Support","field_article_breadcrumbs":true,"field_children":[{"_key":"58f250574ebe","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Kraken Desktop\u003c/strong> is a \u003cstrong>free\u003c/strong> trading terminal packed with state-of-the-art features and a robust suite of tools for detailed market analysis, advanced charting, and order execution.\u003c/p>"},{"_key":"836ae301454b","_type":"paragraphArticleInteractiveVideo","field_video_url":"https://www.youtube.com/watch?v=P_9PKnK812c&feature=youtu.be"},{"_key":"c4b1973addb7","_type":"paragraphArticleBodyLc","field_body":"\u003cp>To use Kraken Desktop, first you need to \u003ca href=\"https://www.kraken.com/sign-up\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">create a Kraken account\u003c/a>. If you already have one, you may \u003ca href=\"/articles/how-to-install-kraken-desktop\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">install Kraken Desktop\u003c/a> and begin right away!\u003c/p>\u003cblockquote>Check eligibility for a Kraken account \u003ca href=\"/articles/201352206-Verification-level-requirements\\\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">here\u003c/a>.\u003c/blockquote>"},{"_key":"ffc821c228c0","_type":"paragraphAccordion","field_children":[{"_key":"b03f02f86dee","_type":"paragraphAccordionItem","field_children":[{"_key":"d6e57a31b99a","_type":"paragraphArticleBodyLc","field_body":"\u003cp>The Kraken Desktop interface can be customized to your personal perfection. A \u003cstrong>“Board” \u003c/strong>is the main interface, the entire screen, where modules can be positioned in any location, and sized to your liking in order to fill the board.\u003c/p>\u003cp>Multiple boards can be opened simultaneously, allowing you to interact with several of them at once, and create multi-monitor setups. To accomplish this, click the\u003cstrong> Board Management\u003c/strong> button in the top right corner. Then, click the external link button located on the right side of each board.\u003c/p>"},{"_key":"d3042e6fd2be","_type":"paragraphArticleImage","field_image":{"alt":"KrakenDesktop_Board_Ticker","asset":{"_ref":"image-19ce728c0bf8f6f55623ee8d77192e4e98378514-682x780-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"KrakenDesktop_Board_Ticker.png","size":48588,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.8743589743589744,"height":780,"width":682},"lqip":"data:image/png;base64,"},"_id":"image-19ce728c0bf8f6f55623ee8d77192e4e98378514-682x780-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/19ce728c0bf8f6f55623ee8d77192e4e98378514-682x780.png"}},"field_width":"auto"},{"_key":"f028a1a6bab4","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Within a board, modules can be dragged to different locations by holding the top of the module, and moving it to your desired location. To resize the module, simply drag any of the 4 sides to your preferred sizing.\u003c/p>\u003cp>You may also\u003cstrong> “split”\u003c/strong> modules to add new modules within the same amount of space as the original. For example, let’s split a module into five modules:\u003cbr/>\u003c/p>"},{"_key":"0eceaf442656","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"e8e253731993","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"f4c49d59b94f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>At the top of the module you wish to split, click \u003cstrong>Split\u003c/strong> module.\u003c/p>"},{"_key":"8610d8663840","_type":"paragraphArticleImage","field_image":{"alt":"Split Module","asset":{"_ref":"image-5edde596740ec7aaca3f8a06c580b33a4ae90de6-420x76-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"KrakenDesktop_SplitModule.png","size":3822,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":5.526315789473684,"height":76,"width":420},"lqip":"data:image/png;base64,"},"_id":"image-5edde596740ec7aaca3f8a06c580b33a4ae90de6-420x76-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/5edde596740ec7aaca3f8a06c580b33a4ae90de6-420x76.png"}},"field_width":"auto"}]},{"_key":"46db635429b3","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"c231454e4614","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Next, let’s select \u003cstrong>1x5.\u003c/strong> \u003c/p>\u003cp>This will turn our one large module into five smaller modules that take up the same amount of space.\u003c/p>"},{"_key":"a549d5d84219","_type":"paragraphArticleImage","field_image":{"alt":"Split 1x5","asset":{"_ref":"image-645d31988556e04f900e324f407960cbc3fecc0a-616x176-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"KrakenDesktop_Split1x5.png","size":10925,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":3.5,"height":176,"width":616},"lqip":"data:image/png;base64,"},"_id":"image-645d31988556e04f900e324f407960cbc3fecc0a-616x176-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/645d31988556e04f900e324f407960cbc3fecc0a-616x176.png"}},"field_width":"auto"},{"_key":"00cddd2ae989","_type":"paragraphArticleBodyLc","field_body":"\u003cblockquote>\u003cstrong>Note:\u003c/strong> By holding CMD or CTRL, the new modules created will be clones of the existing module.\u003c/blockquote>"}]},{"_key":"6426d3cbe169","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"1be96fff075e","_type":"paragraphArticleBodyLc","field_body":"\u003cp>The module has now been split into five individual modules, click \u003cstrong>Configure\u003c/strong> to select each new module.\u003c/p>\u003cblockquote>\u003cstrong>Before\u003c/strong>:\u003c/blockquote>"},{"_key":"75caa1d494ba","_type":"paragraphArticleImage","field_image":{"alt":"Before","asset":{"_ref":"image-5dd9092d045a0a80ca0bf7e8264420eebe732a25-1417x838-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Before&After_2024_06_10_04_53_03.png","size":68454,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.6909307875894988,"height":838,"width":1417},"lqip":"data:image/png;base64,"},"_id":"image-5dd9092d045a0a80ca0bf7e8264420eebe732a25-1417x838-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/5dd9092d045a0a80ca0bf7e8264420eebe732a25-1417x838.png"}},"field_width":"auto"},{"_key":"25dd548f57a0","_type":"paragraphArticleBodyLc","field_body":"\u003cblockquote>\u003cstrong>After\u003c/strong>:\u003c/blockquote>"},{"_key":"c7c05197303a","_type":"paragraphArticleImage","field_image":{"alt":"After","asset":{"_ref":"image-a829b38d5d952848ee0123ca3c7bedf2a3f39546-1418x833-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Before&After_2024_06_10_04_51_50.png","size":85373,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.702280912364946,"height":833,"width":1418},"lqip":"data:image/png;base64,"},"_id":"image-a829b38d5d952848ee0123ca3c7bedf2a3f39546-1418x833-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/a829b38d5d952848ee0123ca3c7bedf2a3f39546-1418x833.png"}},"field_width":"auto"}]}],"field_type":"ol"},{"_key":"b827cc05e2aa","_type":"paragraphArticleHeadingBody","field_body":"\u003cp>Kraken Desktop allows you to save up to 100 custom boards. You may manage your saved boards by clicking the Board Management button on the top right of the screen. The Board Management button will always show the current Board you are using. In the example above, you can see we are using the \u003cstrong>“Sample Board”.\u003c/strong>\u003c/p>","field_heading":" Loading saved boards ","field_level":3}],"field_id":"7bb69689bee4","field_title":"Board management"},{"_key":"796c184855c9","_type":"paragraphAccordionItem","field_children":[{"_key":"e4ce0820aee8","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Kraken Desktop boards can fit up to 48 modules at once, and gives you the ability to configure each module with different markets, settings, sounds, and more.\u003c/p>"},{"_key":"c901da42ec11","_type":"paragraphArticleImage","field_image":{"alt":"modules","asset":{"_ref":"image-ee1eb10ada1286a863375ef3a943d0d5f7da91c9-249x519-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"image.png","size":16442,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.4797687861271676,"height":519,"width":249},"lqip":"data:image/png;base64,"},"_id":"image-ee1eb10ada1286a863375ef3a943d0d5f7da91c9-249x519-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/ee1eb10ada1286a863375ef3a943d0d5f7da91c9-249x519.png"}},"field_width":"auto"},{"_key":"f59114f887ff","_type":"paragraphArticleHeadingBody","field_body":"","field_heading":" Module information ","field_level":3},{"_key":"8ec26683af52","_type":"paragraphArticleBodyTable","field_rows":[{"_key":"006a639f3d60","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"6e89a1f9bf3b","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Module information\u003c/p>"},{"_key":"db4bbaf36951","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Description\u003c/p>"}],"row_description":"Row :: Balances"},{"_key":"63305d7e654b","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"233144342e28","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Balances\u003c/p>"},{"_key":"5fc9e925c47a","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>The Balances module provides a real-time overview of your current account balances. It helps you monitor your assets efficiently to manage your portfolio and trading activities effectively.\u003c/p>"}],"row_description":"Row :: Balances"},{"_key":"fba60af397b0","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"bf2f8591eede","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Chart\u003c/p>"},{"_key":"80f8e29e0bf8","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>The Chart module offers advanced interactive charting tools that display historical price data and market trends. Traders can use this module to conduct detailed technical analysis by adding various indicators such as moving averages, RSI, and Bollinger Bands to the charts. This functionality allows for a deep dive into price movements, helping traders make more informed decisions.\u003c/p>"}],"row_description":"Row :: Chart"},{"_key":"a13b5cf01c34","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"e027db93b730","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Clock\u003c/p>"},{"_key":"92fe613bac09","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>The Clock module displays the current time in any time zone of your choosing. (Default is local time) You may select from a digital clock, analog clock, or both.\u003c/p>"}],"row_description":"Row :: Clock"},{"_key":"6a3923840da4","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"06a23aa154e5","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Depth Chart\u003c/p>"},{"_key":"4beedff6b920","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>The Depth Chart module visualizes the order book, showing the number of buy and sell orders at different price levels.\u003c/p>"}],"row_description":"Row :: Depth Chart"},{"_key":"931f9d19dcad","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"54acf1b2b06f","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Ladder\u003c/p>"},{"_key":"34cb4788dde6","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>The Ladder module allows for rapid execution of trades by displaying prices in a vertical sequence, enabling one-click trading at different levels. Up to 4 shortcuts can be created and customized for lightning fast order submissions.\u003c/p>"}],"row_description":"Row :: Ladder"},{"_key":"8543b2987ebe","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"6d8cfb3feb39","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Margin health\u003c/p>"},{"_key":"ac299296f27a","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Real-time overview of your margin positions, including collateral, margin level, and liquidation  indicators.\u003c/p>"}],"row_description":"Row :: Margin health"},{"_key":"58faeada054e","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"e1807b062475","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Order Book\u003c/p>"},{"_key":"9b318428744c","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>The Order Book module lists all current buy and sell orders for the selected market. It helps you gauge market sentiment and liquidity by showing how many orders are active at different price points. \u003c/p>\u003cp>The Order Book is also useful for filling in the Order Ticket module. You may click a price level displayed in the Order Book, and that price will automatically fill within your Order Ticket module.\u003c/p>\u003cp>\u003cstrong>Note:\u003c/strong> In order for automatic filling to work, your \u003ca href=\"/articles/overview-of-module-settings#dcb663303426\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Order Ticket module must be in \u003cstrong>&quot;Selection&quot;\u003c/strong> mode for grouping. \u003c/a>\u003c/p>"}],"row_description":"Row :: Order Book"},{"_key":"5657357835a8","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"b51768b2c24f","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Order Ticket\u003c/p>"},{"_key":"e2d948a616be","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>The Order Ticket module is where you can quickly enter and execute buy or sell orders. It provides options for setting order type, quantity, and price, allowing for precise control over your trading.\u003c/p>"}],"row_description":"Row :: Order Ticket"},{"_key":"38fb9c148dc7","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"5ec0fbf64182","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Spread Chart\u003c/p>"},{"_key":"8de96819126f","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>The Spread Chart module illustrates the price differences between the\u003ca href=\"/articles/115000364388-Trading-glossary\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\"> Base Currency and Quote Currency\u003c/a> of a selected market.\u003c/p>"}],"row_description":"Row :: Spread Chart"},{"_key":"0c4aa272fc2e","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"3cd42481b2a3","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Summary\u003c/p>"},{"_key":"20a6cd3220a7","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>The Summary module offers a concise overview of key trading information for selected markets. It displays recent price changes, volume statistics, and a 24-hour performance snapshot. This module provides essential data at a glance.\u003c/p>"}],"row_description":"Row :: Summary"},{"_key":"c49645e36271","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"e5ecabfbc653","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Text\u003c/p>"},{"_key":"003a904c0453","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>The Text module allows you to add text boxes to your trading interface. This can be used to note strategies, reminders, or important dates directly on your screen.\u003c/p>"}],"row_description":"Row :: Text"},{"_key":"5eb0b41ab5af","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"6f6d3c49b5e0","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Ticker\u003c/p>"},{"_key":"b3122eb8457f","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>The Ticker module continuously updates and displays the latest trading price, 24 hour change, and the current spreads of a particular market.\u003c/p>"}],"row_description":"Row :: Ticker"},{"_key":"e5adee55bdf6","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"f5b8fc271d65","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Time &amp; Sales\u003c/p>"},{"_key":"2b110a3c676e","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>The Time &amp; Sales module shows a real-time list of executed trades, providing details about the time, price, and size of each trade.\u003c/p>"}],"row_description":"Row :: Time & Sales"},{"_key":"8549947334f7","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"23b4966f1c5f","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Trade Activity\u003c/p>"},{"_key":"6a47ea3959d4","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>The Trade Activity module is a comprehensive tool that logs and displays all your trading actions on Kraken. This module organizes information into columns such as the market, side (buy/sell), order type, time, quantity, and much more.\u003c/p>\u003cp>You can use the Trade Activity module to see your open positions, open orders, recent trades, and logs of your trading activity.\u003c/p>"}],"row_description":"Row :: Trade Activity"},{"_key":"b8ba2611e199","_type":"paragraphArticleBodyTableRow","field_cells":[{"_key":"140a30e752b2","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>Watchlist\u003c/p>"},{"_key":"c9ad170896b1","_type":"paragraphArticleBodyTableCell","cell_description":"Column :: add here","field_content":"\u003cp>The Watchlist module allows you to create personalized lists of markets to monitor.\u003c/p>\u003cp>To add a market to your watchlist, add the Watchlist module, then click the settings button in the top right corner. You may then search for markets to add under the Add Market section.\u003c/p>"}],"row_description":"Row :: Watchlist"}],"field_search_placeholder":"Search","table_description":"Module Info","table_expanded_table":false,"table_mobile_style":"summary"},{"_key":"55d8a87688d0","_type":"paragraphArticleImage","field_image":{"alt":"Full","asset":{"_ref":"image-72c607ad1a4994f885a7c3f9e2c9e6e37daf7f76-720x404-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"image.png","size":154291,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.7821782178217822,"height":404,"width":720},"lqip":"data:image/png;base64,"},"_id":"image-72c607ad1a4994f885a7c3f9e2c9e6e37daf7f76-720x404-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/72c607ad1a4994f885a7c3f9e2c9e6e37daf7f76-720x404.png"}},"field_width":"auto"},{"_key":"ca17ae6b704f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>After clicking the\u003cstrong> Board Management\u003c/strong> button, you will see the option to Create a new Board, or you can view your list of saved Boards. You may also drag &amp; drop them to be in any order you wish.\u003c/p>\u003cp>The pencil icon above your saved Boards will present you with the options to rename, clone, or delete a Board.\u003cbr/>\u003c/p>"}],"field_id":"61258ba164b4","field_title":"Using Modules on Kraken Desktop"},{"_key":"4c2c4311c84c","_type":"paragraphAccordionItem","field_children":[{"_key":"2f059a2001d1","_type":"paragraphArticleBodyLc","field_body":"\u003cp>At the top of every module on your Board, you will see a toolbar that allows you to edit or remove the module. Each module will have different buttons in this toolbar depending on the selected module type. Let’s go over the most common buttons below:\u003c/p>"},{"_key":"3acfc9b85415","_type":"paragraphArticleImage","field_image":{"alt":"toolbar","asset":{"_ref":"image-fd7995c3d2c0ee957ac1040e0045e89a89a1722e-516x102-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"Screenshot 2024-08-06 at 15.13.43.png","size":10473,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":5.0588235294117645,"height":102,"width":516},"lqip":"data:image/png;base64,"},"_id":"image-fd7995c3d2c0ee957ac1040e0045e89a89a1722e-516x102-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/fd7995c3d2c0ee957ac1040e0045e89a89a1722e-516x102.png"}},"field_width":"auto"},{"_key":"e9ee7941045f","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"1a6dad7d9323","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"5f64f37680b3","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Settings (Green): \u003c/strong>Here is where you’ll find the majority of your module settings. These settings configure the way your module may display information, which units to use, and much more. Each module’s settings are tailored to provide maximum customization for that particular module type.\u003c/p>"}]},{"_key":"879dc12df0ce","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"c91662d57bc4","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Mute Volume (Orange): \u003c/strong>Clicking this will mute any sounds produced by the module.\u003c/p>"}]},{"_key":"1bb189fc83ca","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"979f7dec48ea","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Split module (Yellow): \u003c/strong>Allows you to split the module into more modules that take up the same amount of space.\u003c/p>"}]},{"_key":"b97bda913235","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"19411d596474","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Screenshot (Blue):\u003c/strong> The screenshot button takes a screenshot of the individual module. You will be shown a preview of the screenshot, and can then download the image as a PNG, TIFF, or BMP file.\u003c/p>\u003cp>Tip: The screenshot button on the top right of the application takes a screenshot of your whole board!\u003c/p>"}]},{"_key":"a06d46c5afa1","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"32473d0bf4c9","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Maximize (Pink): \u003c/strong>Clicking this button will maximize the module to be fullscreen. Clicking “Restore” while maximized will return it to its original size within the Board.\u003c/p>"}]},{"_key":"f9d7d0a43f7a","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"08b5d17bd26b","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Close (White): \u003c/strong>This button will remove the module from the board, and the space will be consumed by neighboring modules.\u003c/p>"}]},{"_key":"42659a5c3c01","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"25a16e7d9a63","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Hotkeys (Not pictured above):\u003c/strong> The Hotkeys button allows you to set up custom hotkeys and keymaps that your module will listen to. These Hotkeys/Keymaps are meant to provide fast and convenient executions of several actions, such as trading, adjusting views, undoing edits, and more.\u003c/p>"},{"_key":"d3a7c123327c","_type":"paragraphArticleImage","field_image":{"alt":"Hotkeys","asset":{"_ref":"image-0d4d9fb694a65d3f7ebe9f12395a366eb2b3d336-214x360-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"image.png","size":21814,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.5944444444444444,"height":360,"width":214},"lqip":"data:image/png;base64,"},"_id":"image-0d4d9fb694a65d3f7ebe9f12395a366eb2b3d336-214x360-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/0d4d9fb694a65d3f7ebe9f12395a366eb2b3d336-214x360.png"}},"field_width":"auto"}]}],"field_type":"ul"}],"field_id":"67d046f537d0","field_title":"How to edit and remove modules"},{"_key":"531df89f0d1e","_type":"paragraphAccordionItem","field_children":[{"_key":"4134d302084c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Kraken Desktop comes out of the box with several beautiful themes that are just a click away. You may also \u003ca href=\"/articles/create-import-or-edit-a-custom-theme-on-kraken-desktop\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">create your own theme\u003c/a> to make your Kraken Desktop experience pixel perfect.\u003c/p>\u003cp>To view the theme settings, click the \u003cstrong>Theme Management\u003c/strong> button located on the top-right corner of your screen.\u003c/p>"},{"_key":"b6d9caae4ee2","_type":"paragraphArticleImage","field_image":{"alt":"sample","asset":{"_ref":"image-ad229568e4ec5384069d4b195d7b5cc0459ecc35-1064x156-png","_type":"sanity.imageAsset","mimeType":"image/png","originalFilename":"ThemeManagementButton.png","size":13961,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":6.82051282051282,"height":156,"width":1064},"lqip":"data:image/png;base64,"},"_id":"image-ad229568e4ec5384069d4b195d7b5cc0459ecc35-1064x156-png","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/ad229568e4ec5384069d4b195d7b5cc0459ecc35-1064x156.png"}},"field_width":"auto"},{"_key":"876e32738ea0","_type":"paragraphArticleBodyLc","field_body":"\u003cp>This will open a sidebar where you are able to do the following:\u003c/p>"},{"_key":"e2e00bc4b898","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"17f2032905ef","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"33825b23e21f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Edit, save, and share your current theme:\u003c/p>\u003cp>\u003c/p>"},{"_key":"fe943a7d5922","_type":"paragraphArticleImage","field_image":{"alt":"Theme","asset":{"_ref":"image-ac2bf855c25490ec07fa3d796b8ba5662100aae2-672x422-webp","_type":"sanity.imageAsset","mimeType":"image/webp","originalFilename":"Thememanagment.webp","size":7644,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.5924170616113744,"height":422,"width":672},"lqip":"data:image/jpeg;base64,"},"_id":"image-ac2bf855c25490ec07fa3d796b8ba5662100aae2-672x422-webp","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/ac2bf855c25490ec07fa3d796b8ba5662100aae2-672x422.webp"}},"field_width":"80"},{"_key":"036540a66229","_type":"paragraphArticleBodyLc","field_body":"\u003cp>The pencil icon allows you to rename and adjust the colors of the current theme. After saving your changes, this theme will appear in a list under the Custom Themes section.\u003c/p>\u003cp>The trash can icon will delete your current theme.\u003c/p>\u003cp>The export button allows you to copy a public link to your theme to share it with others to try.\u003cbr/>\u003c/p>"}]},{"_key":"de2c7b76d0b5","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"feed92575444","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/create-import-or-edit-a-custom-theme-on-kraken-desktop\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Import and create custom themes.\u003c/a>\u003c/p>"}]},{"_key":"f4d5ecd2679a","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"f2eff990d7db","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Select one of many preset themes that are always available, and cannot be deleted.\u003c/p>"}]}],"field_type":"ul"}],"field_id":"b9c109040cde","field_title":"Theme management"}]}],"field_display_breadcrumbs":true,"field_last_updated_label":"Last updated:","field_title":"How to use Kraken Desktop","field_tldr_title":"Key takeaways"}],"field_page_meta":{"description":"Support Center for Kraken.com | Bitcoin & Cryptocurrency Exchange | Bitcoin Trading Platform","title":"How to use Kraken Desktop | Kraken"},"field_sitemap_definition":{"field_sitemap_dynamic_variables":[]},"field_tags":[{"_key":"1e56d7b9a5b8","_ref":"5b19b9e3-89a4-4b53-b580-8bd5c3986333","_type":"taxonomyTag","_id":"5b19b9e3-89a4-4b53-b580-8bd5c3986333","firstPublishedAt":"2026-01-20T10:38:52.485Z","lastPublishedAt":"2026-01-20T10:38:52.485Z","name":"sc-tier-2"}],"field_target_languages":["de_de","es_es","fr_fr","it_it","nl_nl","pl_pl","pt_br","ru_ru","tr_tr","uk_ua","vi_vn","zh_cn"],"is_article":true,"is_dynamic_template":false,"lastPublishedAt":"2026-04-28T00:39:52.435Z","locale":{"_ref":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","_type":"taxonomyLocales","_id":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","code":"en-us","field_label":"English","name":"en-US"},"path":"/articles/how-to-use-kraken-desktop","status":true,"title":"How to use Kraken Desktop"}}],"visibility":[{"_key":"c47e441a1fca","component":"searchFilter","value":true}]},{"_createdAt":"2025-03-06T16:06:26Z","_id":"product-ProWeb","_key":"370bb0d8a153","_rev":"R4bDO5qNaIcYVJNTEZsDyn","_type":"taxonomyProduct","_updatedAt":"2025-05-30T08:07:28Z","deprecated":false,"description":"","displayName":"Kraken Pro (pro.kraken.com)","editable":false,"name":"Product: Pro Web","topArticles":[],"visibility":[{"_key":"1f71c9884982","component":"searchFilter","value":true}]},{"_createdAt":"2025-03-06T16:06:26Z","_id":"product-ProApp","_key":"6d90f2e0d76a","_rev":"R4bDO5qNaIcYVJNTEZsDyn","_type":"taxonomyProduct","_updatedAt":"2025-05-30T08:07:28Z","deprecated":false,"description":"","displayName":"Kraken Pro App","editable":false,"name":"Product: Pro App","topArticles":[{"_key":"0973e8f65672","reference":{"_ref":"ed98bcdf-d363-49ce-9160-fd0ec20e6105","_type":"page","_id":"ed98bcdf-d363-49ce-9160-fd0ec20e6105","_system":{"base":{"id":"ed98bcdf-d363-49ce-9160-fd0ec20e6105","rev":"qrQtqtZQeYcK1ZYDkFhWq1"}},"appId":"support","content_source_locale":"en_us","enabled_locales":[],"field_page_components":[{"_key":"ea3fcdb6c710","_type":"paragraphArticleLayout","field_article_breadcrumb_label":"Support","field_article_breadcrumbs":true,"field_children":[{"_key":"28aa63e4800c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Need help? You’re in the right place! Most questions can be answered quickly by searching our Support Center, where you’ll find guides, tutorials, and tips for getting the most out of Kraken.\u003c/p>\u003cp>\u003c/p>"},{"_key":"c67b66f0897b","_type":"paragraphArticleHeadingBody","field_body":"\u003cp>Looking for help on our mobile apps? Just head to any article in the Support Center you’ll see the \u003cstrong>Chat with us\u003c/strong> option if you need more assistance.\u003c/p>\u003cp>Go to \u003cstrong>Account settings &gt; Support &gt; any article \u003c/strong>and tap\u003cstrong> Chat with us.\u003c/strong>\u003c/p>","field_heading":" Using the Kraken Mobile App ","field_heading_html_id":"7660e41def3c","field_level":2},{"_key":"4cec4f653a2c","_type":"paragraphArticleHeadingBody","field_body":"\u003cp>If you&#x27;re using Kraken on your desktop, you&#x27;ll find plenty of self-service options right on our \u003ca href=\"\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">homepage\u003c/a>. We&#x27;ve also organized support by product, so it&#x27;s easy to explore solutions tailored to what you&#x27;re using.\u003c/p>","field_heading":" On Desktop ","field_heading_html_id":"ba217e689fbb","field_level":2}],"field_last_updated_label":"Last updated:","field_title":"How to contact Kraken Support","field_tldr_title":"Key takeaways"}],"field_page_meta":{"description":"Support Center for Kraken.com | Bitcoin & Cryptocurrency Exchange | Bitcoin Trading Platform","title":"How to contact Kraken Support | Kraken"},"field_tags":[{"_key":"c9272281a9d4","_ref":"673540af-947a-4586-b886-b8aaafba4775","_type":"taxonomyTag","_id":"673540af-947a-4586-b886-b8aaafba4775","firstPublishedAt":"2025-02-13T13:49:17.581Z","lastPublishedAt":"2025-02-13T13:49:17.581Z","name":"api-elastic-disabled"},{"_key":"71cf5f902278","_ref":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","_type":"taxonomyTag","_id":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","firstPublishedAt":"2026-01-20T10:38:23.492Z","lastPublishedAt":"2026-01-20T10:38:23.492Z","name":"sc-tier-1"}],"field_target_languages":["de_de","es_es","fr_fr","it_it","nl_nl","pl_pl","pt_br","ru_ru","tr_tr","uk_ua","vi_vn","zh_cn"],"lastPublishedAt":"2025-08-08T18:18:19.670Z","locale":{"_ref":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","_type":"taxonomyLocales","_id":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","code":"en-us","field_label":"English","name":"en-US"},"path":"/articles/contacting-support","status":true,"title":"How to contact Kraken Support"}},{"_key":"80930f6403b0","reference":{"_ref":"32490215-448b-4a02-9a17-b421d5487d9b","_type":"page","_id":"32490215-448b-4a02-9a17-b421d5487d9b","_system":{"base":{"id":"32490215-448b-4a02-9a17-b421d5487d9b","rev":"hd17HufMe8v6npij634tJQ"}},"appId":"support","content_source_locale":"en_us","enabled_locales":[],"field_page_components":[{"_key":"49e7a5c60e77","_type":"paragraphArticleLayout","field_article_breadcrumb_label":"Support","field_article_breadcrumbs":true,"field_children":[{"_key":"3085b451c43e","_type":"paragraphArticleBodyLc","field_body":"\u003cblockquote>\u003cstrong>This article is for clients using the Kraken Pro app.\u003cbr/>\u003cbr/>\u003c/strong>If you are looking for information on how to get verified on the Kraken app, \u003ca href=\"/articles/360059110151-Creating-and-verifying-your-account-on-the-Kraken-app\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">you can find out here!\u003c/a>\u003c/blockquote>"},{"_key":"f7ad056500dc","_type":"paragraphArticleHeadingBody","field_body":"\u003cp>To create an account using the Kraken Pro app, you&#x27;ll first need to install the app via the \u003ca href=\"https://apps.apple.com/us/app/kraken-pro-crypto-trading/id1473024338\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">App Store\u003c/a> or \u003ca href=\"https://play.google.com/store/apps/details?id=com.kraken.trade&pcampaignid=web_share\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Google Play.\u003c/a> \u003c/p>\u003cp>Once installed, open the app and tap the \u003cstrong>Create account\u003c/strong> button.\u003c/p>\u003cp>Next, you&#x27;ll need to provide the details to your new account. Please provide:\u003c/p>","field_heading":" Creating your account ","field_level":3},{"_key":"83abd49c71f7","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"612ce47e9abc","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"eda776eb3cb9","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Your email address\u003c/p>"}]},{"_key":"f192c209a6c7","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"45dc5abe5adc","_type":"paragraphArticleBodyLc","field_body":"\u003cp>A \u003ca href=\"/articles/360029008212-Username-requirements-and-recommendations\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">username\u003c/a> and \u003ca href=\"/articles/201396497-Password-requirements-and-recommendations\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">password\u003c/a>\u003c/p>"}]},{"_key":"81af15664ba9","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"492eca100db1","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Your country of residence\u003c/p>"}]}],"field_type":"ul"},{"_key":"bd2a1fcf1fa7","_type":"paragraphArticleBodyLc","field_body":"\u003cp>At this point, an email will be sent to you with an activation code. Please enter the activation code in the app, or simply tap the link in the email message.\u003c/p>"},{"_key":"ccfc340dbb9f","_type":"paragraphArticleHeadingBody","field_body":"\u003cp>In order to buy and sell cryptocurrencies, you&#x27;ll need to verify your account with Kraken. To verify your account, tap &quot;\u003cstrong>Start personal verification\u003c/strong>&quot; and provide the following information:\u003c/p>","field_heading":" Verifying your account ","field_level":3},{"_key":"a9b9fa317b7a","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"c7901c5245e6","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"04ee2474bb48","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Mobile phone number\u003c/p>"}]},{"_key":"6a1cf26bbb8e","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"3e21c4ecd5b2","_type":"paragraphArticleBodyLc","field_body":"\u003cp>First and last name, as written on your\u003ca href=\"/articles/360000672203-Document-requirements-for-verification\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\"> ID document\u003c/a>\u003c/p>"}]},{"_key":"027ed5adbd70","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"65142b90d851","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Date of birth (must be at least 18 years of age)\u003c/p>"}]},{"_key":"138e082e9d26","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"196902a455e3","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Address\u003c/p>"}]},{"_key":"5069f191b2b6","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"ac4fd3bf331c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Social security number (US only)\u003c/p>"}]},{"_key":"b34cb707ee3f","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"f8067472b147","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Occupation\u003c/p>"}]}],"field_type":"ul"},{"_key":"c41c9a9f6e9f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>You will then need to photograph and submit some supporting documents.\u003c/p>"},{"_key":"6618daa159ea","_type":"paragraphAccordion","field_children":[{"_key":"701a333ce854","_type":"paragraphAccordionItem","field_children":[{"_key":"4417789dc1d4","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"7c54d20652c9","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"b2a337898f70","_type":"paragraphArticleBodyLc","field_body":"\u003cp>National ID (front and back)\u003c/p>"}]},{"_key":"e2b6bf07a09d","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"2b2b819cfed8","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Passport (information page)\u003c/p>"}]},{"_key":"67800ab541f8","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"11a26d731e38","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Driver&#x27;s license (front and back)\u003c/p>"}]}],"field_type":"ul"}],"field_id":"90d423a29fa3","field_title":"Identity document"},{"_key":"efde84c58223","_type":"paragraphAccordionItem","field_children":[{"_key":"2c75d21fd21f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"},{"_key":"29e91ac3a551","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"c9df0455adf1","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"4419ecf2501e","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Utility bill\u003c/p>"}]},{"_key":"14d6204b7294","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"6b66fc42219c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Bank statement\u003c/p>"}]},{"_key":"212a0b429b9e","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"c60377ed0470","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Credit card statement\u003c/p>"}]},{"_key":"68bf565b27b8","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"e6a6fef04635","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Proof of residency certificate\u003c/p>"}]}],"field_type":"ul"}],"field_id":"e450371ffc27","field_title":"Proof of address document"}]},{"_key":"011c3e407033","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Residents of the US and South Africa will also be asked to provide a face photo.\u003c/p>\u003cp>\u003c/p>\u003cp>Each step will explain the \u003ca href=\"/articles/360000672203-Document-requirements-for-verification\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">document requirements\u003c/a>, and we also have tips on how to \u003ca href=\"/articles/360000700603-Image-requirements-for-ID-documents\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">provide a high quality photo\u003c/a>.\u003c/p>\u003cp>\u003c/p>\u003cp>Once your documents have been submitted, they will be processed and you will receive an email when your account is verified. If you have any questions about the verification process, or you encounter any issues, please \u003ca href=\"/requests/new?ticket_form_id=5516133851284\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">contact support\u003c/a>.\u003c/p>"}],"field_last_updated_label":"Last updated:","field_title":"Creating and verifying your account on the Kraken Pro app","field_tldr_title":"Key takeaways"}],"field_page_meta":{"description":"Support Center for Kraken.com | Bitcoin & Cryptocurrency Exchange | Bitcoin Trading Platform","title":"Creating and verifying your account on the Kraken Pro app | Kraken"},"field_tags":[{"_key":"bd0fb85a96f8","_ref":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","_type":"taxonomyTag","_id":"8acf30f1-ab2c-48b7-a789-0f46d836c3cd","firstPublishedAt":"2026-01-20T10:38:23.492Z","lastPublishedAt":"2026-01-20T10:38:23.492Z","name":"sc-tier-1"}],"field_target_languages":["de_de","es_es","fr_fr","it_it","nl_nl","pl_pl","pt_br","ru_ru","tr_tr","uk_ua","vi_vn","zh_cn"],"lastPublishedAt":"2025-08-08T22:50:59.411Z","locale":{"_ref":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","_type":"taxonomyLocales","_id":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","code":"en-us","field_label":"English","name":"en-US"},"path":"/articles/creating-and-verifying-your-account-on-the-kraken-pro-app","status":true,"title":"Creating and verifying your account on the Kraken Pro app"}},{"_key":"4691a20c4d72","reference":{"_ref":"article-360049788312","_type":"page","_id":"article-360049788312","_system":{"base":{"id":"article-360049788312","rev":"hd17HufMe8v6npij64N624"}},"appId":"support","content_source_locale":"en_us","enabled_locales":[],"field_page_components":[{"_key":"91f4ab7c6bc6","_type":"paragraphArticleLayout","field_article_breadcrumb_label":"Support","field_article_breadcrumbs":true,"field_children":[{"_key":"0050d6e97ce4","_type":"paragraphArticleBodyLc","field_body":"\u003cp>With the Kraken Pro app, you can:\u003c/p>"},{"_key":"2f37f1ff6265","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"cdb249a7289f","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"964e92a37931","_type":"paragraphArticleBodyLc","field_body":"\u003cp>View your trading and staking portfolio balances.\u003c/p>"}]},{"_key":"a61072c38cbf","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"344ec33ca32e","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Trade with market, limit, stop loss and take profit order types.\u003c/p>"}]},{"_key":"954e413819da","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"33bbbb69d3f6","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Margin trade, \u003ca href=\"/articles/4402532394260\" >if eligible\u003c/a>.\u003c/p>"}]},{"_key":"c93bedf9d7aa","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"8a5ae235a3bc","_type":"paragraphArticleBodyLc","field_body":"\u003cp>View candlestick price charts.\u003c/p>"}]}],"field_type":"ul"},{"_key":"408632d3f177","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"https://play.google.com/store/apps/details?id=com.kraken.trade\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Download \u003cstrong>Kraken Pro\u003c/strong> for Android 8.0 and up\u003c/a> (Google Play)\u003c/p>\u003cp>\u003ca href=\"https://apps.apple.com/app/kraken-pro/id1473024338\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Download Kraken Pro for iOS 15 and up\u003c/a> (Apple App Store)\u003c/p>"},{"_key":"6556445bb6ac","_type":"paragraphArticleHeadingBody","field_body":"","field_heading":" App Setup ","field_level":3},{"_key":"3c6983ec4022","_type":"paragraphAccordion","field_children":[{"_key":"6a74beb01c46","_type":"paragraphAccordionItem","field_children":[{"_key":"ce938e5756a6","_type":"paragraphArticleBodyLc","field_body":"\u003cp>To connect your Kraken account to the Kraken Pro app you can sign in using your current \u003ca href=\"https://kraken.com/\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">username and password. \u003c/a>Once connected to the app, you will have the following benefits:\u003c/p>"},{"_key":"ca095eaeca4f","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"0f2766337429","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"e7b6bb03c1ce","_type":"paragraphArticleBodyLc","field_body":"\u003cp>You will stay signed in permanently on the app unless you choose to disconnect by tapping \u003cstrong>Sign Out\u003c/strong>.\u003c/p>"}]},{"_key":"5b5dfe061753","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"a656ff8dcc63","_type":"paragraphArticleBodyLc","field_body":"\u003cp>If you lose your device, you can sign in to \u003ca href=\"http://www.kraken.com\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">Kraken.com\u003c/a> and revoke your signed in session.\u003c/p>"}]}],"field_type":"ul"}],"field_id":"Im3M_Gm8vnH7ddj57x-la","field_title":"How do I connect my account to the app?"},{"_key":"864f44979f15","_type":"paragraphAccordionItem","field_children":[{"_key":"bdad5f868706","_type":"paragraphArticleBodyLc","field_body":"\u003cp>When you open the app, it will request your security code at the system level. This would be your device&#x27;s lock screen biometrics or lock screen PIN.\u003c/p>"}],"field_id":"u63LtllfPjd48FE2favxx","field_title":"Why is the app asking for fingerprint or PIN when I haven't set one up yet?"}]},{"_key":"b86a1f32da17","_type":"paragraphArticleHeadingBody","field_body":"","field_heading":" Security ","field_level":3},{"_key":"49e4f0725226","_type":"paragraphAccordion","field_children":[{"_key":"001b859ef0f6","_type":"paragraphAccordionItem","field_children":[{"_key":"e6bbbec067c0","_type":"paragraphArticleBodyLc","field_body":"\u003cp>When signing in with your \u003ca href=\"https://www.kraken.com/sign-in\" >username and password \u003c/a>all \u003ca href=\"/articles/360000426923\" >Two-factor Authentication (2FA)\u003c/a> settings will be enabled. \u003c/p>\u003cp>A \u003ca href=\"/articles/360000426923\" >sign in 2FA\u003c/a> is required when signing in and \u003ca href=\"/articles/360000911503\" >Trading 2FA\u003c/a> will be prompted when applicable. \u003ca href=\"/articles/360000911503\" >Trading 2FA \u003c/a>is a separate 2FA method specifically for placing orders, so it is still possible to place a new order or modify an existing order via the app even though you have Trading 2FA enabled on your account.\u003c/p>\u003cp>\u003ca href=\"/articles/360000714526\" >2FA for API keys\u003c/a> is not yet compatible with the app. If you have this set up on your API keys it will not be possible to access the app.\u003c/p>"}],"field_id":"VZSXSCtcx_O1JBo64F12e","field_title":"What 2FA methods are compatible with the app?"}]},{"_key":"909b5482d26e","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003c/p>"}],"field_last_updated_label":"Last updated:","field_title":"Introduction to the Kraken Pro App","field_tldr_title":"Key takeaways"}],"field_page_meta":{"description":"Support Center for Kraken.com | Bitcoin & Cryptocurrency Exchange | Bitcoin Trading Platform","title":"Introduction to the Kraken Pro App | Kraken"},"field_tags":[{"_key":"57577e3a03af","_ref":"5b19b9e3-89a4-4b53-b580-8bd5c3986333","_type":"taxonomyTag","_id":"5b19b9e3-89a4-4b53-b580-8bd5c3986333","firstPublishedAt":"2026-01-20T10:38:52.485Z","lastPublishedAt":"2026-01-20T10:38:52.485Z","name":"sc-tier-2"}],"field_target_languages":["de_de","es_es","fr_fr","it_it","nl_nl","pl_pl","pt_br","ru_ru","tr_tr","uk_ua","vi_vn","zh_cn"],"lastPublishedAt":"2025-08-08T22:54:35.757Z","locale":{"_ref":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","_type":"taxonomyLocales","_id":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","code":"en-us","field_label":"English","name":"en-US"},"path":"/articles/360049788312-kraken-pro-mobile-app-frequently-asked-questions-","status":true,"title":"Introduction to the Kraken Pro App"}},{"_key":"8e0cd6cb5446","reference":{"_ref":"article-360056804571","_type":"page","_id":"article-360056804571","_system":{"base":{"id":"article-360056804571","rev":"SiJoPpsxLhzmIkVzmL7h4h"}},"appId":"support","content_source_locale":"en_us","enabled_locales":[],"field_page_components":[{"_key":"e59efb6e25ba","_type":"paragraphArticleLayout","field_article_breadcrumb_label":"Support","field_article_breadcrumbs":true,"field_children":[{"_key":"a664c32ace2e","_type":"paragraphArticleBodyLc","field_body":"\u003cp>The \u003ca href=\"/articles/360049788312-Kraken-Pro-mobile-app-FAQ?source=search\">Kraken Pro mobile app \u003c/a>was built with the active trader in mind. This application can be easily accessed using your existing Kraken.com credentials to buy and sell crypto.\u003c/p>\n\n\u003cp>\u003ca href=\"https://support.kraken.com/articles/deposit-withdraw-on-the-kraken-pro-app\" target=\"_blank\">Deposits and withdrawals\u003c/a> are available on the Kraken Pro app.\u003c/p>\n"},{"_key":"5682ca0eb3f1","_type":"paragraphAccordion","field_children":[{"_key":"5fefab78448d","_type":"paragraphAccordionItem","field_children":[{"_key":"fd7ebb1f8561","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"cf58803b77e3","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"497a2ae8fefa","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Once you&rsquo;ve opened the app, you can tap the \u003cstrong>purple Action Icon\u003c/strong>&nbsp;in the bottom-right corner to see the last 6 markets you&#39;ve viewed, or to search for a new market.\u003c/p>\n"},{"_key":"288caf4a618e","_type":"paragraphArticleImage","field_image":{"alt":"ProApp_NewOrderButton_02082021.png","asset":{"_ref":"image-e7bba72f612305fdc01d16f4b8725fe90e2905b7-600x563-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (54).jpg","size":27457,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.0657193605683837,"height":563,"width":600},"lqip":"data:image/jpeg;base64,"},"_id":"image-e7bba72f612305fdc01d16f4b8725fe90e2905b7-600x563-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/e7bba72f612305fdc01d16f4b8725fe90e2905b7-600x563.jpg"}},"field_width":"80"}]},{"_key":"76adf7cd1c23","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"9d6aa5657e41","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Select one of the listed markets, or, tap \u003cstrong>Search\u003c/strong> to search for one.&nbsp;\u003c/p>\n"},{"_key":"01172af61ba8","_type":"paragraphArticleImage","field_align":"left","field_image":{"_type":"image","asset":{"_ref":"image-162dbe97c4e873103df04ad972313e86d9f635af-1206x1483-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (55).jpg","size":131604,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.813216453135536,"height":1483,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-162dbe97c4e873103df04ad972313e86d9f635af-1206x1483-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/162dbe97c4e873103df04ad972313e86d9f635af-1206x1483.jpg"}},"field_width":"80"}]},{"_key":"4690f1de7cbd","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"812bbebb1a2a","_type":"paragraphArticleBodyLc","field_body":"\u003cp>After you&#39;ve selected the market that you&#39;d like to trade, you&#39;ll be taken to the&nbsp;\u003cstrong>Trade\u003c/strong>&nbsp;page for the market. If you want to change the market afterwards, you can always tap the market in the top-left corner to bring the search menu again.\u003c/p>\n\n\u003cp>To start your order, tap the&nbsp;\u003cstrong>Buy\u003c/strong>&nbsp;or&nbsp;\u003cstrong>Sell\u003c/strong>&nbsp;button on the bottom of the page.\u003c/p>\n"},{"_key":"a2f2f280306b","_type":"paragraphArticleImage","field_image":{"alt":"KrakenProApp_CurrencyPair.jpg","asset":{"_ref":"image-40a5b32402dbc2d6e43545dd2150ac68f20527cd-1206x2334-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (56).jpg","size":292087,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.5167095115681234,"height":2334,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-40a5b32402dbc2d6e43545dd2150ac68f20527cd-1206x2334-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/40a5b32402dbc2d6e43545dd2150ac68f20527cd-1206x2334.jpg"}},"field_width":"80"}]},{"_key":"ac25274fb995","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"ccde4c7e387f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>After tapping Buy or Sell, the \u003cstrong>Order Form\u003c/strong> will open. This is where you fill out the order details. You can slide the Order Form up to view more information comfortably.&nbsp;\u003c/p>\n\n\u003cp>\u003cstrong>It is recommended to familiarize yourself with the Order Form using our guide \u003ca href=\"https://support.kraken.com/articles/360056804571-how-to-place-orders-with-the-kraken-pro-app#order-form-guide\">here\u003c/a>.&nbsp;\u003c/strong>\u003c/p>\n"},{"_key":"367fab5d8097","_type":"paragraphArticleImage","field_image":{"alt":"KrakenProApp_Limitorder.jpg","asset":{"_ref":"image-b409fccd56df1f25d0fc019d372501b41301a10c-1206x1451-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (57).jpg","size":152469,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.8311509303928325,"height":1451,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-b409fccd56df1f25d0fc019d372501b41301a10c-1206x1451-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/b409fccd56df1f25d0fc019d372501b41301a10c-1206x1451.jpg"}},"field_width":"80"}]},{"_key":"4c55d3f8d6ff","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"5c2568ba35c7","_type":"paragraphArticleBodyLc","field_body":"\u003cp>To start your order, first choose the order type you&#39;d like to use. \u003cstrong>For this example, we&#39;ll be doing a Buy Limit Order.\u003c/strong>&nbsp;A Limit Order allows you to choose the price that your order will execute at, assuming the market reaches your Limit Price.\u003c/p>\n"},{"_key":"ea0c61265dc5","_type":"paragraphArticleImage","field_image":{"alt":"KrakenProApp_Buy_Sell.gif","asset":{"_ref":"image-23c9984567f40d3a9bd760509e2b77c89c242369-1206x1493-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (58).jpg","size":176481,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.8077695914266577,"height":1493,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-23c9984567f40d3a9bd760509e2b77c89c242369-1206x1493-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/23c9984567f40d3a9bd760509e2b77c89c242369-1206x1493.jpg"}},"field_width":"80"}]},{"_key":"7926aa77c949","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"e14a6dcb0064","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Next, fill in the \u003cstrong>Limit Price\u003c/strong>. This is where you choose the price that your order will execute at, assuming the market reaches your price. If you \u003ca href=\"https://support.kraken.com/articles/how-to-set-prices-for-limit-orders-on-kraken-pro\" target=\"_blank\">input a price\u003c/a> that is above the market price (for a buy order), it will execute immediately as a Market Order, thus incurring \u003ca href=\"https://support.kraken.com/articles/360000526126-what-are-maker-and-taker-fees-\" target=\"_blank\">Taker Fees\u003c/a>.\u003c/p>\n"},{"_key":"dc4a6a6ff006","_type":"paragraphArticleImage","field_image":{"alt":"KrakenProApp_Amount.jpg","asset":{"_ref":"image-710209bfdea696d92befc8e15af9e442801cd3af-1122x354-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (62).jpg","size":58198,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":3.169491525423729,"height":354,"width":1122},"lqip":"data:image/jpeg;base64,"},"_id":"image-710209bfdea696d92befc8e15af9e442801cd3af-1122x354-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/710209bfdea696d92befc8e15af9e442801cd3af-1122x354.jpg"}},"field_width":"80"}]},{"_key":"19d90f0d32d7","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"60a13e357848","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Then, you&#39;ll want to enter your&nbsp;\u003cstrong>Amount\u003c/strong>&nbsp;or&nbsp;\u003cstrong>Total.&nbsp;\u003c/strong>Both boxes will automatically adjust based on what you enter in one of them.\u003c/p>\n\n\u003cp>For example, if you want to spend $10 (in a USD market), you can enter &quot;10&quot; in the&nbsp;\u003cstrong>Total\u003c/strong>&nbsp;box. Or, if you want to buy a specific amount of the base currency (XMR in this example), you&#39;d enter that in the \u003cstrong>Amount\u003c/strong>&nbsp;box. Both boxes will always align.&nbsp;\u003c/p>\n"},{"_key":"b677cb866959","_type":"paragraphArticleImage","field_image":{"alt":"KrakenProApp_LimitPrice.jpg","asset":{"_ref":"image-79120663cf5f0f45feed05aa4ecddc0edf1981a2-1129x357-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (68).jpg","size":56210,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":3.1624649859943976,"height":357,"width":1129},"lqip":"data:image/jpeg;base64,"},"_id":"image-79120663cf5f0f45feed05aa4ecddc0edf1981a2-1129x357-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/79120663cf5f0f45feed05aa4ecddc0edf1981a2-1129x357.jpg"}},"field_width":"80"}]},{"_key":"9dd1553e899b","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"211d00a82148","_type":"paragraphArticleBodyLc","field_body":"\u003cp>At this point, your order is ready for submission. You can stop here and tap the green&nbsp;\u003cstrong>Buy\u003c/strong>&nbsp;button at the bottom of the Order Form to submit your order to the market.&nbsp;\u003c/p>\n\n\u003cp>Alternatively, you can slide the Order Form upwards and see the options to attach \u003ca href=\"https://support.kraken.com/articles/bracket-orders-on-kraken-pro\" target=\"_blank\">Bracket Orders\u003c/a>, or adjust other settings such as the Post only option and time in force.&nbsp;\u003c/p>\n"},{"_key":"b2b4bc9627a8","_type":"paragraphArticleImage","field_image":{"alt":"KrakenProApp_Total.jpg","asset":{"_ref":"image-02860699383d117847eb4b9f0b7086623adf1b83-1206x1021-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (69).jpg","size":108928,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.1811949069539667,"height":1021,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-02860699383d117847eb4b9f0b7086623adf1b83-1206x1021-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/02860699383d117847eb4b9f0b7086623adf1b83-1206x1021.jpg"}},"field_width":"80"}]},{"_key":"e7cc7ca72462","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"c701121452f2","_type":"paragraphArticleBodyLc","field_body":"\u003cp>After you tap the&nbsp;\u003cstrong>Green Buy button,&nbsp;\u003c/strong>an order confirmation will appear providing you with a summary of your order. If everything looks satisfactory, \u003cstrong>slide the arrow to confirm\u003c/strong> and submit the order.\u003c/p>\n"},{"_key":"feaa661b1b8f","_type":"paragraphArticleImage","field_image":{"alt":"ProApp_AvailableBalanceEUR_02082021.png","asset":{"_ref":"image-0828c92951fbe70ef7edf4fb82ae7199d8354ddb-1206x1044-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (70).jpg","size":99397,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.1551724137931034,"height":1044,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-0828c92951fbe70ef7edf4fb82ae7199d8354ddb-1206x1044-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/0828c92951fbe70ef7edf4fb82ae7199d8354ddb-1206x1044.jpg"}},"field_width":"80"}]}],"field_type":"ol"}],"field_id":"spot","field_is_expanded":false,"field_title":"Spot orders"},{"_key":"6e810b92e1a4","_type":"paragraphAccordionItem","field_children":[{"_key":"4e6b9e8fb797","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"2dad9938d836","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"4ffba7544123","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Once you&rsquo;ve opened the app, you can tap the \u003cstrong>purple Action Icon\u003c/strong>&nbsp;in the bottom-right corner to see the last 6 markets you&#39;ve viewed, or to search for a new market.\u003c/p>\n"},{"_key":"240cd1f9edc0","_type":"paragraphArticleImage","field_image":{"alt":"ProApp_NewOrderButton_02082021.png","asset":{"_ref":"image-e7bba72f612305fdc01d16f4b8725fe90e2905b7-600x563-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (54).jpg","size":27457,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.0657193605683837,"height":563,"width":600},"lqip":"data:image/jpeg;base64,"},"_id":"image-e7bba72f612305fdc01d16f4b8725fe90e2905b7-600x563-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/e7bba72f612305fdc01d16f4b8725fe90e2905b7-600x563.jpg"}},"field_width":"80"}]},{"_key":"7f85bf560afb","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"195c283dca85","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Select one of the listed markets, or, tap \u003cstrong>Search\u003c/strong> to search for one. If you decide to search for a market, you can \u003cstrong>filter for markets with margin available.\u003c/strong>\u003c/p>\n"},{"_key":"624d5d5f1877","_type":"paragraphArticleImage","field_align":"left","field_image":{"_type":"image","asset":{"_ref":"image-162dbe97c4e873103df04ad972313e86d9f635af-1206x1483-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (55).jpg","size":131604,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.813216453135536,"height":1483,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-162dbe97c4e873103df04ad972313e86d9f635af-1206x1483-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/162dbe97c4e873103df04ad972313e86d9f635af-1206x1483.jpg"}},"field_width":"80"},{"_key":"17a556241e49","_type":"paragraphArticleImage","field_align":"left","field_image":{"_type":"image","asset":{"_ref":"image-8188039380f158d9c60655b172270c893d942298-1206x1188-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (71).jpg","size":145753,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.0151515151515151,"height":1188,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-8188039380f158d9c60655b172270c893d942298-1206x1188-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/8188039380f158d9c60655b172270c893d942298-1206x1188.jpg"}},"field_width":"80"}]},{"_key":"dd405002ac4f","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"214dba850475","_type":"paragraphArticleBodyLc","field_body":"\u003cp>After you&#39;ve selected the market that you&#39;d like to trade, you&#39;ll be taken to the&nbsp;\u003cstrong>Trade\u003c/strong>&nbsp;page for the market. If you want to change the market afterwards, you can always tap the market in the top-left corner to bring the search menu again.\u003c/p>\n\n\u003cp>To start your order, tap the&nbsp;\u003cstrong>Buy\u003c/strong>&nbsp;or&nbsp;\u003cstrong>Sell\u003c/strong>&nbsp;button on the bottom of the page.\u003c/p>\n"},{"_key":"7f73307de63a","_type":"paragraphArticleImage","field_image":{"alt":"KrakenProApp_CurrencyPair.jpg","asset":{"_ref":"image-40a5b32402dbc2d6e43545dd2150ac68f20527cd-1206x2334-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (56).jpg","size":292087,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.5167095115681234,"height":2334,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-40a5b32402dbc2d6e43545dd2150ac68f20527cd-1206x2334-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/40a5b32402dbc2d6e43545dd2150ac68f20527cd-1206x2334.jpg"}},"field_width":"80"}]},{"_key":"d9d947b8a2f1","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"fdb8ce15dd19","_type":"paragraphArticleBodyLc","field_body":"\u003cp>After tapping Buy or Sell, the \u003cstrong>Order Form\u003c/strong> will open. This is where you fill out the order details. You can slide the Order Form up to view more information comfortably.&nbsp;\u003c/p>\n\n\u003cp>\u003cstrong>It is recommended to familiarize yourself with the Order Form using our guide \u003ca href=\"https://support.kraken.com/articles/360056804571-how-to-place-orders-with-the-kraken-pro-app#order-form-guide\">here\u003c/a>.&nbsp;\u003c/strong>\u003c/p>\n"},{"_key":"11a8171b9983","_type":"paragraphArticleImage","field_image":{"alt":"KrakenProApp_Limitorder.jpg","asset":{"_ref":"image-b409fccd56df1f25d0fc019d372501b41301a10c-1206x1451-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (57).jpg","size":152469,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.8311509303928325,"height":1451,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-b409fccd56df1f25d0fc019d372501b41301a10c-1206x1451-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/b409fccd56df1f25d0fc019d372501b41301a10c-1206x1451.jpg"}},"field_width":"80"}]},{"_key":"b16574a4d1ef","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"f0df98fb0e4f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Before you start filling out the Order Form, you&#39;ll want to \u003cstrong>enable margin using the margin toggle.\u003c/strong>&nbsp;The amount of leverage applied to your order will be displayed here, in this case for XMR/USD, it is \u003cstrong>3x\u003c/strong>.\u003c/p>\n"},{"_key":"cac769f8dbd5","_type":"paragraphArticleImage","field_align":"left","field_image":{"_type":"image","asset":{"_ref":"image-7ee004d626c0a2275a9097ac26aa7c4b8718e573-1206x780-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (72).jpg","size":81691,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.5461538461538462,"height":780,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-7ee004d626c0a2275a9097ac26aa7c4b8718e573-1206x780-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/7ee004d626c0a2275a9097ac26aa7c4b8718e573-1206x780.jpg"}},"field_width":"80"}]},{"_key":"66e909bd7557","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"8f0b4bb2e7f1","_type":"paragraphArticleBodyLc","field_body":"\u003cp>To start your order, first choose the order type you&#39;d like to use. \u003cstrong>For this example, we&#39;ll be doing a Buy Limit Order.\u003c/strong>&nbsp;A Limit Order allows you to choose the price that your order will execute at, assuming the market reaches your Limit Price.\u003c/p>\n"},{"_key":"1ede0eb2d15c","_type":"paragraphArticleImage","field_image":{"alt":"KrakenProApp_Buy_Sell.gif","asset":{"_ref":"image-23c9984567f40d3a9bd760509e2b77c89c242369-1206x1493-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (58).jpg","size":176481,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.8077695914266577,"height":1493,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-23c9984567f40d3a9bd760509e2b77c89c242369-1206x1493-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/23c9984567f40d3a9bd760509e2b77c89c242369-1206x1493.jpg"}},"field_width":"80"}]},{"_key":"7dbe11f665c2","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"fae092936caf","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Next, fill in the \u003cstrong>Limit Price\u003c/strong>. This is where you choose the price that your order will execute at, assuming the market reaches your price. If you \u003ca href=\"https://support.kraken.com/articles/how-to-set-prices-for-limit-orders-on-kraken-pro\" target=\"_blank\">input a price\u003c/a> that is above the market price (for a buy order), it will execute immediately as a Market Order, thus incurring \u003ca href=\"https://support.kraken.com/articles/360000526126-what-are-maker-and-taker-fees-\" target=\"_blank\">Taker Fees\u003c/a>.\u003c/p>\n"},{"_key":"f554a4cd129b","_type":"paragraphArticleImage","field_image":{"alt":"KrakenProApp_Amount.jpg","asset":{"_ref":"image-710209bfdea696d92befc8e15af9e442801cd3af-1122x354-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (62).jpg","size":58198,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":3.169491525423729,"height":354,"width":1122},"lqip":"data:image/jpeg;base64,"},"_id":"image-710209bfdea696d92befc8e15af9e442801cd3af-1122x354-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/710209bfdea696d92befc8e15af9e442801cd3af-1122x354.jpg"}},"field_width":"80"}]},{"_key":"df6221fa01d9","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"0a016f118269","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Then, you&#39;ll want to enter your&nbsp;\u003cstrong>Amount\u003c/strong>&nbsp;or&nbsp;\u003cstrong>Total.&nbsp;\u003c/strong>Both boxes will automatically adjust based on what you enter in one of them.\u003c/p>\n\n\u003cp>For example, if you want to spend $10 (in a USD market), you can enter &quot;10&quot; in the&nbsp;\u003cstrong>Total\u003c/strong>&nbsp;box. Or, if you want to buy a specific amount of the base currency (XMR in this example), you&#39;d enter that in the \u003cstrong>Amount\u003c/strong>&nbsp;box. Both boxes will always align.&nbsp;\u003c/p>\n"},{"_key":"2bdc0b4de1bb","_type":"paragraphArticleImage","field_image":{"alt":"KrakenProApp_LimitPrice.jpg","asset":{"_ref":"image-79120663cf5f0f45feed05aa4ecddc0edf1981a2-1129x357-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (68).jpg","size":56210,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":3.1624649859943976,"height":357,"width":1129},"lqip":"data:image/jpeg;base64,"},"_id":"image-79120663cf5f0f45feed05aa4ecddc0edf1981a2-1129x357-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/79120663cf5f0f45feed05aa4ecddc0edf1981a2-1129x357.jpg"}},"field_width":"80"}]},{"_key":"7d8b01ac1e8b","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"d1411ca09f34","_type":"paragraphArticleBodyLc","field_body":"\u003cp>At this point, your order is ready for submission. You can stop here and tap the green&nbsp;\u003cstrong>Buy\u003c/strong>&nbsp;button at the bottom of the Order Form to submit your order to the market.&nbsp;\u003c/p>\n\n\u003cp>Alternatively, you can slide the Order Form upwards and see the options to attach \u003ca href=\"https://support.kraken.com/articles/bracket-orders-on-kraken-pro\" target=\"_blank\">Bracket Orders\u003c/a>, or adjust other settings such as the Post only option and time in force.&nbsp;\u003c/p>\n"},{"_key":"9b7b4b204dff","_type":"paragraphArticleImage","field_image":{"alt":"KrakenProApp_Total.jpg","asset":{"_ref":"image-7d268e7438aa0122d2101797418ce10e189d04c0-1206x1016-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (73).jpg","size":114603,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.187007874015748,"height":1016,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-7d268e7438aa0122d2101797418ce10e189d04c0-1206x1016-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/7d268e7438aa0122d2101797418ce10e189d04c0-1206x1016.jpg"}},"field_width":"80"}]},{"_key":"7da8a48a41af","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"9930d0bac223","_type":"paragraphArticleBodyLc","field_body":"\u003cp>After you tap the&nbsp;\u003cstrong>Green Buy button,&nbsp;\u003c/strong>an order confirmation will appear providing you with a summary of your order. If everything looks satisfactory, \u003cstrong>slide the arrow to confirm\u003c/strong> and submit the order.\u003c/p>\n"},{"_key":"d2539f908d40","_type":"paragraphArticleImage","field_image":{"alt":"ProApp_AvailableBalanceEUR_02082021.png","asset":{"_ref":"image-82d9f9d652b0d0d0e3c2a892a911dfc892ef2f73-1206x1182-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (74).jpg","size":116319,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.0203045685279188,"height":1182,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-82d9f9d652b0d0d0e3c2a892a911dfc892ef2f73-1206x1182-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/82d9f9d652b0d0d0e3c2a892a911dfc892ef2f73-1206x1182.jpg"}},"field_width":"80"}]}],"field_type":"ol"}],"field_id":"margin","field_is_expanded":false,"field_title":"Margin orders"},{"_key":"fe31230c269c","_type":"paragraphAccordionItem","field_children":[{"_key":"8706817814e5","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"0676aa536a7d","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"b254a061d175","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Buy/Sell toggle:&nbsp;\u003c/strong>Quickly switch between a buy order or a sell order.\u003c/p>\n"},{"_key":"361ddad39107","_type":"paragraphArticleImage","field_align":"left","field_image":{"_type":"image","asset":{"_ref":"image-50f964057e1bf8a4ec0ab994e3f2d0fe083e3116-556x155-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (59).jpg","size":8149,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":3.587096774193548,"height":155,"width":556},"lqip":"data:image/jpeg;base64,"},"_id":"image-50f964057e1bf8a4ec0ab994e3f2d0fe083e3116-556x155-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/50f964057e1bf8a4ec0ab994e3f2d0fe083e3116-556x155.jpg"}},"field_width":"48"}]},{"_key":"fd5ef092fd91","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"3224f5f7650f","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Order type:&nbsp;\u003c/strong>Choose between different order types for your order. More information on the order types available on Kraken can be found&nbsp;\u003ca href=\"https://support.kraken.com/sections/200577136-order-types\">here\u003c/a>.\u003c/p>\n"},{"_key":"153c9bfcf408","_type":"paragraphArticleImage","field_align":"left","field_image":{"_type":"image","asset":{"_ref":"image-86e9fd8137810370f0c39917b50913606ad0edc2-559x156-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (60).jpg","size":7273,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":3.5833333333333335,"height":156,"width":559},"lqip":"data:image/jpeg;base64,"},"_id":"image-86e9fd8137810370f0c39917b50913606ad0edc2-559x156-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/86e9fd8137810370f0c39917b50913606ad0edc2-559x156.jpg"}},"field_width":"48"}]},{"_key":"9ac6794b397a","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"747cb9276463","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Available balance/margin toggle:&nbsp;\u003c/strong>Here is where your available balance in the quote currency is displayed, as well as the ability to turn on margin. (If applicable)\u003c/p>\n"},{"_key":"69953877adeb","_type":"paragraphArticleImage","field_align":"left","field_image":{"_type":"image","asset":{"_ref":"image-ce84c42a5319e0eaffca58ed7a4d1b61cbc7ea85-1120x263-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (61).jpg","size":44546,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":4.258555133079848,"height":263,"width":1120},"lqip":"data:image/jpeg;base64,"},"_id":"image-ce84c42a5319e0eaffca58ed7a4d1b61cbc7ea85-1120x263-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/ce84c42a5319e0eaffca58ed7a4d1b61cbc7ea85-1120x263.jpg"}},"field_width":"80"}]},{"_key":"b79578357807","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"cf55a8e653d3","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Limit Price (Limit-type Orders only):&nbsp;\u003c/strong>Here is where you enter the&nbsp;\u003ca href=\"https://support.kraken.com/articles/how-to-set-prices-for-limit-orders-on-kraken-pro\">Limit Price\u003c/a>&nbsp;if you&#39;re using a Limit Order. The Limit Price is the price you wish to buy or sell an asset at.\u003c/p>\n"},{"_key":"a0fe14e196ef","_type":"paragraphArticleImage","field_align":"left","field_image":{"_type":"image","asset":{"_ref":"image-710209bfdea696d92befc8e15af9e442801cd3af-1122x354-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (62).jpg","size":58198,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":3.169491525423729,"height":354,"width":1122},"lqip":"data:image/jpeg;base64,"},"_id":"image-710209bfdea696d92befc8e15af9e442801cd3af-1122x354-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/710209bfdea696d92befc8e15af9e442801cd3af-1122x354.jpg"}},"field_width":"100"}]},{"_key":"f15b8ea7832a","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"7e7ad92a5161","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Quantity:&nbsp;\u003c/strong>Enter the quantity of the base currency you&#39;d like to purchase. If you type something here, the&nbsp;\u003cstrong>Total\u003c/strong>&nbsp;(to the right), will automatically adjust to match.\u003c/p>\n"},{"_key":"002a69c70f62","_type":"paragraphArticleImage","field_align":"left","field_image":{"_type":"image","asset":{"_ref":"image-d13dcf128e0c0b1347eedcd1e8afde2591a7db34-1114x335-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (63).jpg","size":53598,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":3.325373134328358,"height":335,"width":1114},"lqip":"data:image/jpeg;base64,"},"_id":"image-d13dcf128e0c0b1347eedcd1e8afde2591a7db34-1114x335-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/d13dcf128e0c0b1347eedcd1e8afde2591a7db34-1114x335.jpg"}},"field_width":"100"}]},{"_key":"98bf5c5890ad","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"d333490aa53c","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Total:&nbsp;\u003c/strong>Enter the total of the quote currency you&#39;d like to spend. If you type something here, the&nbsp;\u003cstrong>Quantity\u003c/strong>&nbsp;(to the left), will automatically adjust to match.\u003c/p>\n"},{"_key":"684b292467e7","_type":"paragraphArticleImage","field_align":"left","field_image":{"_type":"image","asset":{"_ref":"image-b6accda763c79028431b395b90bad79448626929-1116x338-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (64).jpg","size":52184,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":3.301775147928994,"height":338,"width":1116},"lqip":"data:image/jpeg;base64,"},"_id":"image-b6accda763c79028431b395b90bad79448626929-1116x338-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/b6accda763c79028431b395b90bad79448626929-1116x338.jpg"}},"field_width":"100"}]},{"_key":"f959316ab27e","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"bbe91773f9ec","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Take Profit/Stop Loss:&nbsp;\u003c/strong>Enable this to attach a&nbsp;\u003ca href=\"https://support.kraken.com/articles/bracket-orders-on-kraken-pro\">Bracket (TP/SL) Order\u003c/a>&nbsp;to your main order.\u003c/p>\n"},{"_key":"d851a4d47c81","_type":"paragraphArticleImage","field_align":"left","field_image":{"_type":"image","asset":{"_ref":"image-6d8c54a2f393a37ee53b4ef24f2a9c42eb758c38-1206x1129-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (66).jpg","size":135137,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.0682019486271037,"height":1129,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-6d8c54a2f393a37ee53b4ef24f2a9c42eb758c38-1206x1129-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/6d8c54a2f393a37ee53b4ef24f2a9c42eb758c38-1206x1129.jpg"}},"field_width":"100"}]},{"_key":"5c178d125949","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"f78eb4f729fa","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Est. Fee:&nbsp;\u003c/strong>The estimated fee for your order.\u003c/p>\n"}]},{"_key":"fec08f72d05d","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"7c7cc2064401","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Post only (Limit Orders only):&nbsp;\u003c/strong>This prevents your order from executing as a Market Order, thus incurring more expensive&nbsp;\u003ca href=\"https://support.kraken.com/articles/360000526126-what-are-maker-and-taker-fees-\">Taker Fees\u003c/a>. The order will get posted on the books (or be cancelled). This prevents placing a limit buy order that matches against the sell side of the order book immediately (and vice versa for sell orders) which would result in taker fees.\u003c/p>\n"}]},{"_key":"54239f095670","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"d0ad22753aa3","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cstrong>Time in force:&nbsp;\u003c/strong>The&nbsp;Time in force&nbsp;field allows you to customize the time at which the order is cancelled if it isn&#39;t filled.\u003c/p>\n"},{"_key":"3a0ea8bc66ab","_type":"paragraphArticleImage","field_align":"left","field_image":{"_type":"image","asset":{"_ref":"image-f430025dbeafb0e8f546b34d61e1288511a7c17f-1206x1174-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"Image from iOS (67).jpg","size":49039,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":1.0272572402044293,"height":1174,"width":1206},"lqip":"data:image/jpeg;base64,"},"_id":"image-f430025dbeafb0e8f546b34d61e1288511a7c17f-1206x1174-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/f430025dbeafb0e8f546b34d61e1288511a7c17f-1206x1174.jpg"}},"field_width":"100"}]}],"field_type":"ul"}],"field_id":"order-form-guide","field_is_expanded":false,"field_title":"Order Form Guide"}],"field_emit_faq_schema":false},{"_key":"88bf52065a48","_type":"paragraphArticleHeadingBody","field_body":"","field_heading":" ","field_heading_html_id":"dd74dafa57f5","field_level":2},{"_key":"eca132f8905d","_type":"paragraphAccordion","field_children":[]},{"_key":"74e230c4101e","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003cem>*Availability of margin trading services is subject to certain limitations and eligibility criteria.\u003c/em>\u003c/p>"}],"field_last_updated_label":"Last updated:","field_title":"How to place orders with the Kraken Pro app","field_tldr_title":"Key takeaways"}],"field_page_meta":{"description":"Support Center for Kraken.com | Bitcoin & Cryptocurrency Exchange | Bitcoin Trading Platform","title":"How to place orders with the Kraken Pro app | Kraken"},"field_tags":[{"_key":"25c2c1266413","_ref":"5b19b9e3-89a4-4b53-b580-8bd5c3986333","_type":"taxonomyTag","_id":"5b19b9e3-89a4-4b53-b580-8bd5c3986333","firstPublishedAt":"2026-01-20T10:38:52.485Z","lastPublishedAt":"2026-01-20T10:38:52.485Z","name":"sc-tier-2"}],"field_target_languages":["de_de","es_es","fr_fr","it_it","nl_nl","pl_pl","pt_br","ru_ru","tr_tr","uk_ua","vi_vn","zh_cn"],"lastPublishedAt":"2026-02-18T22:49:50.427Z","locale":{"_ref":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","_type":"taxonomyLocales","_id":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","code":"en-us","field_label":"English","name":"en-US"},"path":"/articles/360056804571-how-to-place-orders-with-the-kraken-pro-app","status":true,"title":"How to place orders with the Kraken Pro app"}},{"_key":"6c0dc2f9fb07","reference":{"_ref":"article-360038009652","_type":"page","_id":"article-360038009652","_system":{"base":{"id":"article-360038009652","rev":"8tMnvPzY4ctUNnHRoeKkRx"}},"appId":"support","content_source_locale":"en_us","enabled_locales":[],"field_page_components":[{"_key":"573da0c6918e","_type":"paragraphArticleLayout","field_article_breadcrumb_label":"Support","field_article_breadcrumbs":true,"field_children":[{"_key":"96d2303e56d7","_type":"paragraphArticleBodyLc","field_body":"\u003cp>If you experience technical issues with the Kraken Pro mobile app, please follow these steps:\u003c/p>"},{"_key":"dc8c2cb42aa7","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"a969973540ff","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"00a7ed1e48ed","_type":"paragraphArticleBodyLc","field_body":"\u003cp> Make sure you are signing into the app correctly. Ensure that you are using the \u003ca href=\"/articles/360000426923\" >correct sign in 2FA.\u003c/a>\u003c/p>"}]},{"_key":"bf6c3f7b54aa","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"3f0294538950","_type":"paragraphArticleBodyLc","field_body":"\u003cp> Make sure your Kraken Pro app and phone are \u003cstrong>up-to-date\u003c/strong>. \u003c/p>"}]},{"_key":"bdb587a0c920","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"e81fd71a4ecd","_type":"paragraphArticleBodyLc","field_body":"\u003cp>\u003ca href=\"/articles/360038009792\" >Clear the cache and storage of your Kraken Pro app.\u003c/a>\u003c/p>"}]},{"_key":"38cf91ff4b5d","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"2084a7ac0d37","_type":"paragraphArticleBodyLc","field_body":"\u003cp> Some final steps to follow: \u003c/p>"},{"_key":"3ea723bb2b78","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"a58472afb301","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"ab46e6971dd9","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Try force closing and re-opening the app.\u003c/p>"}]},{"_key":"9f34dcde6be6","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"7f2f5d4d4422","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Logging in and out of the app.\u003c/p>"}]},{"_key":"54dfb91b0b12","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"f433fc5d21e7","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Restarting your device.\u003c/p>"}]}],"field_type":"ol"}]}],"field_type":"ol"},{"_key":"619744316819","_type":"paragraphArticleBodyLc","field_body":"\u003cp>If none of these steps solve the issue, please \u003ca href=\"/requests/new?ticket_form_id=96688\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\">contact Kraken Support\u003c/a> and provide the following details:\u003c/p>"},{"_key":"e0543ae99913","_type":"paragraphArticleBodyList","field_list_items":[{"_key":"e5412bc73057","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"955d89f510fe","_type":"paragraphArticleBodyLc","field_body":"\u003cp>Your Kraken app version number.\u003c/p>"}]},{"_key":"3ad99d7cce5b","_type":"paragraphArticleBodyListItem","field_children":[{"_key":"773994f97b8a","_type":"paragraphArticleBodyLc","field_body":"\u003cp> Your mobile device information (brand, model and operating system version). \u003c/p>"}]}],"field_type":"ul"},{"_key":"ccf42284b643","_type":"paragraphArticleHeadingBody","field_body":"\u003cp>The app version number will be shown below the \u003cstrong>Sign out \u003c/strong>button.\u003c/p>","field_heading":" App version number ","field_heading_html_id":"7557763eec1d","field_level":2},{"_key":"e22a22d64aeb","_type":"paragraphArticleImage","field_image":{"alt":"KrakenProApp_VersionNumber.jpg","asset":{"_ref":"image-5d3793205b8ad6acb9fe39cbaa2d28c719d0aef7-1023x1999-jpg","_type":"sanity.imageAsset","mimeType":"image/jpeg","originalFilename":"KrakenProApp_AppVersion_0830.jpg","size":55742,"metadata":{"dimensions":{"_type":"sanity.imageDimensions","aspectRatio":0.5117558779389695,"height":1999,"width":1023},"lqip":"data:image/jpeg;base64,"},"_id":"image-5d3793205b8ad6acb9fe39cbaa2d28c719d0aef7-1023x1999-jpg","sanityUrl":"https://assets-cms.kraken.com/images/51n36hrp/facade/5d3793205b8ad6acb9fe39cbaa2d28c719d0aef7-1023x1999.jpg"}},"field_width":"auto"}],"field_last_updated_label":"Last updated:","field_title":"Troubleshooting steps for the Kraken Pro mobile app","field_tldr_title":"Key takeaways"}],"field_page_meta":{"description":"Support Center for Kraken.com | Bitcoin & Cryptocurrency Exchange | Bitcoin Trading Platform","title":"Troubleshooting steps for the Kraken Pro mobile app | Kraken"},"field_tags":[{"_key":"5247daac0114","_ref":"c9cebfd5-adc5-4382-abb7-f161fe126fd4","_type":"taxonomyTag","_id":"c9cebfd5-adc5-4382-abb7-f161fe126fd4","firstPublishedAt":"2026-01-20T10:38:46.086Z","lastPublishedAt":"2026-01-20T10:38:46.086Z","name":"sc-tier-3"}],"field_target_languages":["de_de","es_es","fr_fr","it_it","nl_nl","pl_pl","pt_br","ru_ru","tr_tr","uk_ua","vi_vn","zh_cn"],"lastPublishedAt":"2025-08-08T22:59:44.623Z","locale":{"_ref":"6a947fc0-ff5d-4972-a190-1bde98fa51a3","_type":