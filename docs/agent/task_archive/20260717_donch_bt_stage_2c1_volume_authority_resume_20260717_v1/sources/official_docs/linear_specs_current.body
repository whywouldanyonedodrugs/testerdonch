],"firstPublishedAt":"2025-12-19T12:29:15.695Z","lastPublishedAt":"2025-12-22T10:01:22.914Z","title":"Navigation Disclaimer UK"},"fieldValues":[{"_key":"5848906392fb","_type":"datasetRecord","children":[{"_key":"dfe1e6729184","_type":"datasetHtmlRecord","datasetFieldDefinitionKey":"86cfc09c5a62","datasetPropertyName":"text","fieldValue":"\u003cp>Don't invest unless you're prepared to lose all the money you invest. This is a high-risk investment and you should not expect to be protected if something goes wrong. \u003ca target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https://www.kraken.com/legal/uk/disclaimer\">Take 2 minutes to learn more\u003c/a>.\u003c/p>"}]}],"fieldLocalisedValues":[]},{"routeId":"a6305fb8-19d2-47bf-8ce7-55ae51960099","template":{"_id":"a345f747-3835-4377-aaa6-b8fb1680d7a5","_system":{"base":{"id":"a345f747-3835-4377-aaa6-b8fb1680d7a5","rev":"o4pyhQYrjL2RaFwwAXkPhs"}},"_type":"componentTemplate","field_page_components":[{"_key":"ac87f39e1432","_type":"paragraphConditionalContent","field_children":[{"_key":"41525fbd006c","_type":"paragraphRouteContentWrapper","field_children":[{"_key":"e645df5b5796","_type":"paragraphSpacingVertical","field_size":6},{"_key":"e0f5a67c3f3c","_type":"paragraphTemplateRef","component_template_reference":{"_ref":"24861306-1d6a-47e0-836e-d8ddb52e4906","_type":"reference"},"field_values":[{"_key":"5b11d3c47861","_type":"datasetBooleanRecord","datasetFieldDefinitionKey":"0fdee94c3d27","datasetPropertyName":"displayInReadingMode","fieldValue":false},{"_key":"c205c6375de8","_type":"datasetObjectArrayRecord","datasetFieldDefinitionKey":"8ff8eaf55b5d","datasetPropertyName":"initialFilters","fieldValue":[]},{"_key":"371249fd46f1","_type":"datasetBooleanRecord","datasetFieldDefinitionKey":"74172c399795","datasetPropertyName":"enableDialog","fieldValue":true},{"_key":"a9651e53190f","_type":"datasetStringRecord","datasetFieldDefinitionKey":"e95331c2edb6","datasetPropertyName":"background"}]},{"_key":"9bd030ed1b35","_