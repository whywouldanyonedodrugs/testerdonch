MATCH (article:Article { key: \"nodeId\" })\nMATCH (section:Section)-[:Section_Article]->(article)\nMATCH (parentSection:Section)-[:Section_Section]->(section)\nMATCH (grandfatherSection:Section)-[:Section_Section]->(parentSection)\nMATCH (category:Category)-[:Category_Section]->(grandfatherSection)\nRETURN [category, grandfatherSection, parentSection, section] AS breadcrumbsData","graph_id":"graph-support"}}],"field_page_components":[{"_key":"54b2482fc994","_type":"paragraphLayout","field_children":[],"field_taxonomy_color_background_opacity":100}],"firstPublishedAt":"2025-07-01T11:59:47.657Z","lastPublishedAt":"2025-08-20T16:21:40.587Z","title":"Support Breadcrumbs"},"fieldValues":[{"_key":"47152b058de7","_type":"datasetRecord","children":[{"_key":"8160778e9dcc","_type":"datasetJsonRecord","datasetFieldDefinitionKey":"b379137a286f","datasetPropertyName":"data"}]}],"fieldLocalisedValues":[]},{"routeId":"a6305fb8-19d2-47bf-8ce7-55ae51960099","template":{"_id":"afb4aaa8-ec80-469c-a590-3e92f67b1ec1","_system":{"base":{"id":"afb4aaa8-ec80-469c-a590-3e92f67b1ec1","rev":"5eQ4FD7pIR4sQnBMGvHYx9"}},"_type":"componentTemplate","field_page_components":[{"_key":"a7e20bbd17fe","_type":"paragraphConditionalContent","field_children":[{"_key":"42ecdc3bd208","_type":"paragraphRouteContentWrapper","field_children":[{"_key":"e48a784196ec","_type":"paragraphSpacingVertical","field_size":20,"field_sm_size":10},{"_key":"6ecf1fdc7727","_type":"paragraphTemplateRef","component_template_reference":{"_ref":"ee9a7c05-76da-4b61-b51b-ba2e8b4e6dfb","_type":"reference"},"field_values":[{"_key":"2b6a4792c7b0","_type":"datasetRecord","children":[{"_key":"483cc99ee409","_type":"datasetBooleanRecord","datasetFieldDefinitionKey":"7eae3811bdcb","datasetPropertyName":"displayCards","fieldValue":false},{"_key":"2933479fb333","_type":"datasetBooleanRecord","datasetFieldDefinitionKey":"ffea5ceab77a","datasetPropertyName":"forceTabletView","fieldValue":false}]}]},{"_key":"1c06924f2538","_type":"paragraphS