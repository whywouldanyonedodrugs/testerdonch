ld_content":"\u003cp\u003e22-Jan-2025\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][1591f2b44451][field_content":"\u003cp\u003ePF_ZETAUSD\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][03c9100e24d1][field_content":"\u003cp\u003eZetaChain (ZETA)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][07fe7cd42938][field_content":"\u003cp\u003e1\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][12290de849d0][field_content":"\u003cp\u003e0.0001\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][5b12a7dfbfcf][field_content":"\u003cp\u003e3,000,000\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][68d868db2595][field_content":"\u003cp\u003eClass D (20x)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][87d461e7ed0f][field_content":"\u003cp\u003e15-May-2024\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][5e1f88ab9388][field_content":"\u003cp\u003ePF_ZEUSUSD\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][6c2af2e2f416][field_content":"\u003cp\u003eZeus Network (ZEUS)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][e36188f786f6][field_content":"\u003cp\u003e1\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][ea2670587931][field_content":"\u003cp\u003e0.00001\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][9c9169b407e6][field_content":"\u003cp\u003e25,000,000\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][8baff9846774][field_content":"\u003cp\u003eClass D (20x)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][6c1ce8a8805b][field_content":"\u003cp\u003e04-Jul-2024\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][df213a816226][field_content":"\u003cp\u003ePF_ZILUSD**\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][b0cac4937707][field_content":"\u003cp\u003eZilliqa (ZIL)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][2498dea71e43][field_content":"\u003cp\u003e10\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][284380b96281][field_content":"\u003cp\u003e0.000001\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][a2ca4055c5c8][field_content":"\u003cp\u003e120,000,000\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][9ffd7f4cb276][field_content":"\u003cp\u003eClass D (20x)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][a2ab958501fe][field_content":"\u003cp\u003e26-Nov-2024\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][743009a5c806][field_content":"\u003cp\u003ePF_ZKUSD\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][63128791ac49][field_content":"\u003cp\u003eZKsync (ZK)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][8ea0f4ea60d8][field_content":"\u003cp\u003e1\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][ac7bed2a393e][field_content":"\u003cp\u003e0.000001\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][01e7b511deed][field_content":"\u003cp\u003e25,000,000\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][babddb16a019][field_content":"\u003cp\u003eClass C (25x)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][da6f6dd79bad][field_content":"\u003cp\u003e01-Aug-2024\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][a9fb7da94f02][field_content":"\u003cp\u003ePF_ZROUSD\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][742e0e231c98][field_content":"\u003cp\u003eLayerZero (ZRO)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][5fe67ce3e63e][field_content":"\u003cp\u003e1\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][b02222ecda8e][field_content":"\u003cp\u003e0.0001\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][081da3e241fb][field_content":"\u003cp\u003e1,000,000\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][af58055e9060][field_content":"\u003cp\u003eClass C (25x)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][a7d34c31539e][field_content":"\u003cp\u003e21-Jun-2024\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][c030223eb618][field_content":"\u003cp\u003ePF_ZRXUSD\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][a7521abb0f63][field_content":"\u003cp\u003e0x Protocol (ZRX)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][d900b65e87eb][field_content":"\u003cp\u003e1\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][b6a9e7549408][field_content":"\u003cp\u003e0.00001\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][2063b34cbfc8][field_content":"\u003cp\u003e10,000,000\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][aaa91500d580][field_content":"\u003cp\u003eClass D (20x)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][e24a5d99c06c][field_content":"\u003cp\u003e12-Apr-2023\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][a186b42fcfd2][field_body":"\u003cp\u003e*BTC is used on the platform UI. XBT is used on the API and account logs. Both refer to Bitcoin (BTC).\u003c/p\u003e\u003cp\u003e**These contracts are not available on the \u003ca href=\"https://futures.kraken.com\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\"\u003elegacy user interface\u003c/a\u003e and can only be accessed via Kraken Pro \u003ca href=\"https://pro.kraken.com/app/trade\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\"\u003eweb\u003c/a\u003e or \u003ca href=\"/articles/360049788312-Kraken-Pro-mobile-app-frequently-asked-questions-\" target=\"blank\" rel=\"noopener\"\u003emobile\u003c/a\u003e and \u003ca href=\"https://docs.kraken.com/api/\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\"\u003eAPI\u003c/a\u003e. \u003c/p\u003e\u003cp\u003eContract specification changes are published on our \u003ca href=\"/articles/13049711807636-derivatives-platform-parameters-changelog\" target=\"blank\" rel=\"noopener\"\u003eDerivatives Platform Parameters Changelog\u003c/a\u003e.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][4b668ca2b1f0][field_title":"Perpetual Contract Specifications","linear_multi-collateral_derivatives_contract_specifications][277037867b91][field_body":"\u003cp\u003ePerpetual Derivatives are a type of Derivatives contract that have \u003cstrong\u003eno expiration date\u003c/strong\u003e and an \u003cstrong\u003eauto-rolling\u003c/strong\u003e feature \u003cstrong\u003eevery hour\u003c/strong\u003e. \u003c/p\u003e\u003cp\u003ePerpetual contracts feature a funding rate, a payment between traders designed to keep the contract\u0026#x27;s price aligned with the underlying asset\u0026#x27;s spot price. \u003c/p\u003e\u003cp\u003eIf the funding rate is positive, long positions pay short positions; if negative, short positions pay long positions. \u003c/p\u003e\u003cp\u003eTraders may pay or receive funding dependent on market conditions. The price difference is calculated hourly, with funding adjustments reflected as unrealized profit or loss, settling at the end of each hour or when the net position changes.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][8efb77260ebf][field_content":"\u003cp\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][295461d06f4e][field_content":"\u003cp\u003eAdditional Information\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][13d61a8ca097][field_content":"\u003cp\u003e\u003cstrong\u003eAuto-Roll Period\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][b16172ac421d][field_content":"\u003cp\u003eEvery 1 hour at the end of the hour\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][02f6e42e441a][field_content":"\u003cp\u003e\u003cstrong\u003eRate-setting Calculation Window\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][aca4d7268612][field_content":"\u003cp\u003eRate for next period is calculated over current 1-hour period (e.g., rate for 12-13 UTC period is calculated in window between 11-12 UTC)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][84cca0d3deb5][field_content":"\u003cp\u003e\u003cstrong\u003eFunding Rate\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][faf5c3bbf592][field_content":"\u003cp\u003eBetween start and end of the \u003cstrong\u003eRate-setting Period\u003c/strong\u003e the \u003cstrong\u003eFunding Rate\u003c/strong\u003e is computed as the time-weighted average premium, and standardised to a per-hour basis. Permissible range per 1 hours: [-0.25%, +0.25%]*** (i.e., 600 basis point magnitude for 24-hour realisation period)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][12f56c554dd4][field_content":"\u003cp\u003e\u003cstrong\u003ePayout Frequency\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][f60235fe5a37][field_content":"\u003cp\u003eContinuously based on \u003cstrong\u003eFunding Rate\u003c/strong\u003e set at the end of the prior \u003cstrong\u003eFunding Period\u003c/strong\u003e. Positions will immediately and continuously receive or send funding while open in the perpetual contracts. The funding accumulates as unrealised profit/loss and settles every 1 hour at end of the \u003cstrong\u003eFunding Period\u003c/strong\u003e, or when user changes net open position (whichever occurs first).\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][71f4ba99ce29][field_content":"\u003cp\u003e\u003cstrong\u003eFunding Rate Multiplier\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][06d4f1ef0171][field_content":"\u003cp\u003en = 24 This is the coefficient used in the calculation of the funding rate. A value of 1/n means that, ceteris paribus, it will take n hours to realise the \u003cstrong\u003eAverage Premium\u003c/strong\u003e. \u003cstrong\u003eExample\u003c/strong\u003e: if the \u003cstrong\u003eAverage Premium\u003c/strong\u003e is 0.36% for the 1-hour period, then Funding Rate is equal to 0.015%, meaning that over the course of 24 hours, this 0.36% total will be realised.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][bc452025528a][field_content":"\u003cp\u003e\u003cstrong\u003eFunding Rate Calculation\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][8ee1a984f4dd][field_content":"\u003cp\u003eIn a given 1-hour Funding Period, \u003cstrong\u003ePremium\u003c/strong\u003e values calculated from minutely perpetual contract prices (60 observations) using an \u003cstrong\u003eImpact Mid\u003c/strong\u003e are recorded versus the \u003cstrong\u003eReal Time Platform Ticker\u003c/strong\u003e. The \u003cstrong\u003eImpact Mid\u003c/strong\u003e is the median of the average entry price market-selling x value of contracts and market-buying x value of contracts. See table above for contract-specific values. The \u003cstrong\u003eAverage Premium\u003c/strong\u003e is calculated as the average of the mid 30 values recorded from the above 60 observations. Finally, this value is weighted by the \u003cstrong\u003eFunding Rate Multiplier\u003c/strong\u003e. If \u003cstrong\u003eAverage Premium\u003c/strong\u003e is greater than 0 for the 1 hour period, those in Long positions will continuously pay out to Short positions, which pushes the price closer to Index. If \u003cstrong\u003eAverage Premium\u003c/strong\u003e is less than 0 for the 1 hour period, those in Short positions will continuously pay out to Long positions, which pushes the price closer to Index.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][270a0576dc13][field_content":"\u003cp\u003e\u003cstrong\u003eTrading Hours\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][6e43bb0cce31][field_content":"\u003cp\u003e24 hours/day, 7 days/week, 365 days/year (excluding \u003ca href=\"/articles/360022837571-Platform-outage-options\" \u003emaintenance\u003c/a\u003e)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][b941f16aaf10][field_content":"\u003cp\u003e\u003cstrong\u003eP\u0026amp;L Settlement Method\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][117d520a43f7][field_content":"\u003cp\u003eCash settled in USD with optional payout in any of the \u003ca href=\"/articles/4843323030164-Futures-Collateral-Currencies\" \u003ecollateral currencies\u003c/a\u003e (profit only, losses are always realised in USD)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][0b1e14944e49][field_content":"\u003cp\u003e\u003cstrong\u003eFee Structure\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][2cac635b1f2d][field_content":"\u003cp\u003eKraken Derivatives uses a maker-taker \u003ca href=\"/articles/360048917612-Fee-schedule\" \u003efee structure\u003c/a\u003e. Fees are calculated as a percentage of the notional order value for a matched trade. No fees are charged on auto-roll or funding payouts -- these occur strictly between counter-parties.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][f5ed382e7e70][field_content":"\u003cp\u003e\u003cstrong\u003eContract Expiration\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][b46d825d1a69][field_content":"\u003cp\u003eThe perpetual derivatives are non-expiring, which means that positions in the contract are never “expired” or “matured”, however there is a settlement process every hour that applies funding to anchor the spot value to the Index. See \u003cstrong\u003eLast Trading\u003c/strong\u003e for more information.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][98d4e973dd45][field_content":"\u003cp\u003e\u003cstrong\u003eSettlement time\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][865d82cde50d][field_content":"\u003cp\u003eEvery 1 hour at the end of the hour: The accumulated unrealised funding is settled and new rate set based on TWAP premium to index in prior rate period.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][fbbb54332e08][field_content":"\u003cp\u003e\u003cstrong\u003eLast Trading\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][2f8a74c01afc][field_content":"\u003cp\u003eThis contract remains trading perpetually and would only expire in an emergency situation if Kraken Derivatives deems necessary to settle/expire the contract. Kraken Derivatives reserve the right to set any contract to post-only, suspended, or settle any contract at any time and without warning due to either adverse market conditions or regulatory risk. \u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][c275ebbc8d1f][field_content":"\u003cp\u003e\u003cstrong\u003eInitial Margin\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][8fea15572baa][field_content":"\u003cp\u003e\u003ca href=\"/articles/360022632452-Margin-Schedule\" \u003eAs low as 2%\u003c/a\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][000d2eb6525a][field_content":"\u003cp\u003e\u003cstrong\u003eMaintenance Margin\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][32cab3455d6e][field_content":"\u003cp\u003eHalf of Initial Margin\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][ed514357cd47][field_content":"\u003cp\u003e\u003cstrong\u003eMaximum Initial Leverage\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][643fe7df3c69][field_content":"\u003cp\u003e\u003ca href=\"/articles/360022632452-Margin-Schedule\" \u003eUp to 50x\u003c/a\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][26fae5bc048d][field_content":"\u003cp\u003e\u003cstrong\u003eMark Price\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][c5c632c63e08][field_content":"\u003cp\u003eIndex Price plus the 30 seconds exponential moving average of the order book mid price minus the index price (future\u0026#x27;s basis). The premium for perpetual contracts is capped at 1%. Calculation: Index Price + EMA_30seconds(Impact Mid Price - Index Price) \u003cbr/\u003e \u003cstrong\u003eNote\u003c/strong\u003e: in the extremely rare circumstance that the Index Price is unavailable for whatever reason, the above caps may not apply and the Mark Price will be equal to the Impact Mid Price.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][fe86707a63ce][field_content":"\u003cp\u003e\u003cstrong\u003eMargin \u0026amp; Settlement Currency\u003c/strong\u003e\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][21a12c713b92][field_content":"\u003cp\u003eUSD, but with full collateral options of BTC, ETH, ADA, DOT, LTC, SOL, XRP, USDT, USDC, EUR, and GBP, adjusted for haircut (see \u003ca href=\"/articles/4843323030164\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\"\u003eDerivatives Collateral Currencies\u003c/a\u003e)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][a2acfa44ebff][field_heading":" The funding rate for a given perpetual contract is represented in two different ways: ","linear_multi-collateral_derivatives_contract_specifications][7d2fc3324afb][field_body":"\u003cp\u003e\u003cstrong\u003eabsolute rate\u003c/strong\u003e: The amount of funding an account will receive by maintaining a 1 contract unit short position for 1 hour. This is more useful for account log purposes.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][8d2063e45b08][field_body":"\u003cp\u003e\u003cstrong\u003eabsolute funding payout\u003c/strong\u003e = # of contracts * absolute funding rate * time elapsed within funding period without position alteration\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][1b01ba50e89a][field_body":"\u003cp\u003e\u003cstrong\u003erelative rate\u003c/strong\u003e: The absolute funding rate relative to the spot price at the time of funding rate calculation. This is an intermediate value in the calculation of the absolute funding rate and is the number we display in the front end (as a %) as the \u0026#x27;funding rate\u0026#x27;.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][c181afb5cf7c][field_body":"\u003cp\u003e\u003cstrong\u003erelative funding payout\u003c/strong\u003e = # of contracts * (relative funding rate*spot price) * time elapsed within funding period without position alteration\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][4458b967a6ff][field_body":"\u003cp\u003eIn order to get a complete understanding of the funding rate dynamics of the Perpetual Contract, we present examples to demonstrate the key features.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][4458b967a6ff][field_heading":" Funding Rate Examples ","linear_multi-collateral_derivatives_contract_specifications][2813e299161c][field_body":"\u003cp\u003eAssume time is 12 UTC and that the price of BTC is $37,000 (via bitcoin-dollar real-time index) and the Perpetual trades at $37,100 the whole time until 13 UTC. The average premium is computed as 0.27027% for the 1-hour period (100/37,000). This leads to a funding rate of 0.27027 / 24 = 0.01126125% per hour.\u003c/p\u003e\u003cp\u003e\u003c/p\u003e\u003cp\u003eNow assume that you are in a short position of 2 BTC, with 1 BTC perpetual contract valued at $37,100. If you hold this position from 13 to 14 UTC, and the premium in the 13 to 14 UTC period remains as 0.27027%, then you will be paid funding of 8.333325 USD for the one-hour period [(2*37000)*0.0001126125]\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][dee2c9f7d08c][field_body":"\u003cp\u003eAssume time is 12 UTC and that price of BTC is $37,000 and the Perpetual trades at $39,700 until 13 UTC. The average premium is computed as 7.297297% for the 1-hour period. This leads to a funding rate of 7.297297 / 24 = 0.30405404% per hour.\u003cbr/\u003e \u003c/p\u003e\u003cp\u003eThe maximum funding rate per hour in any given period is 0.25%. The minimum is -0.25%.\u003c/p\u003e\u003cp\u003e\u003c/p\u003e\u003cp\u003eAs a result, this 0.30405404% hourly rate is floored to 0.25% per hour, so that the maximum 24 hour realisation will not exceed 6%.\u003cbr/\u003e \u003c/p\u003e\u003cp\u003eNote that there is no \u0026quot;dampening\u0026quot; of rates done in this model: if a 1 hour computed rate is near 0, then it will pay out non-0 value even if it is de minimis.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][0960e466738d][field_body":"\u003cp\u003eAssume time is 13 UTC and that the index spot price of BTCUSD is $37,000, and the relative rate set for the 1 hour period is 0.05% per hour.\u003cbr/\u003e \u003c/p\u003e\u003cp\u003eNow assume the time is 13:30 UTC and the perpetual trades at $38,000 and you enter a Short position of 4 BTC at this price.\u003cbr/\u003e \u003c/p\u003e\u003cp\u003eYou will immediately begin receiving funding at an absolute rate of 0.05%*$37,000 = 18.5 USD per hour per unit.\u003cbr/\u003e\u003c/p\u003e\u003cp\u003eIn your available balance you will then see this rate applying in your unrealised PnL through continuous funding payout equal to:\u003c/p\u003e\u003cp\u003e\u003cem\u003e18.5 * 4 BTC = $74 per hour\u003c/em\u003e\u003c/p\u003e\u003cp\u003e\u003cem\u003e$1.233 per minute\u003c/em\u003e\u003c/p\u003e\u003cp\u003e\u003c/p\u003e\u003cp\u003eThis will pay out continuously until 14 UTC where the relative funding rate will change based on the market activity between 13-14 UTC.\u003cbr/\u003e \u003c/p\u003e\u003cp\u003eIn your 4 BTC short position at the end of the half hour period you will have $36.99 applied in your account log at 14 UTC.\u003cbr/\u003e \u003c/p\u003e\u003cp\u003eAssume this new relative funding rate is now 0.03% and the real-time spot index is $37,900 for BTCUSD at 14 UTC. \u003cbr/\u003e \u003c/p\u003e\u003cp\u003eFrom 14 UTC to 15 UTC a new absolute funding rate will begin applying of 0.03%*$37,900=$11.37 per hour per unit.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][3ffb3ff37f22][field_body":"\u003cp\u003eAssume time is 14 UTC and you enter a position long 2 BTC on BTCUSD at 37,000. Assume that the funding rate for the one-hour period (13-14 UTC) is set as -0.04% per hour.\u003cbr/\u003e \u003c/p\u003e\u003cp\u003eAt 15 UTC, after you have held this position for one full hour, you will have earned $29.6 [(0.0004*2 BTC)*37,000], which credits continuously throughout the hour period you hold it.\u003cbr/\u003e \u003c/p\u003e\u003cp\u003eHowever, during this period, the price was at a premium and so the new one-hour rate set for 14 - 15 UTC is 0.04% per hour. After one hour of holding the position, you have paid $29.6 and you close at 16 UTC.\u003cbr/\u003e \u003c/p\u003e\u003cp\u003eYour funding for the two hour period you held the position is thus + $29.6 for the first period and then - $29.6 for the first second and your net flows are 0 for this.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][b17142f788bf][field_body":"\u003cp\u003eAssume it\u0026#x27;s 12 UTC you are in a 5 BTC long position on BTCUSD with spot index at $37,000 and the rate in the funding period is -0.08%. This credits and debits every millisecond to every user with an open position. It credits first as unrealised profit and loss, but you have the funds available right away to use in further positions or transfer into your Cash account. The funding is booked into your account log and realised when one of the following events occur:\u003cbr/\u003e\u003c/p\u003e\u003cp\u003e- You adjust your open position up or down by any amount, \u003c/p\u003e\u003cp\u003e-You hold until the end of the Funding Period, at which point it is booked (occurs at the end of every hour).\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][ceda06f5ca7e][field_body":"\u003cp\u003eAssume it\u0026#x27;s 12 UTC you are in a 3 BTC long position on PF_BTCUSD with spot index at $37,000 and the rate in the funding period is -0.05%. Assume that you have set your profit currency as ETH and you hold this position until the end of the funding period at 13 UTC.\u003cbr/\u003e\u003c/p\u003e\u003cp\u003e0.0015*37,000*3 = $55.5 per hour\u003cbr/\u003e\u003c/p\u003e\u003cp\u003eAt the end of the period at 13 UTC, assume that the price of ETH is 2,500 (from the ether-dollar real-time index)\u003cbr/\u003e\u003c/p\u003e\u003cp\u003eThe conversion can be calculated using the following:\u003cbr/\u003e= Amount in USD to be converted / (Target currency index * (1 - 0.25%))\u003cbr/\u003e= 55.5 USD / (2,500 ETHUSD * .9975)\u003cbr/\u003e= 0.022 ETH\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][d39992643fbf][field_title":"Perpetual Contract Funding Rate Information","linear_multi-collateral_derivatives_contract_specifications][8634678dff36][field_content":"\u003cp\u003eSymbol\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][a8e125b62833][field_content":"\u003cp\u003eActive Maturities\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][b259b09eda5e][field_content":"\u003cp\u003eBase Currency\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][7d98c79fdafb][field_content":"\u003cp\u003eMin Order\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][00ec0ac1470e][field_content":"\u003cp\u003eTick Size\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][4643204c73aa][field_content":"\u003cp\u003eMax Position (Base units)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][892d857639ee][field_content":"\u003cp\u003eMargin Class\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][741630c57768][field_content":"\u003cp\u003eSettlement Index\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][e2d8f5d77eee][field_content":"\u003cp\u003eFF_ETHUSD\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][d284c3814d78][field_content":"\u003cp\u003eWeekly, Monthly, Quarterly, Semiannual\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][10c9c9eb21bb][field_content":"\u003cp\u003eEthereum (ETH)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][2b2d1ae7f539][field_content":"\u003cp\u003e0.001\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][658cb1831caa][field_content":"\u003cp\u003e0.1\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][4346dd044438][field_content":"\u003cp\u003e8,000\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][ee4ec4d8c7d1][field_content":"\u003cp\u003eClass A\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][e48974850195][field_content":"\u003cp\u003eETHOPTRR\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][6ffcb006ce32][field_content":"\u003cp\u003eFF_SOLUSD\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][d635c2af251e][field_content":"\u003cp\u003eMonthly, Quarterly\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][c13acc63dc14][field_content":"\u003cp\u003eSolana (SOL)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][ef708bed713a][field_content":"\u003cp\u003e0.01\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][2ff7c1890e5e][field_content":"\u003cp\u003e0.01\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][1f07a239c6ab][field_content":"\u003cp\u003e80,000\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][02f75665afbd][field_content":"\u003cp\u003eClass B\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][8f65f3d14784][field_content":"\u003cp\u003eSOLOPTRR\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][dfa0cd788cb3][field_content":"\u003cp\u003eFF_XBTUSD*\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][ae59b3ba739b][field_content":"\u003cp\u003eWeekly, Monthly, Quarterly, Semiannual\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][8223a13e9f36][field_content":"\u003cp\u003eBitcoin (BTC*)\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][f2f1525d71ff][field_content":"\u003cp\u003e0.0001\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][8bb9400837d9][field_content":"\u003cp\u003e1\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][c2db1af79436][field_content":"\u003cp\u003e600\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][308dfe7af6db][field_content":"\u003cp\u003eClass A\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][f20097d1f5fb][field_content":"\u003cp\u003eBTCOPTRR\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][4b616971b09e][field_body":"\u003cp\u003e*BTC is used on the platform UI. XBT is used on the API and account logs. Both refer to Bitcoin (BTC).\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][1541ac5174d6][field_body":"\u003cblockquote\u003e\u003cstrong\u003ePnL Settlement Method \u0026amp; Collateral Currencies:\u003c/strong\u003e Linear Derivatives are settled in USD by default, or your chosen profit currency. See\u003ca href=\"/articles/4843323030164-Futures-Collateral-Currencies\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\"\u003e Derivatives Collateral Currencies\u003c/a\u003e for more information.\u003c/blockquote\u003e\u003cp\u003e\u003c/p\u003e\u003cblockquote\u003e\u003cstrong\u003eTrading Hours: \u003c/strong\u003e24 hours/day, 7 days/week, 365 days/year (excluding maintenance)\u003c/blockquote\u003e\u003cp\u003e\u003c/p\u003e\u003cblockquote\u003e\u003cstrong\u003eFee Structure: \u003c/strong\u003eKraken Derivatives uses a \u003ca href=\"/articles/360048917612-Fee-schedule\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\"\u003emaker-taker fee structure.\u003c/a\u003e Fees are calculated as a percentage of the notional order value for a matched trade. Holding a position until settlement will result in a taker fee. \u003cbr/\u003e\u003cbr/\u003eConversion fees and interest may be applied in some instances. See\u003ca href=\"/articles/4844392809620-Fees-Charges-for-Multi-Collateral-Futures\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\"\u003e Fees \u0026amp; Charges for Multi-Collateral Derivatives \u003c/a\u003efor more information.\u003c/blockquote\u003e\u003cp\u003e\u003c/p\u003e\u003cblockquote\u003e\u003cstrong\u003eSettlement Index: \u003c/strong\u003eThe settlement rate is calculated using observations of the underlying Real Time Index over the period of 7:30 UTC to 8:00 UTC on Last Trading day. \u003cbr/\u003eThe methodology is as follows: \u003cbr/\u003e- Take a 30 minute observation window of Real Time Index values before 8 UTC\u003cbr/\u003e- Split the window into 1 minute partitions\u003cbr/\u003e- Compute the average Real Time Index for each minute\u003cbr/\u003e- Compute the average of all 1 minute partitions to obtain the Settlement Rate\u003c/blockquote\u003e\u003cp\u003e\u003c/p\u003e\u003cblockquote\u003e\u003cstrong\u003eSettlement time: \u003c/strong\u003eWithin 15 minutes after Last Trading\u003c/blockquote\u003e\u003cp\u003e\u003c/p\u003e\u003cblockquote\u003e\u003cstrong\u003eLast Trading: \u003c/strong\u003e08:00 UTC \u003cbr/\u003e\u003cbr/\u003eWeek: Every Friday\u003cbr/\u003e\u003cbr/\u003eMonth: Last Friday of the month.\u003cbr/\u003e\u003cbr/\u003eQuarter: Last Friday of a month in the March quarterly cycle (March, June, September, December).\u003cbr/\u003e\u003cbr/\u003eSemiannual: Last Friday of a month in the March quarterly cycle (March, June, September, December).\u003c/blockquote\u003e\u003cp\u003e\u003c/p\u003e\u003cblockquote\u003e\u003cstrong\u003eFirst Trading: \u003c/strong\u003e08:00 UTC.\u003cbr/\u003e\u003cbr/\u003eWeek: Friday of each week where no contract exists in the following week.\u003cbr/\u003e\u003cbr/\u003eMonth: The last Friday of the calendar month where no contract exists in the following calendar month.\u003cbr/\u003e\u003cbr/\u003eQuarter: The last Friday of the calendar month where a contract exists in the following calendar month.\u003cbr/\u003e\u003cbr/\u003eSemiannual: The last Friday of the calendar month where a Month contract and Quarter contract exists.\u003cbr/\u003e\u003cbr/\u003eThe fixed maturity listing schedule results in there always being listed simultaneously at four contracts for BTC and ETH: a Week contract, a Month contract, a Quarter contract, and a Semiannual contract. SOL only has a month and a quarter contract. No contract can have the same remaining days to maturity as another currently-listed contract, therefore at maturity, if the days remaining to maturity on one contract correspond to the maturity of a contract with fewer days to maturity, it will roll into that maturity and the new contract with more days to maturity will be listed.\u003cbr/\u003e\u003cbr/\u003eFor example, if the monthly contract expires on the 31st of May, then the June quarterly contract will become the June monthly contract, the September quarterly contract will be listed.\u003c/blockquote\u003e\u003cp\u003e\u003c/p\u003e\u003cblockquote\u003e\u003cstrong\u003eInitial Margin:\u003c/strong\u003e \u003ca href=\"/articles/360022632452-Margin-Schedule\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\"\u003eAs low as 2%\u003c/a\u003e\u003c/blockquote\u003e\u003cp\u003e\u003c/p\u003e\u003cblockquote\u003e\u003cstrong\u003eMaintenance Margin: \u003c/strong\u003eHalf of Initial Margin\u003c/blockquote\u003e\u003cp\u003e\u003c/p\u003e\u003cblockquote\u003e\u003cstrong\u003eMaximum Initial Leverage:\u003ca href=\"/articles/360022632452-Margin-Schedule\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\"\u003e Up to 50x\u003c/a\u003e\u003c/strong\u003e\u003c/blockquote\u003e\u003cp\u003e\u003c/p\u003e\u003cblockquote\u003e\u003cstrong\u003eMark Price:\u003c/strong\u003e Index Price plus the 30 seconds exponential moving average of the order book mid price minus the index price (future\u0026#x27;s basis).\u003cbr/\u003e\u003cbr/\u003eThe premium is capped at 1% for contracts with 1 day to expiry and 20% for contracts with 210 days to expiry and is linearly interpolated in between.\u003cbr/\u003e\u003cbr/\u003eCalculation: Index Price + EMA_30seconds(Impact Mid Price - Index Price)\u003cbr/\u003e\u003cbr/\u003eNote: in the extremely rare circumstance that the Index Price is unavailable for whatever reason, the above caps may not apply and the Mark Price will be equal to the Impact Mid Price.\u003c/blockquote\u003e\u003cp\u003e\u003c/p\u003e\u003cp\u003e\u003c/p\u003e\u003cp\u003e**Note that if the settlement rate reported by the Index provider is, for any reason, deemed to not adequately represent the underlying market, the Market Risk Committee of Kraken Derivatives reserves the right to select its own appropriate fair value settlement rate. If the index provider restates the price, Kraken Derivatives will settle to the first value published by the index provider at or after publication time.\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][1541ac5174d6][field_heading":" Additional Information: ","linear_multi-collateral_derivatives_contract_specifications][231b3a6828cb][field_title":"Fixed Maturity Contract Specifications","linear_multi-collateral_derivatives_contract_specifications][0b07971fb8f0][field_heading":" Additional Information ","linear_multi-collateral_derivatives_contract_specifications][6b8077e60cf9][field_body":"\u003cp\u003eThe Impact Mid is the median of the average entry price market-selling x value of contracts and market-buying x value of contracts. \u003c/p\u003e\u003cp\u003eThe contract values for Impact Mid are regularly updated. \u003c/p\u003e\u003cp\u003eFor current contract-specific Impact Mid values see our API\u0026#x27;s \u003ca href=\"https://futures.kraken.com/derivatives/api/v3/instruments\" target=\"blank\" rel=\"noopener\" data-testid=\"external-link\"\u003eInstruments Endpoint\u003c/a\u003e. \u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][6b8077e60cf9][field_heading":" Impact Mid Size ","linear_multi-collateral_derivatives_contract_specifications][e63dc5d9a447][field_body":"\u003cp\u003eThe maximum individual order size is $20,000,000 for all contracts and order types. A single order placed with a USD value higher than this amount will not execute. \u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][e63dc5d9a447][field_heading":" Global Platform Max Order Size ","linear_multi-collateral_derivatives_contract_specifications][fb2fad2a663a][field_body":"\u003cp\u003eThe decimal and thousands separators shown in this article may differ from the formats displayed on our trading platforms. Review our article on how we use \u003ca href=\"/articles/360001169543-Decimal-separators-points-vs-commas\" \u003epoints and commas\u003c/a\u003e for more information.\u003c/p\u003e\u003cp\u003e\u003c/p\u003e\u003cp\u003eLast updated: 23 May, 2025\u003c/p\u003e","linear_multi-collateral_derivatives_contract_specifications][fb2fad2a663a][field_heading":" Decimal \u0026amp; Thousands Separator Formatting ","linear_multi-collateral_derivatives_contract_specifications][295a203a6ebc][field_title":"Linear Multi-Collateral Derivatives Contract Specifications","linear_multi-collateral_derivatives_contract_specifications][295a203a6ebc][field_tldr_title":"Key takeaways","linear_multi-collateral_derivatives_contract_specifications][field_page_meta][description":"Support Center for Kraken.com | Bitcoin \u0026 Cryptocurrency Exchange | Bitcoin Trading Platform","linear_multi-collateral_derivatives_contract_specifications][field_page_meta][title":"Linear Multi-Collateral Derivatives Contract Specifications | Kraken","taxonomy_country][8358e943-0034-492f-8225-e6fc88d7587a][description":"United States","taxonomy_country][8358e943-0034-492f-8225-e6fc88d7587a][field_from":"from the USA","taxonomy_country][8358e943-0034-492f-8225-e6fc88d7587a][field_in":"in the USA","taxonomy_country][8358e943-0034-492f-8225-e6fc88d7587a][field_of":"of the USA","taxonomy_country][8358e943-0034-492f-8225-e6fc88d7587a][