window.loadMeta = fetch('/config.json')
  .then((response) => response.json())
  .then((configJson) => {
    configJson.internalApi = configJson.internalApi || "https://iapi.kraken.com";

    // pro.kraken.com/config.json adds an unnecessary path to the internalApi, strip it out if there
    configJson.internalApi = configJson.internalApi.replace(/(\.com|\.zone)\/api\/internal/, '$1');

    window.CONFIG_JSON = configJson;
    return configJson;
  })
  .then((configJson) =>
    fetch(configJson.internalApi + '/api/internal/meta', {
      mode: 'cors',
      credentials: 'include'
    }),
  )
  .then((response) => response.json())
  .then((data) => {
    window.META_DATA = data.result;
  })
  .catch(() => console.log('Unable to load META_DATA'));</script><script id="oneTrustLoaded" data-nscript="beforeInteractive">
