esses\",\"api-reference/funding/get-status-of-recent-deposits\",\"api-reference/funding/get-withdrawal-methods\",\"api-reference/funding/get-withdrawal-addresses\",\"api-reference/funding/get-withdrawal-information\",\"api-reference/funding/withdraw-funds\",\"api-reference/funding/get-status-of-recent-withdrawals\",\"api-reference/funding/request-withdrawal-cancellation\",\"api-reference/funding/request-wallet-transfer\"]},{\"group\":\"Subaccounts\",\"public\":true,\"openapi\":\"openapi/spot-rest.yaml\",\"pages\":[\"api-reference/subaccounts/create-subaccount\",\"api-reference/subaccounts/account-transfer\"]},{\"group\":\"Earn\",\"public\":true,\"openapi\":\"openapi/spot-rest.yaml\",\"pages\":[\"api-reference/earn/list-earn-strategies\",\"api-reference/earn/list-earn-allocations\",\"api-reference/earn/allocate-earn-funds\",\"api-reference/earn/deallocate-earn-funds\",\"api-reference/earn/get-allocation-status\",\"api-reference/earn/get-deallocation-status\"]},{\"group\":\"Transparency\",\"public\":true,\"openapi\":\"openapi/spot-rest.yaml\",\"pages\":[\"api-reference/transparency/pre-trade-data\",\"api-reference/transparency/post-trade-data\"]}]},{\"dropdown\":\"Spot WebSocket v2\",\"icon\":\"bolt\",\"pages\":[\"exchange/api-reference/spot-websocket\",{\"group\":\"Public Channels\",\"public\":true,\"pages\":[\"exchange/api-reference/spot-websocket-v2/ticker\",\"exchange/api-reference/spot-websocket-v2/book\",\"exchange/api-reference/spot-websocket-v2/ohlc\",\"exchange/api-reference/spot-websocket-v2/trade\",\"exchange/api-reference/spot-websocket-v2/instrument\",\"exchange/api-reference/spot-websocket-v2/level3\",\"exchange/api-reference/spot-websocket-v2/status\",\"exchange/api-reference/spot-websocket-v2/heartbeat\"]},{\"group\":\"Trading\",\"public\":true,\"pages\":[\"exchange/api-reference/spot-websocket-v2/add_order\",\"exchange/api-reference/spot-websocket-v2/edit_order\",\"exchange/api-reference/spot-websocket-v2/amend_order\",\"exchange/api-reference/spot-websocket-v2/cancel_order\",\"exchange/api-reference/spot-websocket-v2/cancel_all\",\"exchange/api-reference/spot-websocket-v2/cancel_after\",\"exchange/api-reference/spot-websocket-v2/batch_add\",\"exchange/api-reference/spot-websocket-v2/batch_cancel\"]},{\"group\":\"Account\",\"public\":true,\"pages\":[\"exchange/api-reference/spot-websocket-v2/balances\",\"exchange/api-reference/spot-websocket-v2/executions\"]},{\"group\":\"System\",\"public\":true,\"pages\":[\"exchange/api-reference/spot-websocket-v2/ping\"]}]},{\"dropdown\":\"Unified WebSocket\",\"icon\":\"lock\",\"hidden\":true,\"groups\":[{\"group\":\"Public Channels\",\"public\":true,\"pages\":[\"exchange/api-reference/unified-ws/ticker\",\"exchange/api-reference/unified-ws/book\",\"exchange/api-reference/unified-ws/ohlc\",\"exchange/api-reference/unified-ws/instrument\",\"exchange/api-reference/unified-ws/level3\",\"exchange/api-reference/unified-ws/status\",\"exchange/api-reference/unified-ws/heartbeat\"]},{\"group\":\"Trading\",\"public\":true,\"pages\":[\"exchange/api-reference/unified-ws/add_order\",\"exchange/api-reference/unified-ws/amend_order\",\"exchange/api-reference/unified-ws/cancel_order\",\"exchange/api-reference/unified-ws/cancel_all\",\"exchange/api-reference/unified-ws/cancel_after\"]},{\"group\":\"Account\",\"public\":true,\"pages\":[\"exchange/api-reference/unified-ws/balances\",\"exchange/api-reference/unified-ws/executions\"]},{\"group\":\"System\",\"public\":true,\"pages\":[\"exchange/api-reference/unified-ws/ping\"]}]},{\"dropdown\":\"Spot WebSocket v1\",\"icon\":\"bolt\",\"groups\":[{\"group\":\"Public Channels\",\"public\":true,\"pages\":[\"exchange/api-reference/spot-websocket-v1/ticker\",\"exchange/api-reference/spot-websocket-v1/ohlc\",\"exchange/api-reference/spot-websocket-v1/trade\",\"exchange/api-reference/spot-websocket-v1/spread\",\"exchange/api-reference/spot-websocket-v1/book\"]},{\"group\":\"Trading\",\"public\":true,\"pages\":[\"exchange/api-reference/spot-websocket-v1/a