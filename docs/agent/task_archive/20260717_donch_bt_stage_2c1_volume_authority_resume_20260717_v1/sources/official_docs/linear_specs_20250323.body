rkDefs":[],"children":[{"_type":"span","marks":[],"text":"**These contracts are not available on the legacy user interface and can only be accessed via Kraken Pro or API. ","_key":"55608582c4030"}],"_type":"block","style":"normal","_key":"d3b8ac8c4e571"},{"_key":"d3b8ac8c4e572","markDefs":[{"_key":"e2a2f72e32b6","newTab":true,"referenceArticle":{"url":{"current":"360022632452-Multi-Collateral-Futures-Margin-Schedule-Maximum-Leverage","_type":"slug"}},"_type":"articleLink"}],"children":[{"_type":"span","marks":[],"text":"Margin Category details available on ","_key":"544198f37ee50"},{"_type":"span","marks":["e2a2f72e32b6"],"text":"Margin schedule and Maximum Leverage","_key":"aa4ac4e04794"},{"text":".","_key":"c5a9b626fc77","_type":"span","marks":[]}],"_type":"block","style":"normal"},{"style":"normal","_key":"d3b8ac8c4e573","markDefs":[{"_key":"7f1c3139cfba","newTab":true,"referenceArticle":{"url":{"current":"13049711807636-Futures-Platform-Parameters-Changelog","_type":"slug"}},"_type":"articleLink"}],"children":[{"_key":"3b75668219410","_type":"span","marks":[],"text":"Contract specification changes available on our "},{"_type":"span","marks":["7f1c3139cfba"],"text":"Derivatives Platform Parameters Changelog","_key":"3e5fea5096a9"},{"text":".","_key":"4ad27c36c84e","_type":"span","marks":[]}],"_type":"block"}],"_type":"item","_key":"85Bl7Ei4pF_CN0GWYSZ59","title":"Perpetual Contract Specifications"},{"_key":"AcEWbN5YEbWZzXt5uFuVi","title":"Perpetual Contract Funding Rate Information","contentPortable":[{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"Perpetual Derivatives are a type of Derivatives contract that have ","_key":"6697ac8ea03d"},{"_type":"span","marks":["strong"],"text":"no expiration date","_key":"59d6be9d8dcb"},{"_key":"05eae9fa541b","_type":"span","marks":[],"text":" and an "},{"_type":"span","marks":["strong"],"text":"auto-rolling","_key":"db2c285816f8"},{"marks":[],"text":" feature ","_key":"35dbe7264a0d","_type":"span"},{"text":"every hour","_key":"d4811d7cb850","_type":"span","marks":["strong"]},{"_type":"span","marks":[],"text":". ","_key":"f5528114c43a"}],"_type":"block","style":"normal","_key":"5952dfdb412f"},{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"Perpetual contracts feature a funding rate, a payment between traders designed to keep the contract's price aligned with the underlying asset's spot price. ","_key":"a26663f1f38c"}],"_type":"block","style":"normal","_key":"ccb3048a68c0"},{"style":"normal","_key":"d067daa31cf7","markDefs":[],"children":[{"_type":"span","marks":[],"text":"If the funding rate is positive, long positions pay short positions; if negative, short positions pay long positions. ","_key":"0525bbca1136"}],"_type":"block"},{"_key":"98c0478758f7","markDefs":[],"children":[{"_key":"1498b193174d","_type":"span","marks":[],"text":"Traders may pay or receive funding dependent on market conditions. The price difference is calculated hourly, with funding adjustments reflected as unrealized profit or loss, settling at the end of each hour or when the net position changes."}],"_type":"block","style":"normal"},{"rows":[{"cells":[{"contentPortable":[{"markDefs":[],"children":[{"text":"","_key":"c9d1fb9f05610","_type":"span","marks":[]}],"_type":"block","style":"normal","_key":"c9d1fb9f0561"}],"_type":"cell","description":"Column :: ","_key":"LVSZbGxkTzqvdH_mrvF7z"},{"_type":"cell","description":"Column :: Additional Information","_key":"Bp3xMLE49kb71_EhKxf-e","contentPortable":[{"markDefs":[],"children":[{"text":"Additional Information","_key":"8962303967750","_type":"span","marks":[]}],"_type":"block","style":"normal","_key":"896230396775"}]}],"_type":"row","description":"Row :: ","_key":"if4j20ReB40WYxaBXu563"},{"cells":[{"contentPortable":[{"children":[{"_key":"0e932ed311f50","_type":"span","marks":["strong"],"text":"Auto-Roll Period"}],"_type":"block","style":"normal","_key":"0e932ed311f5","markDefs":[]}],"_type":"cell","description":"Column :: ","_key":"_Zu2CQ7Vn4xwAWB2wAU7z"},{"contentPortable":[{"_key":"9b72a5078f9e","markDefs":[],"children":[{"text":"Every 1 hour at the end of the hour","_key":"9b72a5078f9e0","_type":"span","marks":[]}],"_type":"block","style":"normal"}],"_type":"cell","description":"Column :: Additional Information","_key":"dYuyUC3NbMKH_r1rqnaWk"}],"_type":"row","description":"Row :: Auto-Roll Period","_key":"Jq1g9v3SmUbO8HYXYqKyG"},{"description":"Row :: Rate-setting Calculation Window","_key":"u67EfDlPzMqpSUtEOrmm8","cells":[{"_type":"cell","description":"Column :: ","_key":"vdi0gmDVN7D03EtSW8_gD","contentPortable":[{"children":[{"_type":"span","marks":["strong"],"text":"Rate-setting Calculation Window","_key":"6f6c9617d0cf0"}],"_type":"block","style":"normal","_key":"6f6c9617d0cf","markDefs":[]}]},{"_key":"cdWwcrC6nD0HSPz-rpIeP","contentPortable":[{"children":[{"_key":"cfa2230680190","_type":"span","marks":[],"text":"Rate for next period is calculated over current 1-hour period (e.g., rate for 12-13 UTC period is calculated in window between 11-12 UTC)"}],"_type":"block","style":"normal","_key":"cfa223068019","markDefs":[]}],"_type":"cell","description":"Column :: Additional Information"}],"_type":"row"},{"cells":[{"description":"Column :: ","_key":"dXiCBkEDvhc3MbkonzT4k","contentPortable":[{"_type":"block","style":"normal","_key":"bf4d4421d145","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Funding Rate","_key":"bf4d4421d1450"}]}],"_type":"cell"},{"_type":"cell","description":"Column :: Additional Information","_key":"D7Nhr5KhLeKHhMUBUBLXm","contentPortable":[{"_key":"b7e651c18f7e","markDefs":[],"children":[{"_type":"span","marks":[],"text":"Between start and end of the ","_key":"b7e651c18f7e0"},{"_type":"span","marks":["strong"],"text":"Rate-setting Period","_key":"b7e651c18f7e1"},{"text":" the ","_key":"b7e651c18f7e2","_type":"span","marks":[]},{"marks":["strong"],"text":"Funding Rate","_key":"b7e651c18f7e3","_type":"span"},{"_type":"span","marks":[],"text":" is computed as the time-weighted average premium, and standardised to a per-hour basis. Permissible range per 1 hours: [-0.25%, +0.25%]*** (i.e., 600 basis point magnitude for 24-hour realisation period)","_key":"b7e651c18f7e4"}],"_type":"block","style":"normal"}]}],"_type":"row","description":"Row :: Funding Rate","_key":"Pb3InwvUK_69w0RyhK1EW"},{"description":"Row :: Payout Frequency","_key":"3oRyykrqHC9A0yRlfe323","cells":[{"contentPortable":[{"_key":"0c0cb59d456f","markDefs":[],"children":[{"marks":["strong"],"text":"Payout Frequency","_key":"0c0cb59d456f0","_type":"span"}],"_type":"block","style":"normal"}],"_type":"cell","description":"Column :: ","_key":"PdSixX2aisBhQ60l7Kdyb"},{"_key":"TZkb0MSdQeh7uMh_tKGvp","contentPortable":[{"children":[{"_type":"span","marks":[],"text":"Continuously based on ","_key":"ad2d4831209b0"},{"_type":"span","marks":["strong"],"text":"Funding Rate","_key":"ad2d4831209b1"},{"_type":"span","marks":[],"text":" set at the end of the prior ","_key":"ad2d4831209b2"},{"_type":"span","marks":["strong"],"text":"Funding Period","_key":"ad2d4831209b3"},{"_type":"span","marks":[],"text":". Positions will immediately and continuously receive or send funding while open in the perpetual contracts. The funding accumulates as unrealised profit/loss and settles every 1 hour at end of the ","_key":"ad2d4831209b4"},{"text":"Funding Period","_key":"ad2d4831209b5","_type":"span","marks":["strong"]},{"_type":"span","marks":[],"text":", or when user changes net open position (whichever occurs first).","_key":"ad2d4831209b6"}],"_type":"block","style":"normal","_key":"ad2d4831209b","markDefs":[]}],"_type":"cell","description":"Column :: Additional Information"}],"_type":"row"},{"cells":[{"_key":"Vn0zKQa-nyx_ThKOTxq3A","contentPortable":[{"children":[{"_type":"span","marks":["strong"],"text":"Funding Rate Multiplier","_key":"056f7262aab50"}],"_type":"block","style":"normal","_key":"056f7262aab5","markDefs":[]}],"_type":"cell","description":"Column :: "},{"_type":"cell","description":"Column :: Additional Information","_key":"TeL8jvbqE8277nqJgazp2","contentPortable":[{"children":[{"_type":"span","marks":[],"text":"n = 24 This is the coefficient used in the calculation of the funding rate. A value of 1/n means that, ceteris paribus, it will take n hours to realise the ","_key":"57dc915606100"},{"_type":"span","marks":["strong"],"text":"Average Premium","_key":"57dc915606101"},{"text":". ","_key":"57dc915606102","_type":"span","marks":[]},{"text":"Example","_key":"57dc915606103","_type":"span","marks":["strong"]},{"_type":"span","marks":[],"text":": if the ","_key":"57dc915606104"},{"_type":"span","marks":["strong"],"text":"Average Premium","_key":"57dc915606105"},{"_type":"span","marks":[],"text":" is 0.36% for the 1-hour period, then Funding Rate is equal to 0.015%, meaning that over the course of 24 hours, this 0.36% total will be realised.","_key":"57dc915606106"}],"_type":"block","style":"normal","_key":"57dc91560610","markDefs":[]}]}],"_type":"row","description":"Row :: Funding Rate Multiplier","_key":"KhTO_KeGZLsEAdWMSVvM-"},{"cells":[{"contentPortable":[{"children":[{"_type":"span","marks":["strong"],"text":"Funding Rate Calculation","_key":"678aa3d496380"}],"_type":"block","style":"normal","_key":"678aa3d49638","markDefs":[]}],"_type":"cell","description":"Column :: ","_key":"BLV9q9chyl8pPzRwtVAcw"},{"contentPortable":[{"style":"normal","_key":"654d8ca2f408","markDefs":[],"children":[{"_type":"span","marks":[],"text":"In a given 1-hour Funding Period, ","_key":"654d8ca2f4080"},{"_type":"span","marks":["strong"],"text":"Premium","_key":"654d8ca2f4081"},{"_type":"span","marks":[],"text":" values calculated from minutely perpetual contract prices (60 observations) using an ","_key":"654d8ca2f4082"},{"marks":["strong"],"text":"Impact Mid","_key":"654d8ca2f4083","_type":"span"},{"_key":"654d8ca2f4084","_type":"span","marks":[],"text":" are recorded versus the "},{"_type":"span","marks":["strong"],"text":"Real Time Platform Ticker","_key":"654d8ca2f4085"},{"_key":"654d8ca2f4086","_type":"span","marks":[],"text":". The "},{"text":"Impact Mid","_key":"654d8ca2f4087","_type":"span","marks":["strong"]},{"_type":"span","marks":[],"text":" is the median of the average entry price market-selling x value of contracts and market-buying x value of contracts. See table above for contract-specific values. The ","_key":"654d8ca2f4088"},{"text":"Average Premium","_key":"654d8ca2f4089","_type":"span","marks":["strong"]},{"_type":"span","marks":[],"text":" is calculated as the average of the mid 30 values recorded from the above 60 observations. Finally, this value is weighted by the ","_key":"654d8ca2f40810"},{"_key":"654d8ca2f40811","_type":"span","marks":["strong"],"text":"Funding Rate Multiplier"},{"_type":"span","marks":[],"text":". If ","_key":"654d8ca2f40812"},{"marks":["strong"],"text":"Average Premium","_key":"654d8ca2f40813","_type":"span"},{"_type":"span","marks":[],"text":" is greater than 0 for the 1 hour period, those in Long positions will continuously pay out to Short positions, which pushes the price closer to Index. If ","_key":"654d8ca2f40814"},{"_key":"654d8ca2f40815","_type":"span","marks":["strong"],"text":"Average Premium"},{"_key":"654d8ca2f40816","_type":"span","marks":[],"text":" is less than 0 for the 1 hour period, those in Short positions will continuously pay out to Long positions, which pushes the price closer to Index."}],"_type":"block"}],"_type":"cell","description":"Column :: Additional Information","_key":"Uv_irTU4PbnUg-xDVdEdV"}],"_type":"row","description":"Row :: Funding Rate Calculation","_key":"KEI6jfo5QY0WHK9imF1s-"},{"_type":"row","description":"Row :: Trading Hours","_key":"Zy15NtCZVknQd1jbjeg8e","cells":[{"description":"Column :: ","_key":"vpNXuXRR4pdAL1bZyMhLj","contentPortable":[{"style":"normal","_key":"e850c89d217b","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Trading Hours","_key":"e850c89d217b0"}],"_type":"block"}],"_type":"cell"},{"contentPortable":[{"markDefs":[{"_type":"externalLink","_key":"3cdb8ee7f8e54","newTab":false,"url":"https://support.kraken.com/hc/en-us/articles/360022837571-Platform-outage-options"}],"children":[{"_type":"span","marks":[],"text":"24 hours/day, 7 days/week, 365 days/year (excluding ","_key":"46c73cffccfa0"},{"_type":"span","marks":["3cdb8ee7f8e54"],"text":"maintenance","_key":"46c73cffccfa1"},{"_type":"span","marks":[],"text":")","_key":"46c73cffccfa2"}],"_type":"block","style":"normal","_key":"46c73cffccfa"}],"_type":"cell","description":"Column :: Additional Information","_key":"I4wN_A8bxrIn9vKLZ6YYp"}]},{"cells":[{"contentPortable":[{"markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"P\u0026L Settlement Method","_key":"f5376745c5540"}],"_type":"block","style":"normal","_key":"f5376745c554"}],"_type":"cell","description":"Column :: ","_key":"Vd5-xKprCJ1XRqpM6_UdF"},{"contentPortable":[{"style":"normal","_key":"71ebcbb242cc","markDefs":[{"_type":"externalLink","_key":"cd4a8ce6013ff","newTab":false,"url":"https://support.kraken.com/hc/en-us/articles/4843323030164-Futures-Collateral-Currencies"}],"children":[{"_key":"71ebcbb242cc0","_type":"span","marks":[],"text":"Cash settled in USD with optional payout in any of the "},{"_type":"span","marks":["cd4a8ce6013ff"],"text":"collateral currencies","_key":"71ebcbb242cc1"},{"_type":"span","marks":[],"text":" (profit only, losses are always realised in USD)","_key":"71ebcbb242cc2"}],"_type":"block"}],"_type":"cell","description":"Column :: Additional Information","_key":"QVFKx3u3uhNDG2eubzTNU"}],"_type":"row","description":"Row :: P\u0026L Settlement Method","_key":"lNptSrPo_QFQN97EJrwr6"},{"_type":"row","description":"Row :: Fee Structure","_key":"y8C9j8Fgg_iQuAdtyEWs9","cells":[{"_type":"cell","description":"Column :: ","_key":"OfiLEk4cJIED-VcfpBM3z","contentPortable":[{"_type":"block","style":"normal","_key":"655c3f345cb5","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Fee Structure","_key":"655c3f345cb50"}]}]},{"description":"Column :: Additional Information","_key":"p-AL5eMSdVTvYUreNJFn9","contentPortable":[{"_type":"block","style":"normal","_key":"b3814277a341","markDefs":[{"newTab":false,"url":"https://support.kraken.com/hc/en-us/articles/360048917612-Fee-schedule","_type":"externalLink","_key":"e4a32e0c27d64"}],"children":[{"_type":"span","marks":[],"text":"Kraken Derivatives uses a maker-taker ","_key":"b3814277a3410"},{"_key":"b3814277a3411","_type":"span","marks":["e4a32e0c27d64"],"text":"fee structure"},{"_type":"span","marks":[],"text":". Fees are calculated as a percentage of the notional order value for a matched trade. No fees are charged on auto-roll or funding payouts -- these occur strictly between counter-parties.","_key":"b3814277a3412"}]}],"_type":"cell"}]},{"_type":"row","description":"Row :: Contract Expiration","_key":"whe8QTuq3zoQYyDLImYmR","cells":[{"contentPortable":[{"children":[{"marks":["strong"],"text":"Contract Expiration","_key":"0fbebe12af800","_type":"span"}],"_type":"block","style":"normal","_key":"0fbebe12af80","markDefs":[]}],"_type":"cell","description":"Column :: ","_key":"0phalLFUKOWSATn76GqEI"},{"_type":"cell","description":"Column :: Additional Information","_key":"O4CBUKaJFqSTFIXQ9m9-z","contentPortable":[{"style":"normal","_key":"f0d6f8bdc573","markDefs":[],"children":[{"_type":"span","marks":[],"text":"The perpetual derivatives are non-expiring, which means that positions in the contract are never “expired” or “matured”, however there is a settlement process every hour that applies funding to anchor the spot value to the Index. See ","_key":"f0d6f8bdc5730"},{"_type":"span","marks":["strong"],"text":"Last Trading","_key":"f0d6f8bdc5731"},{"_type":"span","marks":[],"text":" for more information.","_key":"f0d6f8bdc5732"}],"_type":"block"}]}]},{"_type":"row","description":"Row :: Settlement time","_key":"qyR-Iaea4DJ6u73dHqK1w","cells":[{"description":"Column :: ","_key":"UIcPEY3fw2YQfhIPGessa","contentPortable":[{"_key":"57a00718b86f","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Settlement time","_key":"57a00718b86f0"}],"_type":"block","style":"normal"}],"_type":"cell"},{"_type":"cell","description":"Column :: Additional Information","_key":"RSbjUtcTS4how3U0ViAsJ","contentPortable":[{"children":[{"_type":"span","marks":[],"text":"Every 1 hour at the end of the hour: The accumulated unrealised funding is settled and new rate set based on TWAP premium to index in prior rate period.","_key":"83145ddd90940"}],"_type":"block","style":"normal","_key":"83145ddd9094","markDefs":[]}]}]},{"_type":"row","description":"Row :: Last Trading","_key":"6_P4jWvoFadkbx-EhUHdc","cells":[{"contentPortable":[{"children":[{"marks":["strong"],"text":"Last Trading","_key":"6b5aeabc9a580","_type":"span"}],"_type":"block","style":"normal","_key":"6b5aeabc9a58","markDefs":[]}],"_type":"cell","description":"Column :: ","_key":"kyBi4UvBa6E9fMlYJm5m9"},{"contentPortable":[{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"This contract remains trading perpetually and would only expire in an emergency situation if Kraken Derivatives deems necessary to settle/expire the contract. Kraken Derivatives reserve the right to set any contract to post-only, suspended, or settle any contract at any time and without warning due to either adverse market conditions or regulatory risk. ","_key":"403c0c8e7e870"}],"_type":"block","style":"normal","_key":"403c0c8e7e87"}],"_type":"cell","description":"Column :: Additional Information","_key":"qTsmvIp0ickE-dMscww-9"}]},{"_key":"EwweeYwwjeC2tvqmWvRv8","cells":[{"_key":"2BC9PuH88FgCrmAP3biIa","contentPortable":[{"markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Initial Margin","_key":"0cea575ad7020"}],"_type":"block","style":"normal","_key":"0cea575ad702"}],"_type":"cell","description":"Column :: "},{"contentPortable":[{"markDefs":[{"_type":"externalLink","_key":"95c614b3976ee","newTab":false,"url":"https://support.kraken.com/hc/en-us/articles/360022632452-Margin-Schedule"}],"children":[{"_key":"44729a2fa4150","_type":"span","marks":["95c614b3976ee"],"text":"As low as 2%"}],"_type":"block","style":"normal","_key":"44729a2fa415"}],"_type":"cell","description":"Column :: Additional Information","_key":"W29oNx252g-JT4mi8PUv1"}],"_type":"row","description":"Row :: Initial Margin"},{"description":"Row :: Maintenance Margin","_key":"9i5V_I3m9pZeHJdsXuucC","cells":[{"description":"Column :: ","_key":"8-dzeadPp3ZvBLxlleuAc","contentPortable":[{"_type":"block","style":"normal","_key":"11a2619a4965","markDefs":[],"children":[{"text":"Maintenance Margin","_key":"11a2619a49650","_type":"span","marks":["strong"]}]}],"_type":"cell"},{"_key":"5MS8osPUHVcjgd8FwmFBB","contentPortable":[{"children":[{"_type":"span","marks":[],"text":"Half of Initial Margin","_key":"e2a47d3653ab0"}],"_type":"block","style":"normal","_key":"e2a47d3653ab","markDefs":[]}],"_type":"cell","description":"Column :: Additional Information"}],"_type":"row"},{"_key":"P_XSidtiV_iePgfPjNCPs","cells":[{"contentPortable":[{"style":"normal","_key":"be83860afb48","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Maximum Initial Leverage","_key":"be83860afb480"}],"_type":"block"}],"_type":"cell","description":"Column :: ","_key":"1NTCyKncU4308CWw9Wdrf"},{"_type":"cell","description":"Column :: Additional Information","_key":"bAeRt0L7tLLA9YforQRtt","contentPortable":[{"_key":"3afc429e11a4","markDefs":[{"_key":"1f49ee8f6dccc","newTab":false,"url":"https://support.kraken.com/hc/en-us/articles/360022632452-Margin-Schedule","_type":"externalLink"}],"children":[{"text":"Up to 50x","_key":"3afc429e11a40","_type":"span","marks":["1f49ee8f6dccc"]}],"_type":"block","style":"normal"}]}],"_type":"row","description":"Row :: Maximum Initial Leverage"},{"description":"Row :: Mark Price","_key":"WnVNW_eQLsa1IZgAKOYkY","cells":[{"description":"Column :: ","_key":"HMzvyv7jL_4hnHlDx5Okr","contentPortable":[{"markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Mark Price","_key":"06aa14e3e3a00"}],"_type":"block","style":"normal","_key":"06aa14e3e3a0"}],"_type":"cell"},{"_key":"s15KXxGIuYHUcjv7o5G_m","contentPortable":[{"children":[{"_type":"span","marks":[],"text":"Index Price plus the 30 seconds exponential moving average of the order book mid price minus the index price (future's basis). The premium for perpetual contracts is capped at 1%. Calculation: Index Price + EMA_30seconds(Impact Mid Price - Index Price) \n ","_key":"a8ba553438890"},{"_type":"span","marks":["strong"],"text":"Note","_key":"a8ba553438891"},{"_type":"span","marks":[],"text":": in the extremely rare circumstance that the Index Price is unavailable for whatever reason, the above caps may not apply and the Mark Price will be equal to the Impact Mid Price.","_key":"a8ba553438892"}],"_type":"block","style":"normal","_key":"a8ba55343889","markDefs":[]}],"_type":"cell","description":"Column :: Additional Information"}],"_type":"row"},{"cells":[{"contentPortable":[{"children":[{"_type":"span","marks":["strong"],"text":"Margin \u0026 Settlement Currency","_key":"88a0b49fbf4d0"}],"_type":"block","style":"normal","_key":"88a0b49fbf4d","markDefs":[]}],"_type":"cell","description":"Column :: ","_key":"jLFKQAVYeNrYnnSKYDXrC"},{"_key":"a_SL7aLm0kP_1ClWlkFGB","contentPortable":[{"markDefs":[{"_type":"externalLink","_key":"78fe7da8a01e0","newTab":true,"url":"https://support.kraken.com/hc/articles/4843323030164"}],"children":[{"marks":[],"text":"USD, but with full collateral options of BTC, ETH, ADA, DOT, LTC, SOL, XRP, USDT, USDC, EUR, and GBP, adjusted for haircut (see ","_key":"d0a690dcddfa0","_type":"span"},{"_type":"span","marks":["78fe7da8a01e0"],"text":"Derivatives Collateral Currencies","_key":"d0a690dcddfa1"},{"_type":"span","marks":[],"text":")","_key":"d0a690dcddfa2"}],"_type":"block","style":"normal","_key":"d0a690dcddfa"}],"_type":"cell","description":"Column :: Additional Information"}],"_type":"row","description":"Row :: Margin \u0026 Settlement Currency","_key":"wYEt03-1-aGykiVd3WeMd"}],"_type":"table","description":"Table: Legacy Migrated Placeholder","_key":"-SukD5OkouCZmEMf3ad0y","markDefs":null,"mobileStyle":"summary","expandedTable":false},{"style":"h4","_key":"f1b957db23100","markDefs":[],"children":[{"_type":"span","marks":[],"text":"The funding rate for a given perpetual contract is represented in two different ways:","_key":"0a63cd1484bd"}],"_type":"block"},{"_type":"list","_key":"XnLsA-7DhYvwrPHuc3Rvv","type":"Unordered","items":[{"contentPortable":[{"markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"absolute rate","_key":"af0ea19c1ea60"},{"text":": The amount of funding an account will receive by maintaining a 1 contract unit short position for 1 hour. This is more useful for account log purposes.","_key":"af0ea19c1ea61","_type":"span","marks":[]}],"_type":"block","style":"normal","_key":"af0ea19c1ea6"}],"_type":"item","_key":"PuEcyRkyBd_HJRmbQiGIj"},{"_type":"item","_key":"0y0C-89gy9x9Ef3siAbLO","contentPortable":[{"_key":"d17d04a8b4fa","markDefs":[],"children":[{"_key":"d17d04a8b4fa0","_type":"span","marks":["strong"],"text":"absolute funding payout"},{"_type":"span","marks":[],"text":" = # of contracts * absolute funding rate * time elapsed within funding period without position alteration","_key":"d17d04a8b4fa1"}],"_type":"block","style":"normal"}]},{"_type":"item","_key":"UJMRXug8dyGTAqQ3MKk9Q","contentPortable":[{"_type":"block","style":"normal","_key":"776ced08fb79","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"relative rate","_key":"776ced08fb790"},{"_type":"span","marks":[],"text":": The absolute funding rate relative to the spot price at the time of funding rate calculation. This is an intermediate value in the calculation of the absolute funding rate and is the number we display in the front end (as a %) as the 'funding rate'.","_key":"776ced08fb791"}]}]},{"contentPortable":[{"_type":"block","style":"normal","_key":"311eb912fd46","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"relative funding payout","_key":"311eb912fd460"},{"text":" = # of contracts * (relative funding rate*spot price) * time elapsed within funding period without position alteration","_key":"311eb912fd461","_type":"span","marks":[]}]}],"_type":"item","_key":"jNT20uF5jLFrzWySf6hnD"}],"markDefs":null},{"children":[{"_key":"60deb68bcbf2","_type":"span","marks":["strong"],"text":"Funding Rate Examples"}],"_type":"block","style":"h3","_key":"a08dd1e7ec37","markDefs":[]},{"children":[{"_type":"span","marks":[],"text":"In order to get a complete understanding of the funding rate dynamics of the Perpetual Contract, we present examples to demonstrate the key features.","_key":"91a2c9ebebeb"}],"_type":"block","style":"normal","_key":"470dbbcefefb","markDefs":[]},{"items":[{"contentPortable":[{"markDefs":[],"children":[{"_key":"4c42b0de16a2","_type":"span","marks":[],"text":"Assume time is 12 UTC and that the price of BTC is $37,000 (via bitcoin-dollar real-time index) and the Perpetual trades at $37,100 the whole time until 13 UTC. The average premium is computed as 0.27027% for the 1-hour period (100/37,000). This leads to a funding rate of 0.27027 / 24 = 0.01126125% per hour."}],"_type":"block","style":"normal","_key":"ab6c1811a56e"},{"_type":"block","style":"normal","_key":"c90484dfda47","markDefs":[],"children":[{"_type":"span","marks":[],"text":"","_key":"47433efe97e6"}]},{"_key":"fea46fcbd989","markDefs":[],"children":[{"text":"Now assume that you are in a short position of 2 BTC, with 1 BTC perpetual contract valued at $37,100. If you hold this position from 13 to 14 UTC, and the premium in the 13 to 14 UTC period remains as 0.27027%, then you will be paid funding of 8.333325 USD for the one-hour period [(2*37000)*0.0001126125]","_key":"132da406a590","_type":"span","marks":[]}],"_type":"block","style":"normal"}],"_type":"item","_key":"c914afdc8a7c"},{"contentPortable":[{"_key":"c4b26f27c316","markDefs":[],"children":[{"_type":"span","marks":[],"text":"Assume time is 12 UTC and that price of BTC is $37,000 and the Perpetual trades at $39,700 until 13 UTC. The average premium is computed as 7.297297% for the 1-hour period. This leads to a funding rate of 7.297297 / 24 = 0.30405404% per hour.\n ","_key":"a4a4e25426e2"}],"_type":"block","style":"normal"},{"_type":"block","style":"normal","_key":"db837c29d66b","markDefs":[],"children":[{"_type":"span","marks":[],"text":"The maximum funding rate per hour in any given period is 0.25%. The minimum is -0.25%.","_key":"71d7f1626e6f"}]},{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"","_key":"0acdf40dc77a"}],"_type":"block","style":"normal","_key":"780c5f9d7ed9"},{"_key":"5340e70fa75b","markDefs":[],"children":[{"_type":"span","marks":[],"text":"As a result, this 0.30405404% hourly rate is floored to 0.25% per hour, so that the maximum 24 hour realisation will not exceed 6%.\n ","_key":"95b7918b1283"}],"_type":"block","style":"normal"},{"_key":"1c2b0df7d140","markDefs":[],"children":[{"_type":"span","marks":[],"text":"Note that there is no \"dampening\" of rates done in this model: if a 1 hour computed rate is near 0, then it will pay out non-0 value even if it is de minimis.","_key":"cbd62b31aeb5"}],"_type":"block","style":"normal"}],"_type":"item","_key":"65b0958998af"},{"_type":"item","_key":"545311a4e9f7","contentPortable":[{"children":[{"_type":"span","marks":[],"text":"Assume time is 13 UTC and that the index spot price of BTCUSD is $37,000, and the relative rate set for the 1 hour period is 0.05% per hour.\n ","_key":"eee0b82a404d"}],"_type":"block","style":"normal","_key":"5d23a11d9ef6","markDefs":[]},{"_key":"58e6ded54de3","markDefs":[],"children":[{"marks":[],"text":"Now assume the time is 13:30 UTC and the perpetual trades at $38,000 and you enter a Short position of 4 BTC at this price.\n ","_key":"0f448b0a4cf0","_type":"span"}],"_type":"block","style":"normal"},{"_type":"block","style":"normal","_key":"5ed5419d0c81","markDefs":[],"children":[{"_type":"span","marks":[],"text":"You will immediately begin receiving funding at an absolute rate of 0.05%*$37,000 = 18.5 USD per hour per unit.\n","_key":"8d5c3b59bf08"}]},{"_type":"block","style":"normal","_key":"936d575e18af","markDefs":[],"children":[{"_type":"span","marks":[],"text":"In your available balance you will then see this rate applying in your unrealised PnL through continuous funding payout equal to:","_key":"9cf93a9fbc82"}]},{"children":[{"text":"18.5 * 4 BTC = $74 per hour","_key":"400c67d0c40c","_type":"span","marks":["em"]}],"_type":"block","style":"normal","_key":"d1c2ee33d05e","markDefs":[]},{"_type":"block","style":"normal","_key":"77074f30c6e7","markDefs":[],"children":[{"_type":"span","marks":["em"],"text":"$1.233 per minute","_key":"66efe80cf446"}]},{"style":"normal","_key":"1ff4e89eafca","markDefs":[],"children":[{"_type":"span","marks":[],"text":"","_key":"d1fd956f7406"}],"_type":"block"},{"children":[{"_type":"span","marks":[],"text":"This will pay out continuously until 14 UTC where the relative funding rate will change based on the market activity between 13-14 UTC.\n ","_key":"a99dd4184aea"}],"_type":"block","style":"normal","_key":"c39cab537f89","markDefs":[]},{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"In your 4 BTC short position at the end of the half hour period you will have $36.99 applied in your account log at 14 UTC.\n ","_key":"6fd0c65831df"}],"_type":"block","style":"normal","_key":"37ea713cbc7c"},{"markDefs":[],"children":[{"_key":"48b554447bc2","_type":"span","marks":[],"text":"Assume this new relative funding rate is now 0.03% and the real-time spot index is $37,900 for BTCUSD at 14 UTC. \n "}],"_type":"block","style":"normal","_key":"224aa12ed292"},{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"From 14 UTC to 15 UTC a new absolute funding rate will begin applying of 0.03%*$37,900=$11.37 per hour per unit.","_key":"ad8696f0805c"}],"_type":"block","style":"normal","_key":"91b45f527a5c"}]},{"contentPortable":[{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"Assume time is 14 UTC and you enter a position long 2 BTC on BTCUSD at 37,000. Assume that the funding rate for the one-hour period (13-14 UTC) is set as -0.04% per hour.\n ","_key":"056c02ad6945"}],"_type":"block","style":"normal","_key":"1695818d2072"},{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"At 15 UTC, after you have held this position for one full hour, you will have earned $29.6 [(0.0004*2 BTC)*37,000], which credits continuously throughout the hour period you hold it.\n ","_key":"a785ef4c8581"}],"_type":"block","style":"normal","_key":"db75c26179ba"},{"_type":"block","style":"normal","_key":"e11ab4fcc149","markDefs":[],"children":[{"_type":"span","marks":[],"text":"However, during this period, the price was at a premium and so the new one-hour rate set for 14 - 15 UTC is 0.04% per hour. After one hour of holding the position, you have paid $29.6 and you close at 16 UTC.\n ","_key":"59e642715df5"}]},{"_key":"3f488218d8e3","markDefs":[],"children":[{"_key":"12a458a33c05","_type":"span","marks":[],"text":"Your funding for the two hour period you held the position is thus + $29.6 for the first period and then - $29.6 for the first second and your net flows are 0 for this."}],"_type":"block","style":"normal"}],"_type":"item","_key":"9c90d3bfa765"},{"contentPortable":[{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"Assume it's 12 UTC you are in a 5 BTC long position on BTCUSD with spot index at $37,000 and the rate in the funding period is -0.08%. This earns you funding of:ListThis credits and debits every millisecond to every user with an open position. It credits first as unrealised profit and loss, but you have the funds available right away to use in further positions or transfer into your Cash account. The funding is booked into your account log and realised when one of the following events occur:1.You adjust your open position up or down by any amount 2.You hold until the end of the Funding Period, at which point it is booked (occurs at the end of every hour)","_key":"ea5874d1d0790"}],"_type":"block","style":"normal","_key":"9bb5253f93f5"}],"_type":"item","_key":"491d34d83276"},{"contentPortable":[{"markDefs":[],"children":[{"_key":"98079e9aed90","_type":"span","marks":[],"text":"Assume it's 12 UTC you are in a 3 BTC long position on PF_BTCUSD with spot index at $37,000 and the rate in the funding period is -0.05%. Assume that you have set your profit currency as ETH and you hold this position until the end of the funding period at 13 UTC.\n"}],"_type":"block","style":"normal","_key":"324d18981f65"},{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"0.0015*37,000*3 = $55.5 per hour\n","_key":"11f328731ce5"}],"_type":"block","style":"normal","_key":"e37e0e651043"},{"style":"normal","_key":"a34d0d239474","markDefs":[],"children":[{"_type":"span","marks":[],"text":"At the end of the period at 13 UTC, assume that the price of ETH is 2,500 (from the ether-dollar real-time index)\n","_key":"79117433e0d2"}],"_type":"block"},{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"The conversion can be calculated using the following:\n= Amount in USD to be converted / (Target currency index * (1 - 0.25%))\n= 55.5 USD / (2,500 ETHUSD * .9975)\n= 0.022 ETH","_key":"40eb31af0a02"}],"_type":"block","style":"normal","_key":"92664aaaf17e"}],"_type":"item","_key":"7ed8412a0940"}],"_type":"list","_key":"862779283653","type":"Ordered","markDefs":null}],"_type":"item"},{"contentPortable":[{"markDefs":null,"mobileStyle":"summary","_key":"47201c071c5f","rows":[{"cells":[{"contentPortable":[{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"Symbol","_key":"214f6270599d0"}],"_type":"block","style":"normal","_key":"8a44aa471905"}],"_type":"cell","description":"Column ::  Symbol","_key":"7158eba7-9c4c-4cae-8cc9-a413f0a2cb7b"},{"description":"Column :: Active Maturities","_key":"2724073e-4a00-4d97-aeeb-5e4ec84dc8b5","contentPortable":[{"_key":"a0e55bab4209","markDefs":[],"children":[{"text":"Active Maturities","_key":"46cf156d11dd0","_type":"span","marks":[]}],"_type":"block","style":"normal"}],"_type":"cell"},{"description":"Column :: Base Currency","_key":"bd37e947-0d57-4a7b-b5a4-441d90cd6472","contentPortable":[{"style":"normal","_key":"59f2653b6c0d","markDefs":[],"children":[{"text":"Base Currency","_key":"d47112828e6a0","_type":"span","marks":[]}],"_type":"block"}],"_type":"cell"},{"contentPortable":[{"markDefs":[],"children":[{"_key":"b001142bff350","_type":"span","marks":[],"text":"Min Order"}],"_type":"block","style":"normal","_key":"0837a5cf4705"}],"_type":"cell","description":"Column :: Min Order","_key":"3bf68f58-3f61-4076-aa44-2dd5bbdce8c0"},{"description":"Column :: Tick Size","_key":"cc66706a-df03-4803-a562-410e5bf1525a","contentPortable":[{"children":[{"marks":[],"text":"Tick Size","_key":"8cd1b767ec780","_type":"span"}],"_type":"block","style":"normal","_key":"489c766a6e9b","markDefs":[]}],"_type":"cell"},{"description":"Column :: Max Position (Base units)","_key":"186d3835-bff8-4e2a-9e8c-fb1e804ac962","contentPortable":[{"style":"normal","_key":"073dc691dced","markDefs":[],"children":[{"_type":"span","marks":[],"text":"Max Position (Base units)","_key":"ba4665fc48720"}],"_type":"block"}],"_type":"cell"},{"_key":"cf64a531-5598-40df-ba9e-7854d765afb4","contentPortable":[{"style":"normal","_key":"fb8cc527c06f","markDefs":[],"children":[{"_type":"span","marks":[],"text":"Impact Mid","_key":"07de414cf7620"}],"_type":"block"}],"_type":"cell","description":"Column :: Impact Mid"},{"_type":"cell","description":"Column :: Margin Class","_key":"a8c4c52b-37f7-4fa2-8b37-b113e9bdbf38","contentPortable":[{"_type":"block","style":"normal","_key":"e937e71d8f1a","markDefs":[],"children":[{"_key":"67a734d0def90","_type":"span","marks":[],"text":"Margin Class"}]}]},{"description":"Column :: Settlement Index","_key":"0e95bc12-9908-4ccd-8c8f-2cf0d6c41195","contentPortable":[{"style":"normal","_key":"65681b9cdc94","markDefs":[],"children":[{"_type":"span","marks":[],"text":"Settlement Index","_key":"c8cfc9ac08e60"}],"_type":"block"}],"_type":"cell"}],"_type":"row","description":"Row :: Contract specifications","_key":"ef86da75-63c8-432f-85d7-9616e1ade38f"},{"cells":[{"contentPortable":[{"style":"normal","_key":"d4af9462914f","markDefs":[],"children":[{"text":"FF_ETHUSD","_key":"c34bd5506a880","_type":"span","marks":[]}],"_type":"block"}],"_type":"cell","description":"Column ::  Symbol","_key":"48f0a96e-5a8c-40a9-85c7-ee116fce1480"},{"contentPortable":[{"_key":"9deb03922ca5","markDefs":[],"children":[{"_key":"e7d90c1d02c50","_type":"span","marks":[],"text":"Weekly, Monthly, Quarterly, Semiannual"}],"_type":"block","style":"normal"}],"_type":"cell","description":"Column ::  Active Maturities","_key":"20ff68a0-c99d-4c9d-8881-f871c1a1c8ab"},{"description":"Column ::  Base Currency","_key":"3fd79661-f1a7-4ec9-b23c-9739a446f7f3","contentPortable":[{"style":"normal","_key":"7574a27ff23b","markDefs":[],"children":[{"_type":"span","marks":[],"text":"Ethereum (ETH)","_key":"cbee8e0e3e750"}],"_type":"block"}],"_type":"cell"},{"contentPortable":[{"_key":"a3ec5f22e7d9","markDefs":[],"children":[{"_type":"span","marks":[],"text":"0.001","_key":"8dc6938189110"}],"_type":"block","style":"normal"}],"_type":"cell","description":"Column ::  Min Order","_key":"5b3f5841-30a3-460b-a256-0cb5098ac28a"},{"_type":"cell","description":"Column :: Tick Size","_key":"c2a64784-4990-47be-9aae-c9516d819920","contentPortable":[{"_key":"1653e70e9eb7","markDefs":[],"children":[{"marks":[],"text":"0.1","_key":"5a95d3db4dd20","_type":"span"}],"_type":"block","style":"normal"}]},{"description":"Column :: Max Position (Base units)","_key":"3abb60cc-d4b3-4e74-ae4e-f4ea585519f8","contentPortable":[{"_type":"block","style":"normal","_key":"46fde9469801","markDefs":[],"children":[{"_type":"span","marks":[],"text":"8,000","_key":"0b5bfd01817a"}]}],"_type":"cell"},{"_key":"a04e616c-1a60-4c70-89de-b8e85768fc86","contentPortable":[{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"0.35 ETH","_key":"6e0e2acffcba0"}],"_type":"block","style":"normal","_key":"3c06e23efdd3"}],"_type":"cell","description":"Column ::  Impact Mid"},{"contentPortable":[{"markDefs":[],"children":[{"text":"Class A","_key":"6fb3a4996a430","_type":"span","marks":[]}],"_type":"block","style":"normal","_key":"5ddcc6787231"}],"_type":"cell","description":"Column :: Margin Class","_key":"4c20f8f9-abde-43f8-a7bd-2db593ce1321"},{"contentPortable":[{"style":"normal","_key":"facf33d745ff","markDefs":[],"children":[{"_type":"span","marks":[],"text":"ETHOPTRR","_key":"619d150b35ee0"}],"_type":"block"}],"_type":"cell","description":"Column ::  Settlement Index","_key":"7a81913b-338d-4f3c-a553-75ebb54e0736"}],"_type":"row","description":"Row :: FF_ETHUSD","_key":"a28cd4e2-dfd6-4a97-8d16-9a966157a944"},{"_type":"row","description":"Row :: FF_SOLUSD","_key":"4e0e3bfa71a0","cells":[{"contentPortable":[{"style":"normal","_key":"a5261de97a8c","markDefs":[],"children":[{"_type":"span","marks":[],"text":"FF_SOLUSD","_key":"eeb152f84cbb0"}],"_type":"block"}],"_type":"cell","description":"Column :: Symbol","_key":"bb24748c5f51"},{"_key":"0d66f087ac78","contentPortable":[{"_type":"block","style":"normal","_key":"2d3319ef431f","markDefs":[],"children":[{"text":"Monthly, Quarterly","_key":"e46786fe98dd","_type":"span","marks":[]}]}],"_type":"cell","description":"Column :: Active Maturities"},{"contentPortable":[{"markDefs":[],"children":[{"_key":"06836b26b3fe","_type":"span","marks":[],"text":"Solana (SOL)"}],"_type":"block","style":"normal","_key":"eeda3f1633ee"}],"_type":"cell","description":"Column :: Base Currency","_key":"15e1f18c38ba"},{"contentPortable":[{"style":"normal","_key":"20250de4a2cf","markDefs":[],"children":[{"_type":"span","marks":[],"text":"0.01","_key":"d4c4a649721f"}],"_type":"block"}],"_type":"cell","description":"Column :: Min Order","_key":"ebe27c3b2848"},{"contentPortable":[{"_key":"d3a83a252f32","markDefs":[],"children":[{"marks":[],"text":"0.01","_key":"56fd63d198be0","_type":"span"}],"_type":"block","style":"normal"}],"_type":"cell","description":"Column :: Tick Size","_key":"bf72ac238da8"},{"contentPortable":[{"style":"normal","_key":"ac37e2a69483","markDefs":[],"children":[{"text":"80,000","_key":"d8593547ea1d","_type":"span","marks":[]}],"_type":"block"}],"_type":"cell","description":"Column :: Max Position (Base units)","_key":"9f145738359f"},{"contentPortable":[{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"6 SOL","_key":"76bf5f6497aa"}],"_type":"block","style":"normal","_key":"aa0c903e91e4"}],"_type":"cell","description":"Column :: Impact Mid","_key":"eb290bde1a9f"},{"contentPortable":[{"_type":"block","style":"normal","_key":"64735d36c07c","markDefs":[],"children":[{"_key":"9b187274454f","_type":"span","marks":[],"text":"Class B"}]}],"_type":"cell","description":"Column :: Margin Class","_key":"78da83c2bb18"},{"contentPortable":[{"_type":"block","style":"normal","_key":"fb46b9613056","markDefs":[],"children":[{"_type":"span","marks":[],"text":"SOLOPTRR","_key":"0b319a06a5d4"}]}],"_type":"cell","description":"Column :: Settlement Index","_key":"675e5a8f180c"}]},{"_type":"row","description":"Row :: FF_XBTUSD","_key":"e70ab5b6-4dfc-4880-89ee-bcaf6c438283","cells":[{"_key":"ff9aef57-869d-4a4c-96ad-20e15cdbb467","contentPortable":[{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"FF_XBTUSD*","_key":"ed1a1661e0ba0"}],"_type":"block","style":"normal","_key":"18cb287582ed"}],"_type":"cell","description":"Column ::  Symbol"},{"contentPortable":[{"style":"normal","_key":"65c658e8059f","markDefs":[],"children":[{"marks":[],"text":"Weekly, Monthly, Quarterly, Semiannual","_key":"0c6304dd53760","_type":"span"}],"_type":"block"}],"_type":"cell","description":"Column ::  Active Maturities","_key":"79e90752-f2ee-41ba-8b72-426c5975a655"},{"contentPortable":[{"children":[{"marks":[],"text":"Bitcoin (BTC*)","_key":"31d1f0b3c6320","_type":"span"}],"_type":"block","style":"normal","_key":"c419a2cd3676","markDefs":[]}],"_type":"cell","description":"Column :: Base Currency","_key":"ac2648a7-9a38-43e8-b4f3-6b61370bb1f4"},{"_type":"cell","description":"Column :: Min Order","_key":"78e69b40-e861-4032-b4f0-66658c71e92d","contentPortable":[{"children":[{"_type":"span","marks":[],"text":"0.0001","_key":"5d1850e367350"}],"_type":"block","style":"normal","_key":"687b324629d8","markDefs":[]}]},{"contentPortable":[{"markDefs":[],"children":[{"text":"1","_key":"26bc3e6fb413","_type":"span","marks":[]}],"_type":"block","style":"normal","_key":"fdc67caabfea"}],"_type":"cell","description":"Column ::  Tick Size","_key":"b7eab9eb-4f2b-40bf-922c-39af3a63f083"},{"_type":"cell","description":"Column :: Max Position (Base units)","_key":"82ae22cf-f595-4087-9a41-ec7b220d5b1b","contentPortable":[{"_type":"block","style":"normal","_key":"8138988c78b9","markDefs":[],"children":[{"_type":"span","marks":[],"text":"600","_key":"23f4a84217e40"}]}]},{"_type":"cell","description":"Column ::  Impact Mid","_key":"2b7bf711-56dc-466b-8776-5e55bde0ecf7","contentPortable":[{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"0.015 BTC","_key":"6a8c10cd53230"}],"_type":"block","style":"normal","_key":"f37519a5c17e"}]},{"description":"Column ::  Margin Class","_key":"8cbb7ada-bbe1-4b4c-9b08-44378b75674b","contentPortable":[{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"Class A","_key":"1830905a38500"}],"_type":"block","style":"normal","_key":"f55af2eed9fa"}],"_type":"cell"},{"_type":"cell","description":"Column ::  Settlement Index","_key":"ea89c3fa-eece-463c-81ed-574fedf88387","contentPortable":[{"children":[{"_type":"span","marks":[],"text":"BTCOPTRR","_key":"332df86d3ce80"}],"_type":"block","style":"normal","_key":"a42791b4653b","markDefs":[]}]}]}],"_type":"table","expandedTable":true,"description":"Contract specifications"},{"_type":"block","style":"normal","_key":"39e7bc365629","markDefs":[],"children":[{"_type":"span","marks":[],"text":"*BTC is used on the platform UI. XBT is used on the API and account logs. Both refer to Bitcoin (BTC).","_key":"4b6c432007c3"}]},{"children":[{"text":"Additional Information:","_key":"57de539649df","_type":"span","marks":["strong"]}],"_type":"block","style":"h4","_key":"56ecbfe75f9f","markDefs":[]},{"children":[{"_type":"span","marks":["strong"],"text":"PnL Settlement Method \u0026 Collateral Currencies:","_key":"a7bc1636a9ed"},{"_type":"span","marks":[],"text":" Linear Derivatives are settled in USD by default, or your chosen profit currency. See","_key":"741890b2a337"},{"_type":"span","marks":["bc3bb56b5ced"],"text":" Derivatives Collateral Currencies","_key":"2ec30c8fba79"},{"_type":"span","marks":[],"text":" for more information.","_key":"1260bcd1f0dc"}],"_type":"block","style":"blockquote","_key":"da635122036c","markDefs":[{"_type":"externalLink","_key":"bc3bb56b5ced","newTab":true,"url":"https://support.kraken.com/hc/en-us/articles/4843323030164-Futures-Collateral-Currencies"}]},{"style":"normal","_key":"e47a80440da4","markDefs":[],"children":[{"_type":"span","marks":[],"text":"","_key":"7f816eedfb20"}],"_type":"block"},{"style":"blockquote","_key":"af79c41fb8f9","markDefs":[],"children":[{"_key":"caa47457fcc3","_type":"span","marks":["strong"],"text":"Trading Hours: "},{"marks":[],"text":"24 hours/day, 7 days/week, 365 days/year (excluding maintenance)","_key":"996fff2c1593","_type":"span"}],"_type":"block"},{"_key":"97cdaf0e21d6","markDefs":[],"children":[{"marks":[],"text":"","_key":"9c53aadc24bc","_type":"span"}],"_type":"block","style":"normal"},{"_key":"e979ec6eca51","markDefs":[{"_key":"7c4d0a8f9d79","newTab":true,"url":"https://support.kraken.com/hc/en-us/articles/360048917612-Fee-schedule","_type":"externalLink"},{"_type":"externalLink","_key":"6df9a05915f6","newTab":true,"url":"https://support.kraken.com/hc/en-us/articles/4844392809620-Fees-Charges-for-Multi-Collateral-Futures"}],"children":[{"text":"Fee Structure: ","_key":"e3377572f7eb","_type":"span","marks":["strong"]},{"_type":"span","marks":[],"text":"Kraken Derivatives uses a ","_key":"6e5a7231e04f"},{"_type":"span","marks":["7c4d0a8f9d79"],"text":"maker-taker fee structure.","_key":"448181ee71df"},{"marks":[],"text":" Fees are calculated as a percentage of the notional order value for a matched trade. Holding a position until settlement will result in a taker fee. \n\nConversion fees and interest may be applied in some instances. See","_key":"89fbb0f23792","_type":"span"},{"_type":"span","marks":["6df9a05915f6"],"text":" Fees \u0026 Charges for Multi-Collateral Derivatives ","_key":"9523388defc2"},{"text":"for more information.","_key":"39f9340eb9b8","_type":"span","marks":[]}],"_type":"block","style":"blockquote"},{"markDefs":[],"children":[{"text":"","_key":"a0141521fba2","_type":"span","marks":[]}],"_type":"block","style":"normal","_key":"92f00de2d896"},{"_type":"block","style":"blockquote","_key":"c50a78a99e2d","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Settlement Index: ","_key":"358f2efbb97e"},{"_type":"span","marks":[],"text":"The settlement rate is calculated using observations of the underlying Real Time Index over the period of 7:30 UTC to 8:00 UTC on Last Trading day. \nThe methodology is as follows: \n- Take a 30 minute observation window of Real Time Index values before 8 UTC\n- Split the window into 1 minute partitions\n- Compute the average Real Time Index for each minute\n- Compute the average of all 1 minute partitions to obtain the Settlement Rate","_key":"fae178c0dda1"}]},{"markDefs":[],"children":[{"text":"","_key":"3f358f1ec8ea","_type":"span","marks":[]}],"_type":"block","style":"normal","_key":"ba9cc1a8f496"},{"markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Settlement time: ","_key":"8b8e0054ab21"},{"marks":[],"text":"Within 15 minutes after Last Trading","_key":"8e9a1912a4fe","_type":"span"}],"_type":"block","style":"blockquote","_key":"73f4bcd7a719"},{"style":"normal","_key":"1d14dbff9699","markDefs":[],"children":[{"_key":"c789daba3a9a","_type":"span","marks":[],"text":""}],"_type":"block"},{"markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Last Trading: ","_key":"8e139c3b7ab5"},{"marks":[],"text":"08:00 UTC \n\nWeek: Every Friday\n\nMonth: Last Friday of the month.\n\nQuarter: Last Friday of a month in the March quarterly cycle (March, June, September, December).\n\nSemiannual: Last Friday of a month in the March quarterly cycle (March, June, September, December).","_key":"d5976372220c","_type":"span"}],"_type":"block","style":"blockquote","_key":"21fdfe91b23a"},{"style":"normal","_key":"ab32a995b77b","markDefs":[],"children":[{"_type":"span","marks":[],"text":"","_key":"50158e4e06f6"}],"_type":"block"},{"markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"First Trading: ","_key":"a58b165b9624"},{"_type":"span","marks":[],"text":"08:00 UTC.\n\nWeek: Friday of each week where no contract exists in the following week.\n\nMonth: The last Friday of the calendar month where no contract exists in the following calendar month.\n\nQuarter: The last Friday of the calendar month where a contract exists in the following calendar month.\n\nSemiannual: The last Friday of the calendar month where a Month contract and Quarter contract exists.\n\nThe fixed maturity listing schedule results in there always being listed simultaneously at four contracts for BTC and ETH: a Week contract, a Month contract, a Quarter contract, and a Semiannual contract. SOL only has a month and a quarter contract. No contract can have the same remaining days to maturity as another currently-listed contract, therefore at maturity, if the days remaining to maturity on one contract correspond to the maturity of a contract with fewer days to maturity, it will roll into that maturity and the new contract with more days to maturity will be listed.\n\nFor example, if the monthly contract expires on the 31st of May, then the June quarterly contract will become the June monthly contract, the September quarterly contract will be listed.","_key":"a8bcad0058a1"}],"_type":"block","style":"blockquote","_key":"ab12f5a99940"},{"_type":"block","style":"normal","_key":"72d3ea3b1ed2","markDefs":[],"children":[{"marks":[],"text":"","_key":"fae4194e13d7","_type":"span"}]},{"markDefs":[{"_type":"externalLink","_key":"67b933bca3d1","newTab":true,"url":"https://support.kraken.com/hc/en-us/articles/360022632452-Margin-Schedule"}],"children":[{"_type":"span","marks":["strong"],"text":"Initial Margin:","_key":"60008fe7fb75"},{"text":" ","_key":"0d29b4e13dff","_type":"span","marks":[]},{"marks":["67b933bca3d1"],"text":"As low as 2%","_key":"6e53f1b095c3","_type":"span"}],"_type":"block","style":"blockquote","_key":"9ff0bf1c7fbc"},{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"","_key":"f661e5a7c751"}],"_type":"block","style":"normal","_key":"d5a491f06471"},{"style":"blockquote","_key":"fd4e0e6a32ca","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Maintenance Margin: ","_key":"7b0cc17f2abc"},{"_type":"span","marks":[],"text":"Half of Initial Margin","_key":"ef763c59f0f8"}],"_type":"block"},{"_type":"block","style":"normal","_key":"aeadf4237427","markDefs":[],"children":[{"_type":"span","marks":[],"text":"","_key":"1d443d4ea51d"}]},{"_key":"f735423fda50","markDefs":[{"_type":"externalLink","_key":"b3c4dffe9576","newTab":true,"url":"https://support.kraken.com/hc/en-us/articles/360022632452-Margin-Schedule"}],"children":[{"text":"Maximum Initial Leverage:","_key":"62cf3612333c","_type":"span","marks":["strong"]},{"_type":"span","marks":["strong","b3c4dffe9576"],"text":" Up to 50x","_key":"8f1878f4079c"}],"_type":"block","style":"blockquote"},{"style":"normal","_key":"51a14c1c2294","markDefs":[],"children":[{"_type":"span","marks":[],"text":"","_key":"92f81084ff1a"}],"_type":"block"},{"_key":"92b0abace825","markDefs":[],"children":[{"text":"Mark Price:","_key":"97b276edb89f","_type":"span","marks":["strong"]},{"_type":"span","marks":[],"text":" Index Price plus the 30 seconds exponential moving average of the order book mid price minus the index price (future's basis).\n\nThe premium is capped at 1% for contracts with 1 day to expiry and 20% for contracts with 210 days to expiry and is linearly interpolated in between.\n\nCalculation: Index Price + EMA_30seconds(Impact Mid Price - Index Price)\n\nNote: in the extremely rare circumstance that the Index Price is unavailable for whatever reason, the above caps may not apply and the Mark Price will be equal to the Impact Mid Price.","_key":"c844702213e8"}],"_type":"block","style":"blockquote"},{"style":"normal","_key":"22728ae7b0a4","markDefs":[],"children":[{"_type":"span","marks":[],"text":"","_key":"b141ae32a48e"}],"_type":"block"},{"_key":"0e1129c390b1","markDefs":[],"children":[{"_type":"span","marks":[],"text":"","_key":"bc50ec24fd8a"}],"_type":"block","style":"normal"},{"markDefs":[],"children":[{"_type":"span","marks":[],"text":"**Note that if the settlement rate reported by the Index provider is, for any reason, deemed to not adequately represent the underlying market, the Market Risk Committee of Kraken Derivatives reserves the right to select its own appropriate fair value settlement rate. If the index provider restates the price, Kraken Derivatives will settle to the first value published by the index provider at or after publication time.","_key":"b4d9e82e369f"}],"_type":"block","style":"normal","_key":"9136ac486dd5"}],"_type":"item","_key":"fbe5fe8615d3","title":"Fixed Maturity Contract Specifications"}],"markDefs":null},{"markDefs":[{"_type":"externalLink","_key":"43c35597005f","newTab":false,"url":"https://support.kraken.com/hc/en-us/articles/360001169543-Decimal-separators-points-vs-commas"}],"children":[{"_type":"span","marks":[],"text":"The decimal and 