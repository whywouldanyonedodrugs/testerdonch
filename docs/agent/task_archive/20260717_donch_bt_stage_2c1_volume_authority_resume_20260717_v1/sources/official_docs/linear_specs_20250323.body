hildren":[{"_type":"span","marks":[],"text":"Margin Category details available on "},{"_type":"span","marks":["d44ace80d207e"],"text":"Margin schedule and Maximum Leverage"},{"_type":"span","marks":[],"text":"."}],"_key":"9viFZ71Qzk5SgWoLxTP-K"},{"_type":"block","markDefs":[{"_key":"86c3fb338c2f5","newTab":true,"referenceArticle":{"url":{"current":"13049711807636-Futures-Platform-Parameters-Changelog","_type":"slug"}},"_type":"articleLink"}],"style":"normal","children":[{"_type":"span","marks":[],"text":"Contract specification changes available on our "},{"_type":"span","marks":["86c3fb338c2f5"],"text":"Derivatives Platform Parameters Changelog"},{"_type":"span","marks":[],"text":"."}],"_key":"UbTLs60DjmT62jNIuDFNJ"}]},{"_type":"item","_key":"AcEWbN5YEbWZzXt5uFuVi","title":"Perpetual Contract Funding Rate Information","contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Perpetual Derivatives are a type of Derivatives contract that have "},{"_type":"span","marks":["strong"],"text":"no expiration date"},{"_type":"span","marks":[],"text":" and an "},{"_type":"span","marks":["strong"],"text":"auto-rolling"},{"_type":"span","marks":[],"text":" feature "},{"_type":"span","marks":["strong"],"text":"every hour"},{"_type":"span","marks":[],"text":". "}],"_key":"w30PGWT0eK1JC7wM2-xRp"},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Perpetual contracts feature a funding rate, a payment between traders designed to keep the contract's price aligned with the underlying asset's spot price. "}],"_key":"C_3s0wTQbXEhaBSyQPL64"},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"If the funding rate is positive, long positions pay short positions; if negative, short positions pay long positions. "}],"_key":"QqHjo6NWGSlGhssDs2inz"},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Traders may pay or receive funding dependent on market conditions. The price difference is calculated hourly, with funding adjustments reflected as unrealized profit or loss, settling at the end of each hour or when the net position changes."}],"_key":"q97gkG00KNCefVnHpX572"},{"_type":"table","style":"normal","rows":[{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Additional Information"}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Auto-Roll Period"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Every 1 hour at the end of the hour"}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Rate-setting Calculation Window"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Rate for next period is calculated over current 1-hour period (e.g., rate for 12-13 UTC period is calculated in window between 11-12 UTC)"}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Funding Rate"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Between start and end of the "},{"_type":"span","marks":["strong"],"text":"Rate-setting Period"},{"_type":"span","marks":[],"text":" the "},{"_type":"span","marks":["strong"],"text":"Funding Rate"},{"_type":"span","marks":[],"text":" is computed as the time-weighted average premium, and standardised to a per-hour basis. Permissible range per 1 hours: [-0.25%, +0.25%]*** (i.e., 600 basis point magnitude for 24-hour realisation period)"}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Payout Frequency"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Continuously based on "},{"_type":"span","marks":["strong"],"text":"Funding Rate"},{"_type":"span","marks":[],"text":" set at the end of the prior "},{"_type":"span","marks":["strong"],"text":"Funding Period"},{"_type":"span","marks":[],"text":". Positions will immediately and continuously receive or send funding while open in the perpetual contracts. The funding accumulates as unrealised profit/loss and settles every 1 hour at end of the "},{"_type":"span","marks":["strong"],"text":"Funding Period"},{"_type":"span","marks":[],"text":", or when user changes net open position (whichever occurs first)."}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Funding Rate Multiplier"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"n = 24 This is the coefficient used in the calculation of the funding rate. A value of 1/n means that, ceteris paribus, it will take n hours to realise the "},{"_type":"span","marks":["strong"],"text":"Average Premium"},{"_type":"span","marks":[],"text":". "},{"_type":"span","marks":["strong"],"text":"Example"},{"_type":"span","marks":[],"text":": if the "},{"_type":"span","marks":["strong"],"text":"Average Premium"},{"_type":"span","marks":[],"text":" is 0.36% for the 1-hour period, then Funding Rate is equal to 0.015%, meaning that over the course of 24 hours, this 0.36% total will be realised."}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Funding Rate Calculation"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"In a given 1-hour Funding Period, "},{"_type":"span","marks":["strong"],"text":"Premium"},{"_type":"span","marks":[],"text":" values calculated from minutely perpetual contract prices (60 observations) using an "},{"_type":"span","marks":["strong"],"text":"Impact Mid"},{"_type":"span","marks":[],"text":" are recorded versus the "},{"_type":"span","marks":["strong"],"text":"Real Time Platform Ticker"},{"_type":"span","marks":[],"text":". The "},{"_type":"span","marks":["strong"],"text":"Impact Mid"},{"_type":"span","marks":[],"text":" is the median of the average entry price market-selling x value of contracts and market-buying x value of contracts. See table above for contract-specific values. The "},{"_type":"span","marks":["strong"],"text":"Average Premium"},{"_type":"span","marks":[],"text":" is calculated as the average of the mid 30 values recorded from the above 60 observations. Finally, this value is weighted by the "},{"_type":"span","marks":["strong"],"text":"Funding Rate Multiplier"},{"_type":"span","marks":[],"text":". If "},{"_type":"span","marks":["strong"],"text":"Average Premium"},{"_type":"span","marks":[],"text":" is greater than 0 for the 1 hour period, those in Long positions will continuously pay out to Short positions, which pushes the price closer to Index. If "},{"_type":"span","marks":["strong"],"text":"Average Premium"},{"_type":"span","marks":[],"text":" is less than 0 for the 1 hour period, those in Short positions will continuously pay out to Long positions, which pushes the price closer to Index."}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Trading Hours"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[{"_type":"externalLink","_key":"728cdda4104a4","newTab":false,"url":"https://support.kraken.com/hc/en-us/articles/360022837571-Platform-outage-options"}],"style":"normal","children":[{"_type":"span","marks":[],"text":"24 hours/day, 7 days/week, 365 days/year (excluding "},{"_type":"span","marks":["728cdda4104a4"],"text":"maintenance"},{"_type":"span","marks":[],"text":")"}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"P\u0026L Settlement Method"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[{"_type":"externalLink","_key":"444edef18f1d9","newTab":false,"url":"https://support.kraken.com/hc/en-us/articles/4843323030164-Futures-Collateral-Currencies"}],"style":"normal","children":[{"_type":"span","marks":[],"text":"Cash settled in USD with optional payout in any of the "},{"_type":"span","marks":["444edef18f1d9"],"text":"collateral currencies"},{"_type":"span","marks":[],"text":" (profit only, losses are always realised in USD)"}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Fee Structure"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[{"newTab":false,"url":"https://support.kraken.com/hc/en-us/articles/360048917612-Fee-schedule","_type":"externalLink","_key":"314a143bd81f1"}],"style":"normal","children":[{"_type":"span","marks":[],"text":"Kraken Derivatives uses a maker-taker "},{"_type":"span","marks":["314a143bd81f1"],"text":"fee structure"},{"_type":"span","marks":[],"text":". Fees are calculated as a percentage of the notional order value for a matched trade. No fees are charged on auto-roll or funding payouts -- these occur strictly between counter-parties."}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Contract Expiration"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"The perpetual derivatives are non-expiring, which means that positions in the contract are never “expired” or “matured”, however there is a settlement process every hour that applies funding to anchor the spot value to the Index. See "},{"_type":"span","marks":["strong"],"text":"Last Trading"},{"_type":"span","marks":[],"text":" for more information."}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Settlement time"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Every 1 hour at the end of the hour: The accumulated unrealised funding is settled and new rate set based on TWAP premium to index in prior rate period."}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Last Trading"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"This contract remains trading perpetually and would only expire in an emergency situation if Kraken Derivatives deems necessary to settle/expire the contract. Kraken Derivatives reserve the right to set any contract to post-only, suspended, or settle any contract at any time and without warning due to either adverse market conditions or regulatory risk. "}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Initial Margin"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[{"_type":"externalLink","_key":"c20b53a7da291","newTab":false,"url":"https://support.kraken.com/hc/en-us/articles/360022632452-Margin-Schedule"}],"style":"normal","children":[{"_type":"span","marks":["c20b53a7da291"],"text":"As low as 2%"}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Maintenance Margin"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Half of Initial Margin"}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Maximum Initial Leverage"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[{"_key":"aac8e9811fc64","newTab":false,"url":"https://support.kraken.com/hc/en-us/articles/360022632452-Margin-Schedule","_type":"externalLink"}],"style":"normal","children":[{"_type":"span","marks":["aac8e9811fc64"],"text":"Up to 50x"}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Mark Price"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Index Price plus the 30 seconds exponential moving average of the order book mid price minus the index price (future's basis). The premium for perpetual contracts is capped at 1%. Calculation: Index Price + EMA_30seconds(Impact Mid Price - Index Price) "},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":" "},{"_type":"span","marks":["strong"],"text":"Note"},{"_type":"span","marks":[],"text":": in the extremely rare circumstance that the Index Price is unavailable for whatever reason, the above caps may not apply and the Mark Price will be equal to the Impact Mid Price."}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"Margin \u0026 Settlement Currency"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[{"_type":"externalLink","_key":"a710d21486850","newTab":true,"url":"https://support.kraken.com/hc/articles/4843323030164"}],"style":"normal","children":[{"_type":"span","marks":[],"text":"USD, but with full collateral options of BTC, ETH, ADA, DOT, LTC, SOL, XRP, USDT, USDC, EUR, and GBP, adjusted for haircut (see "},{"_type":"span","marks":["a710d21486850"],"text":"Derivatives Collateral Currencies"},{"_type":"span","marks":[],"text":")"}]}],"type":"cell"}]}],"mobileStyle":"summary","expandedTable":false,"_key":"NYnJpp6FP9hIRoR2yn5tI"},{"_type":"block","markDefs":[],"style":"h4","children":[{"_type":"span","marks":[],"text":"The funding rate for a given perpetual contract is represented in two different ways:"}],"_key":"RE5FmVi6ntQRV2xpAab8I"},{"_type":"list","style":"normal","type":"Unordered","items":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"absolute rate"},{"_type":"span","marks":[],"text":": The amount of funding an account will receive by maintaining a 1 contract unit short position for 1 hour. This is more useful for account log purposes."}]}],"_type":"item"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"absolute funding payout"},{"_type":"span","marks":[],"text":" = # of contracts * absolute funding rate * time elapsed within funding period without position alteration"}]}],"_type":"item"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"relative rate"},{"_type":"span","marks":[],"text":": The absolute funding rate relative to the spot price at the time of funding rate calculation. This is an intermediate value in the calculation of the absolute funding rate and is the number we display in the front end (as a %) as the 'funding rate'."}]}],"_type":"item"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["strong"],"text":"relative funding payout"},{"_type":"span","marks":[],"text":" = # of contracts * (relative funding rate*spot price) * time elapsed within funding period without position alteration"}]}],"_type":"item"}],"_key":"y6TSiYWXjZNskZVj2F1qr"},{"_type":"block","markDefs":[],"style":"h3","children":[{"_type":"span","marks":["strong"],"text":"Funding Rate Examples"}],"_key":"WVp6_ue5ClJmVwpkyt1dN"},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"In order to get a complete understanding of the funding rate dynamics of the Perpetual Contract, we present examples to demonstrate the key features."}],"_key":"TkajncD_VDGa14kHGB1ZC"},{"_type":"list","style":"normal","type":"Ordered","items":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Assume time is 12 UTC and that the price of BTC is $37,000 (via bitcoin-dollar real-time index) and the Perpetual trades at $37,100 the whole time until 13 UTC. The average premium is computed as 0.27027% for the 1-hour period (100/37,000). This leads to a funding rate of 0.27027 / 24 = 0.01126125% per hour."}]},{"_type":"block","markDefs":[],"style":"normal","children":[]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Now assume that you are in a short position of 2 BTC, with 1 BTC perpetual contract valued at $37,100. If you hold this position from 13 to 14 UTC, and the premium in the 13 to 14 UTC period remains as 0.27027%, then you will be paid funding of 8.333325 USD for the one-hour period [(2*37000)*0.0001126125]"}]}],"_type":"item"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Assume time is 12 UTC and that price of BTC is $37,000 and the Perpetual trades at $39,700 until 13 UTC. The average premium is computed as 7.297297% for the 1-hour period. This leads to a funding rate of 7.297297 / 24 = 0.30405404% per hour."},{"_type":"span","marks":[],"text":"\n"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"The maximum funding rate per hour in any given period is 0.25%. The minimum is -0.25%."}]},{"_type":"block","markDefs":[],"style":"normal","children":[]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"As a result, this 0.30405404% hourly rate is floored to 0.25% per hour, so that the maximum 24 hour realisation will not exceed 6%."},{"_type":"span","marks":[],"text":"\n"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Note that there is no \"dampening\" of rates done in this model: if a 1 hour computed rate is near 0, then it will pay out non-0 value even if it is de minimis."}]}],"_type":"item"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Assume time is 13 UTC and that the index spot price of BTCUSD is $37,000, and the relative rate set for the 1 hour period is 0.05% per hour."},{"_type":"span","marks":[],"text":"\n"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Now assume the time is 13:30 UTC and the perpetual trades at $38,000 and you enter a Short position of 4 BTC at this price."},{"_type":"span","marks":[],"text":"\n"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"You will immediately begin receiving funding at an absolute rate of 0.05%*$37,000 = 18.5 USD per hour per unit."},{"_type":"span","marks":[],"text":"\n"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"In your available balance you will then see this rate applying in your unrealised PnL through continuous funding payout equal to:"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["em"],"text":"18.5 * 4 BTC = $74 per hour"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":["em"],"text":"$1.233 per minute"}]},{"_type":"block","markDefs":[],"style":"normal","children":[]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"This will pay out continuously until 14 UTC where the relative funding rate will change based on the market activity between 13-14 UTC."},{"_type":"span","marks":[],"text":"\n"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"In your 4 BTC short position at the end of the half hour period you will have $36.99 applied in your account log at 14 UTC."},{"_type":"span","marks":[],"text":"\n"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Assume this new relative funding rate is now 0.03% and the real-time spot index is $37,900 for BTCUSD at 14 UTC. "},{"_type":"span","marks":[],"text":"\n"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"From 14 UTC to 15 UTC a new absolute funding rate will begin applying of 0.03%*$37,900=$11.37 per hour per unit."}]}],"_type":"item"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Assume time is 14 UTC and you enter a position long 2 BTC on BTCUSD at 37,000. Assume that the funding rate for the one-hour period (13-14 UTC) is set as -0.04% per hour."},{"_type":"span","marks":[],"text":"\n"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"At 15 UTC, after you have held this position for one full hour, you will have earned $29.6 [(0.0004*2 BTC)*37,000], which credits continuously throughout the hour period you hold it."},{"_type":"span","marks":[],"text":"\n"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"However, during this period, the price was at a premium and so the new one-hour rate set for 14 - 15 UTC is 0.04% per hour. After one hour of holding the position, you have paid $29.6 and you close at 16 UTC."},{"_type":"span","marks":[],"text":"\n"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Your funding for the two hour period you held the position is thus + $29.6 for the first period and then - $29.6 for the first second and your net flows are 0 for this."}]}],"_type":"item"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Assume it's 12 UTC you are in a 5 BTC long position on BTCUSD with spot index at $37,000 and the rate in the funding period is -0.08%. This earns you funding of:ListThis credits and debits every millisecond to every user with an open position. It credits first as unrealised profit and loss, but you have the funds available right away to use in further positions or transfer into your Cash account. The funding is booked into your account log and realised when one of the following events occur:1.You adjust your open position up or down by any amount 2.You hold until the end of the Funding Period, at which point it is booked (occurs at the end of every hour)"}]}],"_type":"item"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Assume it's 12 UTC you are in a 3 BTC long position on PF_BTCUSD with spot index at $37,000 and the rate in the funding period is -0.05%. Assume that you have set your profit currency as ETH and you hold this position until the end of the funding period at 13 UTC."},{"_type":"span","marks":[],"text":"\n"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"0.0015*37,000*3 = $55.5 per hour"},{"_type":"span","marks":[],"text":"\n"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"At the end of the period at 13 UTC, assume that the price of ETH is 2,500 (from the ether-dollar real-time index)"},{"_type":"span","marks":[],"text":"\n"}]},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"The conversion can be calculated using the following:"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"= Amount in USD to be converted / (Target currency index * (1 - 0.25%))"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"= 55.5 USD / (2,500 ETHUSD * .9975)"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"= 0.022 ETH"}]}],"_type":"item"}],"_key":"8K0GseS2zPyWddJeMWZS4"}]},{"_type":"item","_key":"fbe5fe8615d3","title":"Fixed Maturity Contract Specifications","contentPortable":[{"_type":"table","style":"normal","rows":[{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Symbol"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Active Maturities"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Base Currency"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Min Order"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Tick Size"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Max Position (Base units)"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Impact Mid"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Margin Class"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Settlement Index"}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"FF_ETHUSD"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Weekly, Monthly, Quarterly, Semiannual"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Ethereum (ETH)"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"0.001"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"0.1"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"8,000"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"0.35 ETH"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Class A"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"ETHOPTRR"}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"FF_SOLUSD"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Monthly, Quarterly"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Solana (SOL)"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"0.01"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"0.01"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"80,000"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"6 SOL"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Class B"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"SOLOPTRR"}]}],"type":"cell"}]},{"_type":"row","cells":[{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"FF_XBTUSD*"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Weekly, Monthly, Quarterly, Semiannual"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Bitcoin (BTC*)"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"0.0001"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"1"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"600"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"0.015 BTC"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"Class A"}]}],"type":"cell"},{"contentPortable":[{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"BTCOPTRR"}]}],"type":"cell"}]}],"mobileStyle":"summary","expandedTable":true,"_key":"Pzm8I90ickTxa2P6KkcQa"},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"*BTC is used on the platform UI. XBT is used on the API and account logs. Both refer to Bitcoin (BTC)."}],"_key":"_tLrQ3a1TZgd_ps8umL15"},{"_type":"block","markDefs":[],"style":"h4","children":[{"_type":"span","marks":["strong"],"text":"Additional Information:"}],"_key":"K4KnvUeXu27RCQVBrBTui"},{"_type":"block","style":"blockquote","markDefs":[{"_type":"externalLink","_key":"b1fffec4260c6","newTab":true,"url":"https://support.kraken.com/hc/en-us/articles/4843323030164-Futures-Collateral-Currencies"}],"children":[{"_type":"span","marks":["strong"],"text":"PnL Settlement Method \u0026 Collateral Currencies:"},{"_type":"span","marks":[],"text":" Linear Derivatives are settled in USD by default, or your chosen profit currency. See"},{"_type":"span","marks":["b1fffec4260c6"],"text":" Derivatives Collateral Currencies"},{"_type":"span","marks":[],"text":" for more information."}],"_key":"QFVJRwvk0iaMeLcRAF2uu"},{"_type":"block","markDefs":[],"style":"normal","children":[],"_key":"DxAoTa5DX-3xw8vOmw_86"},{"_type":"block","style":"blockquote","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Trading Hours: "},{"_type":"span","marks":[],"text":"24 hours/day, 7 days/week, 365 days/year (excluding maintenance)"}],"_key":"Vv-h5-C3HhTpbXHS_4FQc"},{"_type":"block","markDefs":[],"style":"normal","children":[],"_key":"lMBnuwptdjqkhWgtQUGbH"},{"_type":"block","style":"blockquote","markDefs":[{"_key":"854040da2e882","newTab":true,"url":"https://support.kraken.com/hc/en-us/articles/360048917612-Fee-schedule","_type":"externalLink"}],"children":[{"_type":"span","marks":["strong"],"text":"Fee Structure: "},{"_type":"span","marks":[],"text":"Kraken Derivatives uses a "},{"_type":"span","marks":["854040da2e882"],"text":"maker-taker fee structure."},{"_type":"span","marks":[],"text":" Fees are calculated as a percentage of the notional order value for a matched trade. Holding a position until settlement will result in a taker fee. "},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"Conversion fees and interest may be applied in some instances. See"},{"_type":"span","marks":["e0f852d9ea784"],"text":" Fees \u0026 Charges for Multi-Collateral Derivatives "},{"_type":"span","marks":[],"text":"for more information."}],"_key":"Td6XSzMlCGMo8R1oT3ajI"},{"_type":"block","markDefs":[],"style":"normal","children":[],"_key":"-6WmGsh3NzK5QiHvl9iFI"},{"_type":"block","style":"blockquote","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Settlement Index: "},{"_type":"span","marks":[],"text":"The settlement rate is calculated using observations of the underlying Real Time Index over the period of 7:30 UTC to 8:00 UTC on Last Trading day. "},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"The methodology is as follows: "},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"- Take a 30 minute observation window of Real Time Index values before 8 UTC"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"- Split the window into 1 minute partitions"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"- Compute the average Real Time Index for each minute"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"- Compute the average of all 1 minute partitions to obtain the Settlement Rate"}],"_key":"wUk8z_YVJVt8LvyCnELK0"},{"_type":"block","markDefs":[],"style":"normal","children":[],"_key":"qTJR_jZ95XFo7-UA342eu"},{"_type":"block","style":"blockquote","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Settlement time: "},{"_type":"span","marks":[],"text":"Within 15 minutes after Last Trading"}],"_key":"dscAHYvAC_d4f0k73vXBi"},{"_type":"block","markDefs":[],"style":"normal","children":[],"_key":"oCjexaxMDVDWHvTCpFjQn"},{"_type":"block","style":"blockquote","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Last Trading: "},{"_type":"span","marks":[],"text":"08:00 UTC "},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"Week: Every Friday"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"Month: Last Friday of the month."},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"Quarter: Last Friday of a month in the March quarterly cycle (March, June, September, December)."},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"Semiannual: Last Friday of a month in the March quarterly cycle (March, June, September, December)."}],"_key":"VkPuJqJVJStZD-cRr-S8O"},{"_type":"block","markDefs":[],"style":"normal","children":[],"_key":"SvWhmAuE4WLJGuNXFm4EX"},{"_type":"block","style":"blockquote","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"First Trading: "},{"_type":"span","marks":[],"text":"08:00 UTC."},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"Week: Friday of each week where no contract exists in the following week."},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"Month: The last Friday of the calendar month where no contract exists in the following calendar month."},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"Quarter: The last Friday of the calendar month where a contract exists in the following calendar month."},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"Semiannual: The last Friday of the calendar month where a Month contract and Quarter contract exists."},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"The fixed maturity listing schedule results in there always being listed simultaneously at four contracts for BTC and ETH: a Week contract, a Month contract, a Quarter contract, and a Semiannual contract. SOL only has a month and a quarter contract. No contract can have the same remaining days to maturity as another currently-listed contract, therefore at maturity, if the days remaining to maturity on one contract correspond to the maturity of a contract with fewer days to maturity, it will roll into that maturity and the new contract with more days to maturity will be listed."},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"For example, if the monthly contract expires on the 31st of May, then the June quarterly contract will become the June monthly contract, the September quarterly contract will be listed."}],"_key":"Yhm6zJa8QrDxeqVIihIrP"},{"_type":"block","markDefs":[],"style":"normal","children":[],"_key":"kx7CIVNF_cYeR2Bp1Rvvl"},{"_type":"block","style":"blockquote","markDefs":[{"_type":"externalLink","_key":"9c032755c434d","newTab":true,"url":"https://support.kraken.com/hc/en-us/articles/360022632452-Margin-Schedule"}],"children":[{"_type":"span","marks":["strong"],"text":"Initial Margin:"},{"_type":"span","marks":[],"text":" "},{"_type":"span","marks":["9c032755c434d"],"text":"As low as 2%"}],"_key":"GJt-walXpi3dDF0j7vyR-"},{"_type":"block","markDefs":[],"style":"normal","children":[],"_key":"y0NE0Py3cGpvEaxgN46AY"},{"_type":"block","style":"blockquote","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Maintenance Margin: "},{"_type":"span","marks":[],"text":"Half of Initial Margin"}],"_key":"TRHQW0YX5CielAvQ9Ts6I"},{"_type":"block","markDefs":[],"style":"normal","children":[],"_key":"CWr6VwkiyAOJxclCd-MWn"},{"_type":"block","style":"blockquote","markDefs":[{"_type":"externalLink","_key":"7fae7002f25a2","newTab":true,"url":"https://support.kraken.com/hc/en-us/articles/360022632452-Margin-Schedule"}],"children":[{"_type":"span","marks":["strong"],"text":"Maximum Initial Leverage:"},{"_type":"span","marks":["strong","7fae7002f25a2"],"text":" Up to 50x"}],"_key":"Nnm0O0AOySOdRRGWPsJKJ"},{"_type":"block","markDefs":[],"style":"normal","children":[],"_key":"5e9xgSyRqiVRL2w7Z1im0"},{"_type":"block","style":"blockquote","markDefs":[],"children":[{"_type":"span","marks":["strong"],"text":"Mark Price:"},{"_type":"span","marks":[],"text":" Index Price plus the 30 seconds exponential moving average of the order book mid price minus the index price (future's basis)."},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"The premium is capped at 1% for contracts with 1 day to expiry and 20% for contracts with 210 days to expiry and is linearly interpolated in between."},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"Calculation: Index Price + EMA_30seconds(Impact Mid Price - Index Price)"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"\n"},{"_type":"span","marks":[],"text":"Note: in the extremely rare circumstance that the Index Price is unavailable for whatever reason, the above caps may not apply and the Mark Price will be equal to the Impact Mid Price."}],"_key":"zxxuN0e1D6EQiQ-Owzz65"},{"_type":"block","markDefs":[],"style":"normal","children":[],"_key":"ZmdJOLqZ_mKi4_7Pd9BDc"},{"_type":"block","markDefs":[],"style":"normal","children":[],"_key":"u10wIsg9LPppeuxGVOGdH"},{"_type":"block","markDefs":[],"style":"normal","children":[{"_type":"span","marks":[],"text":"**Note that if the settlement rate reported by the Index provider is, for any reason, deemed to not adequately represent the underlying market, the Market Risk Committee of Kraken Derivatives reserves the right to select its own appropriate fair value settlement rate. If the index provider restates the price, Kraken Derivatives will settle to the first value published by the index provider at or after publication time."}],"_key":"ltjPyHciGgrTRk_E64MHQ"}]}],"_key":"e10b537ef65c0"},{"_key":"351a5051140f","children":[{"_type":"span","marks":[],"text":"The decimal and thousands separators shown in this article may differ from the formats displayed on our trading platforms. Review our article on how we use ","_key":"351a5051140f0"},{"_type":"span","marks":["d4f49d661b888"],"text":"points and commas","_key":"351a5051140f1"},{"_type":"span","marks":[],"text":" for more information.","_key":"351a5051140f2"}],"markDefs":[{"_key":"d4f49d661b888","_type":"externalLink","url":"https://support.kraken.com/hc/en-us/articles/360001169543-Decimal-separators-points-vs-commas","newTab":false}],"_type":"block","style":"normal"},{"_key":"4d9af487c059","children":[{"_type":"span","_key":"4d9af487c0590","text":"","marks":[]}],"markDefs":[],"_type":"block","style":"normal"},{"_key":"1e8b07a480a4","children":[{"_type":"span","marks":[],"text":"Last updated: 14 March, 2025","_key":"1e8b07a480a40"}],"markDefs":[],"_type":"block","style":"normal"}]},"query":"*[(_type == '