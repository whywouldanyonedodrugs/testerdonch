 latency.\n- FIX clients will experience several seconds of continuously rejected orders/order modifications, and an increase in latency.\n\nTrading remains available throughout. Thank you for your patience.","incident_id":"382k8kn5wfj8","created_at":"2026-06-19T01:35:06.822Z","updated_at":"2026-06-19T05:43:43.921Z","display_at":"2026-06-19T01:35:06.822Z","affected_components":[{"code":"mhcnmhlldpkh","name":"Website","old_status":"operational","new_status":"operational"},{"code":"lrx5gjxzw65q","name":"Kraken Pro App","old_status":"operational","new_status":"operational"}],"deliver_notifications":true,"custom_tweet":null,"tweet_id":null}],"components":[{"id":"pwc5xxqb9057","name":"FIX","status":"operational","created_at":"2024-01-24T10:12:01.342Z","updated_at":"2026-07-13T07:06:26.052Z","position":1,"description":null,"showcase":false,"start_date":"2024-01-24","group_id":"qkyy5vkk5zpx","page_id":"lfz25gyhcpjf","group":false,"only_show_if_degraded":false},{"id":"vz83fx0396f0","name":"Websocket","status":"operational","created_at":"2019-01-30T18:03:03.406Z","updated_at":"2026-07-13T07:06:26.093Z","position":3,"description":null,"showcase":false,"start_date":null,"group_id":"qkyy5vkk5zpx","page_id":"lfz25gyhcpjf","group":false,"only_show_if_degraded":false}],"scheduled_for":"2026-06-23T10:30:00.000Z","scheduled_until":"2026-06-23T11:30:00.000Z"},{"id":"htkj42rkdrsd","name":"Derivatives Platform Maintenance","status":"completed","created_at":"2026-06-19T13:34:20.222Z","updated_at":"2026-06-22T10:10:25.675Z","monitoring_at":"2026-06-22T10:05:36.932Z","resolved_at":"2026-06-22T10:10:25.643Z","impact":"maintenance","shortlink":"https://stspg.io/917zw69qgt9n","started_at":"2026-06-19T13:34:20.190Z","page_id":"lfz25gyhcpjf","incident_updates":[{"id":"k0sjc9j9fb96","status":"completed","body":"The platform is back online and post-only has been removed.","incident_id":"htkj42rkdrsd","created_at":"2026-06-22T10:10:25.643Z","updated_at":"2026-06-22T10:10:25.643Z","display_at":"20