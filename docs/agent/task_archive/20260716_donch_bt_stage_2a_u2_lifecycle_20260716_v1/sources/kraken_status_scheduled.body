{"page":{"id":"lfz25gyhcpjf","name":"Kraken","url":"https://status.kraken.com","time_zone":"Etc/UTC","updated_at":"2026-07-16T19:49:41.941Z"},"scheduled_maintenances":[{"id":"yshk4vtwcyg2","name":"Rain (RAIN) Delisting","status":"scheduled","created_at":"2026-06-03T16:18:28.445Z","updated_at":"2026-06-03T16:18:28.618Z","monitoring_at":null,"resolved_at":null,"impact":"maintenance","shortlink":"https://stspg.io/gl5x1ff2lcsx","started_at":"2026-06-03T16:18:28.423Z","page_id":"lfz25gyhcpjf","incident_updates":[{"id":"m7nrd9bxtr5l","status":"scheduled","body":"As part of our regular asset reviews, Kraken will begin a scheduled delisting cycle for RAIN.\n\nKey dates:\n\n- June 17 at 14:00 UTC: Deposits and trading will be disabled\n- September 15 at 14:00 UTC: Withdrawals will be disabled\n- September 15 to September 25: Any remaining balances will be liquidated\n\nWithdrawals will remain available until September 15 at 13:59 UTC. Review your portfolio and take any necessary action before this deadline.\n\nDepending on market conditions at the time of liquidation, prices may be significantly below recent reference prices and, in some cases, may result in minimal or no proceeds due to insufficient market liquidity at the time of execution.\n\nThe denomination of liquidation proceeds is determined by prevailing market conditions and cannot be guaranteed or confirmed prior to execution.","incident_id":"yshk4vtwcyg2","created_at":"2026-06-03T16:18:28.608Z","updated_at":"2026-06-03T16:18:28.608Z","display_at":"2026-06-03T16:18:28.608Z","affected_components":[{"code":"1lzgkynv6t8m","name":"Digital Currency Funding - Rain (RAIN) - Arbitrum One","old_status":"operational","new_status":"operational"}],"deliver_notifications":true,"custom_tweet":null,"tweet_id":null}],"components":[{"id":"1lzgkynv6t8m","name":"Rain (RAIN) - Arbitrum One","status":"operational","created_at":"2026-02-11T11:31:27.801Z","updated_at":"2026-07-16T08:21:45.317Z","position":472,"description":null,"showcase":false,"start_date":"2026-02-11","group_id":"8nh7rvvs6mjh","page_id":"lfz25gyhcpjf","group":false,"only_show_if_degraded":false}],"scheduled_for":"2026-09-25T23:00:00.000Z","scheduled_until":"2026-09-26T00:00:00.000Z"},{"id":"wktgpx1dc3jk","name":"Delisting assets for UAE clients","status":"scheduled","created_at":"2026-06-01T13:56:05.908Z","updated_at":"2026-06-01T13:56:06.004Z","monitoring_at":null,"resolved_at":null,"impact":"maintenance","shortlink":"https://stspg.io/wljtszr36qf3","started_at":"2026-06-01T13:56:05.902Z","page_id":"lfz25gyhcpjf","incident_updates":[{"id":"kh9ky2t431z3","status":"scheduled","body":"As part of our regular asset reviews, Kraken will begin a scheduled delisting cycle for the following assets in the United Arab Emirates: XMR, ZEC, DASH, USDD, DAI, USDS, and USDE. Please check email communication for further details.\n\nKey dates (all times UTC):\nJune 15 at 14:00 UTC: Open margin positions will be closed\nJune 16 at 14:00 UTC: Deposits, trading, and margin will be disabled\nSeptember 14 at 14:00 UTC: Withdrawals will be disabled\nSeptember 15 to September 25: Any remaining balances will be liquidated\n\nWithdrawals will remain available until September 14 at 13:59 UTC. Review your portfolio and take any necessary action before this deadline.\n\nThe denomination of liquidation proceeds is determined by prevailing market conditions and cannot be guaranteed or confirmed prior to execution.","incident_id":"wktgpx1dc3jk","created_at":"2026-06-01T13:56:06.001Z","updated_at":"2026-06-01T13:56:06.001Z","display_at":"2026-06-01T13:56:06.001Z","affected_components":null,"deliver_notifications":false,"custom_tweet":null,"tweet_id":null}],"components":[],"scheduled_for":"2026-09-25T12:00:00.000Z","scheduled_until":"2026-09-26T12:00:00.000Z"},{"id":"f64vmbvtdyg8","name":"AURA, BIT, BOND, BSX, FARM, GARI, K, KET, KINTO, LOBO, MOON, MV, NYM, RAIIN, RHEA, SAROS, SDN, SPC, SPICE, TEA, TEER Delisting","status":"scheduled","created_at":"2026-05-19T07:27:51.043Z","updated_at":"2026-05-19T07:27:51.106Z","monitoring_at":null,"resolved_at":null,"impact":"maintenance","shortlink":"https://stspg.io/c7sdrfg41384","started_at":"2026-05-19T07:27:51.039Z","page_id":"lfz25gyhcpjf","incident_updates":[{"id":"l2k942cp22vz","status":"scheduled","body":"As part of our regular asset reviews, Kraken will begin a scheduled delisting cycle for the following assets: AURA, BIT, BOND, BSX, FARM, GARI, K, KET, KINTO, LOBO, MOON, MV, NYM, RAIIN, RHEA, SAROS, SDN, SPC, SPICE, TEA, and TEER.\n\nSome of these assets are not currently available for trading. For those assets, the trading timeline below will not apply, but all other dates remain the same.\n\nTEER notice: TEER has ceased operations and on-chain transactions will not go through. Trading and funding for TEER is paused and will remain paused.\n\nKey dates:\n- May 29 at 14:00 UTC: Deposits and trading will be disabled \n- August 27 at 14:00 UTC: Withdrawals will be disabled \n- September 1 to September 5: Any remaining balances will be liquidated\n\nWithdrawals will remain available until August 27 at 13:59 UTC. Review your portfolio and take any necessary action before this deadline.\n\nCurrently, several of these assets have limited or inactive markets. As a result, liquidation prices may be significantly below recent reference prices and, in some cases, may result in minimal or no proceeds due to insufficient market liquidity at the time of execution.\n\nThe denomination of liquidation proceeds is determined by prevailing market conditions and cannot be guaranteed or confirmed prior to execution.","incident_id":"f64vmbvtdyg8","created_at":"2026-05-19T07:27:51.104Z","updated_at":"2026-05-19T07:27:51.104Z","display_at":"2026-05-19T07:27:51.104Z","affected_components":null,"deliver_notifications":false,"custom_tweet":null,"tweet_id":null}],"components":[],"scheduled_for":"2026-09-05T23:00:00.000Z","scheduled_until":"2026-09-06T00:00:00.000Z"},{"id":"5mh0c1qz5rr9","name":"PLANCK, AIR, MICHI, FLY, ANLOG, TERM, STRD Delisting","status":"scheduled","created_at":"2026-05-07T01:43:56.994Z","updated_at":"2026-05-07T01:43:57.103Z","monitoring_at":null,"resolved_at":null,"impact":"maintenance","shortlink":"https://stspg.io/dtzljjswck4w","started_at":"2026-05-07T01:43:56.976Z","page_id":"lfz25gyhcpjf","incident_updates":[{"id":"fdybp9t8wqm4","status":"scheduled","body":"As part of our regular asset reviews, Kraken will begin a scheduled delisting cycle for the following assets: PLANCK, AIR, MICHI, FLY, ANLOG, TERM, and STRD.\n\nKey dates:\n\nMay 1 at 14:00 UTC: Deposits and markets will be disabled \nJuly 31 at 14:00 UTC: Withdrawals will be disabled \nAugust 3 to August 7: Any remaining balances will be liquidated\nWithdrawals will remain available until July 31 at 13:59 UTC.\nWe recommend reviewing your portfolio and taking any necessary action before this deadline.\n\nSeveral of these assets have limited or inactive markets.\nAs a result, liquidation prices may be significantly below recent reference prices and, in some cases, may result in minimal or no proceeds due to insufficient market liquidity at the time of execution.\n\nThe denomination of liquidation proceeds is determined by prevailing market conditions and cannot be guaranteed or confirmed prior to execution.","incident_id":"5mh0c1qz5rr9","created_at":"2026-05-07T01:43:57.099Z","updated_at":"2026-05-07T01:43:57.099Z","display_at":"2026-05-07T01:43:57.099Z","affected_components":[{"code":"jxndkmfsl4vv","name":"Digital Currency Funding - Altair (AIR)","old_status":"operational","new_status":"operational"},{"code":"lhjbf1pmw972","name":"Digital Currency Funding - Analog (ANLOG) - Ethereum","old_status":"operational","new_status":"operational"},{"code":"6nb8lqbwfkdg","name":"Digital Currency Funding - Fly Trade (FLY) - Sonic","old_status":"operational","new_status":"operational"},{"code":"6h9kxsfmz4b9","name":"Digital Currency Funding - Michi (MICHI) - Solana","old_status":"operational","ne