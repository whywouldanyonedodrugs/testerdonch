s during this timeframe. Deposits and withdrawals initiated during the maintenance may be delayed. Sign-in and other non-trading related features will be operational. We kindly advise all our clients to plan ahead accordingly and make necessary account adjustments prior to the start of the maintenance. Following maintenance, markets will briefly enter cancel-only mode, and then post-only mode, before returning to full functionality.","incident_id":"1jvthr94v5nx","created_at":"2026-07-07T10:53:24.329Z","updated_at":"2026-07-08T11:09:41.814Z","display_at":"2026-07-07T10:53:24.329Z","affected_components":[{"code":"mhcnmhlldpkh","name":"Website","old_status":"operational","new_status":"operational"},{"code":"pwc5xxqb9057","name":"Kraken API - FIX","old_status":"operational","new_status":"operational"},{"code":"cfpbbhgnlnbf","name":"Kraken API - REST","old_status":"operational","new_status":"operational"},{"code":"vz83fx0396f0","name":"Kraken API - Websocket","old_status":"operational","new_status":"operational"},{"code":"r7q2svsg42cs","name":"Kraken API - Embed","old_status":"operational","new_status":"operational"}],"deliver_notifications":true,"custom_tweet":null,"tweet_id":null}],"components":[{"id":"mhcnmhlldpkh","name":"Website","status":"operational","created_at":"2016-02-10T19:21:13.853Z","updated_at":"2026-07-14T15:20:12.699Z","position":1,"description":null,"showcase":false,"start_date":null,"group_id":null,"page_id":"lfz25gyhcpjf","group":false,"only_show_if_degraded":false},{"id":"pwc5xxqb9057","name":"FIX","status":"operational","created_at":"2024-01-24T10:12:01.342Z","updated_at":"2026-07-13T07:06:26.052Z","position":1,"description":null,"showcase":false,"start_date":"2024-01-24","group_id":"qkyy5vkk5zpx","page_id":"lfz25gyhcpjf","group":false,"only_show_if_degraded":false},{"id":"cfpbbhgnlnbf","name":"REST","status":"operational","created_at":"2016-02-10T20:11:14.871Z","updated_at":"2026-07-13T07:06:26.073Z","position":2,"description":null,"showcase":false