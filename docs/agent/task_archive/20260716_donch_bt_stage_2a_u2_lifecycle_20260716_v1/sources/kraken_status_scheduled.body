fers","status":"operational","created_at":"2024-11-21T16:26:17.350Z","updated_at":"2026-07-13T07:10:33.180Z","position":5,"description":null,"showcase":false,"start_date":"2024-11-21","group_id":"wbb1tdgdzgmc","page_id":"lfz25gyhcpjf","group":false,"only_show_if_degraded":false}],"scheduled_for":"2026-07-02T07:00:00.000Z","scheduled_until":"2026-07-02T07:15:00.000Z"},{"id":"77rqn7tzcxln","name":"IP/USD pair delisting on Kraken Prop","status":"completed","created_at":"2026-06-30T13:39:55.968Z","updated_at":"2026-07-01T14:30:09.397Z","monitoring_at":null,"resolved_at":"2026-07-01T14:30:09.301Z","impact":"maintenance","shortlink":"https://stspg.io/3w43d6vny5mj","started_at":"2026-06-30T13:39:55.961Z","page_id":"lfz25gyhcpjf","incident_updates":[{"id":"78dzp06fhzqq","status":"completed","body":"The scheduled maintenance has been completed.","incident_id":"77rqn7tzcxln","created_at":"2026-07-01T14:30:09.301Z","updated_at":"2026-07-01T14:30:09.301Z","display_at":"2026-07-01T14:30:09.301Z","affected_components":null,"deliver_notifications":false,"custom_tweet":null,"tweet_id":null},{"id":"r46mtt7rycdw","status":"in_progress","body":"Scheduled maintenance is currently in progress. We will provide updates as necessary.","incident_id":"77rqn7tzcxln","created_at":"2026-07-01T13:30:07.787Z","updated_at":"2026-07-01T13:30:07.787Z","display_at":"2026-07-01T13:30:07.787Z","affected_components":null,"deliver_notifications":false,"custom_tweet":null,"tweet_id":null},{"id":"y0l0t7xvy80q","status":"scheduled","body":"The IP token is being renamed to DATA. As a result, the IP market will no longer be supported and IP/USD will no longer be available to trade on Kraken Prop.\n\nAs of Wednesday, July 1 at 14:00 UTC, any open IP/USD positions will be automatically closed at a current market price, and the pair will be delisted.\nTo control your exit price, close your open position before 14:00 UTC on July 1.\n\nThis only affects IP/USD. All other positions in your Kraken Prop account remain unaffected.","incident_id":"77rqn7tzcxln","created_at":"2026-06-30T13:39:56.063Z","updated_at":"2026-06-30T13:39:56.063Z","display_at":"2026-06-30T13:39:56.063Z","affected_components":null,"deliver_notifications":false,"custom_tweet":null,"tweet_id":null}],"components":[],"scheduled_for":"2026-07-01T13:30:00.000Z","scheduled_until":"2026-07-01T14:30:00.000Z"},{"id":"wtyfy8jxqwvw","name":"Scheduled Maintenance: Order Entry System Update","status":"completed","created_at":"2026-06-30T11:32:13.567Z","updated_at":"2026-07-01T10:09:42.447Z","monitoring_at":null,"resolved_at":"2026-07-01T10:09:42.425Z","impact":"maintenance","shortlink":"https://stspg.io/d2tx5ckbzj5w","started_at":"2026-06-30T11:32:13.543Z","page_id":"lfz25gyhcpjf","incident_updates":[{"id":"k3xxwzmb6cks","status":"completed","body":"The scheduled maintenance has been completed.","incident_id":"wtyfy8jxqwvw","created_at":"2026-07-01T10:09:42.425Z","updated_at":"2026-07-01T10:09:42.425Z","display_at":"2026-07-01T10:09:42.425Z","affected_components":[{"code":"mhcnmhlldpkh","name":"Website","old_status":"degraded_performance","new_status":"operational"},{"code":"pwc5xxqb9057","name":"Kraken API - FIX","old_status":"degraded_performance","new_status":"operational"},{"code":"vz83fx0396f0","name":"Kraken API - Websocket","old_status":"degraded_performance","new_status":"operational"},{"code":"lrx5gjxzw65q","name":"Kraken Pro App","old_status":"degraded_performance","new_status":"operational"},{"code":"0jb43711rs84","name":"Krak App","old_status":"degraded_performance","new_status":"operational"},{"code":"btr7ydhgj4vf","name":"Kraken App","old_status":"degraded_performance","new_status":"operational"}],"deliver_notifications":true,"custom_tweet":null,"tweet_id":null},{"id":"80fwthpbwvjl","status":"in_progress","body":"Scheduled maintenance is still in progress. We will provide updates as necessary.","incident_id":"wtyfy8jxqwvw","created_at":"2026-07-01T09:43:49.575Z","updated_at":"2026-07-01T09:54:07.915Z","display_at":"2026-07-01T09:43:49.575Z","affected_components":[{"code":"mhcnmhlldpkh","name":"Website","old_status":"under_maintenance","new_status":"degraded_performance"},{"code":"pwc5xxqb9057","name":"Kraken API - FIX","old_status":"under_maintenance","new_status":"degraded_performance"},{"code":"vz83fx0396f0","name":"Kraken API - Websocket","old_status":"under_maintenance","new_status":"degraded_performance"},{"code":"lrx5gjxzw65q","name":"Kraken Pro App","old_status":"under_maintenance","new_status":"degraded_performance"},{"code":"0jb43711rs84","name":"Krak App","old_status":"under_maintenance","new_status":"degraded_performance"},{"code":"btr7ydhgj4vf","name":"Kraken App","old_status":"under_maintenance","new_status":"degraded_performance"}],"deliver_notifications":true,"custom_tweet":null,"tweet_id":null},{"id":"dn6s7jm52698","status":"in_progress","body":"Scheduled maintenance is currently in progress. We will provide updates as necessary.","incident_id":"wtyfy8jxqwvw","created_at":"2026-07-01T09:00:08.231Z","updated_at":"2026-07-01T09:00:08.231Z","display_at":"2026-07-01T09:00:08.231Z","affected_components":[{"code":"mhcnmhlldpkh","name":"Website","old_status":"operational","new_status":"under_maintenance"},{"code":"pwc5xxqb9057","name":"Kraken API - FIX","old_status":"operational","new_status":"under_maintenance"},{"code":"vz83fx0396f0","name":"Kraken API - Websocket","old_status":"operational","new_status":"under_maintenance"},{"code":"lrx5gjxzw65q","name":"Kraken Pro App","old_status":"operational","new_status":"under_maintenance"},{"code":"0jb43711rs84","name":"Krak App","old_status":"operational","new_status":"under_maintenance"},{"code":"btr7ydhgj4vf","name":"Kraken App","old_status":"operational","new_status":"under_maintenance"}],"deliver_notifications":true,"custom_tweet":null,"tweet_id":null},{"id":"521xzl2zwm3y","status":"scheduled","body":"Maintenance will begin as scheduled in 60 minutes.","incident_id":"wtyfy8jxqwvw","created_at":"2026-07-01T08:00:28.375Z","updated_at":"2026-07-01T08:00:28.375Z","display_at":"2026-07-01T08:00:28.375Z","affected_components":null,"deliver_notifications":true,"custom_tweet":null,"tweet_id":null},{"id":"rfmg3wx67mmg","status":"scheduled","body":"We will be performing scheduled maintenance to our order entry system on Wednesday, July 1st starting at approximately 09:00 UTC. This maintenance is expected to take 30–60 minutes.\nDuring this window, clients may experience the following:\n\n- Web, mobile, and desktop trading: a very small number of order placements/modifications may be rejected\n- WebSocket API: a small number of order placements/modifications may be rejected, with a brief increase in latency\n- FIX API: order placements/modifications may be rejected for several seconds, with a brief increase in latency\n\nNo action is required on your end. We will post an update once maintenance is complete.","incident_id":"wtyfy8jxqwvw","created_at":"2026-06-30T11:32:13.729Z","updated_at":"2026-06-30T11:32:13.729Z","display_at":"2026-06-30T11:32:13.729Z","affected_components":[{"code":"mhcnmhlldpkh","name":"Website","old_status":"operational","new_status":"operational"},{"code":"pwc5xxqb9057","name":"Kraken API - FIX","old_status":"operational","new_status":"operational"},{"code":"vz83fx0396f0","name":"Kraken API - Websocket","old_status":"operational","new_status":"operational"},{"code":"lrx5gjxzw65q","name":"Kraken Pro App","old_status":"operational","new_status":"operational"},{"code":"0jb43711rs84","name":"Krak App","old_status":"operational","new_status":"operational"},{"code":"btr7ydhgj4vf","name":"Kraken App","old_status":"operational","new_status":"operational"}],"deliver_notifications":true,"custom_tweet":null,"tweet_id":null}],"components":[{"id":"mhcnmhlldpkh","name":"Website","status":"operational","created_at":"2016-02-10T19:21:13.853Z","updated_at":"2026-07-14T15:20:12.699Z","position":1,"description":null,"showcase":false,"start_date":null,"group_id":null,"page_id":