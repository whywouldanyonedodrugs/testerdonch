0.515Z","display_at":"2026-06-10T15:59:40.515Z","affected_components":[{"code":"lrx5gjxzw65q","name":"Kraken Pro App","old_status":"degraded_performance","new_status":"operational"},{"code":"0jb43711rs84","name":"Krak App","old_status":"degraded_performance","new_status":"operational"},{"code":"btr7ydhgj4vf","name":"Kraken App","old_status":"degraded_performance","new_status":"operational"}],"deliver_notifications":true,"custom_tweet":null,"tweet_id":null},{"id":"kfy0znr0k7lr","status":"identified","body":"New Breakout and Kraken Pro app versions containing the fix has been released and are available in Google Play.\nWe are continuing to work on a fix for Kraken and Krak apps.\nWe'll update this as soon as we have more information.","incident_id":"bj69kdy4fl41","created_at":"2026-06-10T13:38:28.483Z","updated_at":"2026-06-10T13:38:28.483Z","display_at":"2026-06-10T13:38:28.483Z","affected_components":[{"code":"lrx5gjxzw65q","name":"Kraken Pro App","old_status":"degraded_performance","new_status":"degraded_performance"},{"code":"0jb43711rs84","name":"Krak App","old_status":"degraded_performance","new_status":"degraded_performance"},{"code":"btr7ydhgj4vf","name":"Kraken App","old_status":"degraded_performance","new_status":"degraded_performance"}],"deliver_notifications":true,"custom_tweet":null,"tweet_id":null},{"id":"8l8r02qpxwmw","status":"identified","body":"We've identified an issue affecting Users on older Android devices (Android 15 and earlier) that may prevent them from signing in or using the Kraken, Kraken Pro, Krak, and Breakout Android apps. iOS apps and access via a web browser at kraken.com are not affected. \n\nNew Breakout app version containing the fix has been released and is available in Google Play.\nWe are continuing to work on a fix for Kraken, Kraken Pro and Krak apps.\nWe'll update this as soon as we have more information.","incident_id":"bj69kdy4fl41","created_at":"2026-06-10T12:16:37.126Z","updated_at":"2026-06-10T12:16:37.126Z","display_at"