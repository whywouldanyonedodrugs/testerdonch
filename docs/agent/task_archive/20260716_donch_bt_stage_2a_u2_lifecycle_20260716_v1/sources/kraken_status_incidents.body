r","shortlink":"https://stspg.io/lkrrtx451ldf","started_at":"2026-06-09T03:58:07.450Z","page_id":"lfz25gyhcpjf","incident_updates":[{"id":"h8vzhc2h85ng","status":"resolved","body":"This incident has been resolved.","incident_id":"db7sqxxl8727","created_at":"2026-06-26T20:20:49.499Z","updated_at":"2026-06-26T20:20:49.499Z","display_at":"2026-06-26T20:20:49.499Z","affected_components":[{"code":"5yshwl1xs73q","name":"Digital Currency Funding - Humanity (H) - Ethereum","old_status":"degraded_performance","new_status":"operational"}],"deliver_notifications":true,"custom_tweet":null,"tweet_id":null},{"id":"n505xxy5zwvk","status":"identified","body":"Trading and funding for Humanity (H) on Ethereum remain paused following a security incident affecting the Humanity Protocol. This was caused by an external exploit on H.\n\nKraken's systems were not affected and customer funds held with Kraken are safe. \n\nDetails from the Humanity team are available here: https://www.humanity.org/hincidentupdate\n\nWe are in discussions with the Humanity team on next steps and will provide updates as they become available. Platform activity for H will remain paused in the meantime. We apologize for any inconvenience caused.","incident_id":"db7sqxxl8727","created_at":"2026-06-15T23:16:18.628Z","updated_at":"2026-06-15T23:16:18.628Z","display_at":"2026-06-15T23:16:18.628Z","affected_components":[{"code":"5yshwl1xs73q","name":"Digital Currency Funding - Humanity (H) - Ethereum","old_status":"degraded_performance","new_status":"degraded_performance"}],"deliver_notifications":true,"custom_tweet":null,"tweet_id":null},{"id":"qbd4t266vkky","status":"investigating","body":"Trading pairs for Humanity (H) have been moved to cancel-only mode. We are actively monitoring the situation and will provide updates as they become available. We apologise for any inconvenience caused.","incident_id":"db7sqxxl8727","created_at":"2026-06-09T08:27:29.400Z","updated_at":"2026-06-09T08:27:29.400Z","display_at":"2026-06-09T08:27:29.400Z","affected_components":[{"code":"5yshwl1xs73q","name":"Digital Currency Funding - Humanity (H) - Ethereum","old_status":"degraded_performance","new_status":"degraded_performance"}],"deliver_notifications":true,"custom_tweet":null,"tweet_id":null},{"id":"25qs9pkr78mg","status":"investigating","body":"We're investigating an issue with the [Humanity] ([H]) funding gateway. Deposits and withdrawals may be delayed at this time. All other funding methods are operating normally. We are working diligently to resolve the issue and will keep you updated.","incident_id":"db7sqxxl8727","created_at":"2026-06-09T03:58:07.568Z","updated_at":"2026-06-09T03:58:07.568Z","display_at":"2026-06-09T03:58:07.568Z","affected_components":[{"code":"5yshwl1xs73q","name":"Digital Currency Funding - Humanity (H) - Ethereum","old_status":"operational","new_status":"degraded_performance"}],"deliver_notifications":true,"custom_tweet":null,"tweet_id":null}],"components":[{"id":"5yshwl1xs73q","name":"Humanity (H) - Ethereum","status":"operational","created_at":"2025-09-01T12:49:54.059Z","updated_at":"2026-07-16T08:22:19.929Z","position":280,"description":null,"showcase":false,"start_date":"2025-09-01","group_id":"8nh7rvvs6mjh","page_id":"lfz25gyhcpjf","group":false,"only_show_if_degraded":false}],"reminder_intervals":null},{"id":"73cbh700gsgl","name":"Issues During New Account Onboarding on the Kraken App","status":"resolved","created_at":"2026-06-26T14:01:20.377Z","updated_at":"2026-06-26T14:15:37.304Z","monitoring_at":null,"resolved_at":"2026-06-26T14:15:37.289Z","impact":"minor","shortlink":"https://stspg.io/n66m0kskbs9x","started_at":"2026-06-26T14:01:20.369Z","page_id":"lfz25gyhcpjf","incident_updates":[{"id":"5fzvkvf2202b","status":"resolved","body":"This incident has been resolved.","incident_id":"73cbh700gsgl","created_at":"2026-06-26T14:15:37.289Z","updated_at":"2026-06-26T14:15:37.289Z","display_at":"2026-06-26T14:15:37.289Z","affected_components":[{"code":"btr7ydhgj4v